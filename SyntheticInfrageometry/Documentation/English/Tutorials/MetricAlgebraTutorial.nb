Notebook[{
Cell["Metric Algebra Tutorial", "Title",ExpressionUUID->"2a9cf7c5-3d5b-4056-9795-2b8ba6674e8e"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"201489a6-1011-4c1c-8848-b002d21ab59c"],

Cell["\<\
A worked tour of the metric-algebra layer: inner products from distances \
(Schoenberg and parallelogram), angles at a vertex, comparison triangles, \
CAT(k) thinness, and the local Alexandrov upper-curvature bound.\
\>", "Text",ExpressionUUID->"b831b918-77b2-43aa-ac3f-73871d51cd47"],

Cell["Setup", "Section",ExpressionUUID->"ed8c96c5-eaf9-44d5-ad1c-e30857f830a7"],

Cell["Load the dev paclet and the package context.", "CodeText",ExpressionUUID->"ee35af62-c0be-4c7c-ad7a-3b13f73fb4de"],

Cell[BoxData[
 RowBox[{"Defer", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<../../..\>\""}], 
       "}"}], "]"}], "]"}], ";"}], ",", 
   RowBox[{
    RowBox[{
    "Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", "]"}], 
    ";"}]}], "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"1284afb3-211f-4484-aad0-f911677761d2"],

Cell["Two working graphs.", "CodeText",ExpressionUUID->"1090f985-ead1-45f1-8f52-d74269f9d2a3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"4", ",", "4"}], "}"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"42b14913-271d-4c77-8115-0e6824c37d69"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p", "=", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "7", "]"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"37b60666-b3f2-4e9c-af21-b40ebe1154b1"],

Cell["Inner product from distances", "Section",ExpressionUUID->"0866f8ea-888f-45d6-b70a-2ce92d1bd51e"],

Cell["Schoenberg form at base point 4 on a path.", "CodeText",ExpressionUUID->"30391c74-9bc2-461f-bdda-0f7005c3b1aa"],

Cell[BoxData[
 RowBox[{"InfraScalarProduct", "[", 
  RowBox[{"p", ",", "4", ",", "1", ",", "7"}], "]"}]], "Input",ExpressionUUID->\
"c9d4d34e-daba-44ea-8311-c155761a0816"],

Cell["On a grid, base point at the centre.", "CodeText",ExpressionUUID->"dc960a3a-8afa-4e31-9753-b0cf4d415407"],

Cell[BoxData[
 RowBox[{"InfraScalarProduct", "[", 
  RowBox[{"g", ",", "6", ",", "1", ",", "11"}], "]"}]], "Input",ExpressionUUID\
->"e950840f-9ded-4abc-879f-6daaa8752f2b"],

Cell["Parallelogram polarisation method.", "CodeText",ExpressionUUID->"44da75b0-6017-4449-a677-21007870ab36"],

Cell[BoxData[
 RowBox[{"InfraScalarProduct", "[", 
  RowBox[{"g", ",", "6", ",", "1", ",", "11", ",", 
   RowBox[{"Method", "\[Rule]", "\"\<Parallelogram\>\""}]}], "]"}]], "Input",E\
xpressionUUID->"de4de79d-c9d4-44fa-8f22-b18709b562ae"],

Cell["Linear combinations of vertices", "Section",ExpressionUUID->"0a692877-f31c-4346-b57c-7ff041968b14"],

Cell["\<\
Realisation of 2 * 2 (scale by 2) with base point 1 on a path.\
\>", "CodeText",ExpressionUUID->"368de381-4c1e-45ed-9f6d-0522c215143b"],

Cell[BoxData[
 RowBox[{"FindInfraLinearCombination", "[", 
  RowBox[{"p", ",", "1", ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"2", ",", "2"}], "}"}], "}"}], ",", "All"}], "]"}]], "Input",Expr\
essionUUID->"11e783c9-4b90-425e-a971-92f7d6ccd44c"],

Cell["Two-term sum u + v on a grid.", "CodeText",ExpressionUUID->"42e6e2dc-8521-48d7-bbc5-62f4a7d95895"],

Cell[BoxData[
 RowBox[{"FindInfraLinearCombination", "[", 
  RowBox[{"g", ",", "6", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "11"}], "}"}]}], "}"}], ",", "All"}], "]"}]], "Input",\
ExpressionUUID->"aa376ae2-8972-46d0-acfd-fb99ff1456d4"],

Cell["Angles", "Section",ExpressionUUID->"45a25377-3723-4e17-9e62-bdd89ab20f0a"],

Cell["Punch-out angle at the centre of g.", "CodeText",ExpressionUUID->"df4bc8c8-271d-4ff6-a543-7f6188a87b74"],

Cell[BoxData[
 RowBox[{"InfraAngle", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "6", ",", "11"}], "}"}]}], "]"}]], "Input",ExpressionUUI\
D->"f3ec1100-0f53-4a65-95f9-8a4f63f33dd6"],

Cell["Comparison-triangle angle in the Euclidean model.", "CodeText",ExpressionUUID->"d012abe9-f786-4c25-ab79-b55789249209"],

Cell[BoxData[
 RowBox[{"InfraAngle", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "6", ",", "11"}], "}"}], ",", 
   RowBox[{"Method", "\[Rule]", "\"\<Comparison\>\""}]}], "]"}]], "Input",Expr\
essionUUID->"9a99c7da-2b5c-434a-a0c3-7681d4c3554b"],

Cell["Comparison angle in M_k^2 with negative curvature.", "CodeText",ExpressionUUID->"fbe01d39-1b16-4034-a033-8d1a40c64994"],

Cell[BoxData[
 RowBox[{"InfraAngle", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "6", ",", "11"}], "}"}], ",", 
   RowBox[{"Method", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Comparison\>\"", ",", 
      RowBox[{"\"\<Curvature\>\"", "\[Rule]", 
       RowBox[{"-", "1"}]}]}], "}"}]}]}], "]"}]], "Input",ExpressionUUID->\
"36d9bd4f-96cb-45e1-a4ba-5dac373316ee"],

Cell["Comparison triangles", "Section",ExpressionUUID->"17000f87-888f-41af-b05e-3ad0f0085cfe"],

Cell["Euclidean comparison triangle with sides 3, 4, 5.", "CodeText",ExpressionUUID->"44639d93-4a44-46f2-9e18-2df1a20a7110"],

Cell[BoxData[
 RowBox[{"ComparisonTriangle", "[", 
  RowBox[{"3", ",", "4", ",", "5"}], "]"}]], "Input",ExpressionUUID->\
"e8bc6673-6b3a-4e26-9d7e-5bb206d17d14"],

Cell["Spherical triangle and its angles.", "CodeText",ExpressionUUID->"96bd41aa-b7f8-47b3-8fff-92f9fe696774"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ComparisonTriangle", "[", 
   RowBox[{"1", ",", "1", ",", "1", ",", 
    RowBox[{"\"\<Curvature\>\"", "\[Rule]", "1"}]}], "]"}], 
  "[", "\"\<Angles\>\"", "]"}]], "Input",ExpressionUUID->"dc074808-407d-433e-\
9994-2858b56c7913"],

Cell["Hyperbolic triangle from graph distances.", "CodeText",ExpressionUUID->"8d213818-e4d2-4636-aa71-6acfe0e8157f"],

Cell[BoxData[
 RowBox[{"ComparisonTriangle", "[", 
  RowBox[{"g", ",", "1", ",", "6", ",", "11", ",", 
   RowBox[{"\"\<Curvature\>\"", "\[Rule]", 
    RowBox[{"-", "1"}]}]}], "]"}]], "Input",ExpressionUUID->"dc8cd8d0-21e6-\
49d6-bc21-d0e8fe5b1624"],

Cell["CAT(k) thinness", "Section",ExpressionUUID->"4caa7d5e-84b0-4c0b-a87d-33571491a3b1"],

Cell["A 4x4-grid triangle satisfies CAT(0).", "CodeText",ExpressionUUID->"95ec1146-e7fc-4b0a-9bc3-cdd25c083416"],

Cell[BoxData[
 RowBox[{"CATInequalityQ", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "6", ",", "11"}], "}"}]}], "]"}]], "Input",ExpressionUUI\
D->"5245edb4-cab1-4925-974d-c7be80fca4f6"],

Cell["Same triangle in the CAT(-1) model.", "CodeText",ExpressionUUID->"22415068-1dbc-4d1a-a29f-802513d62d80"],

Cell[BoxData[
 RowBox[{"CATInequalityQ", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "6", ",", "11"}], "}"}], ",", 
   RowBox[{"-", "1"}]}], "]"}]], "Input",ExpressionUUID->"ef3bdb0e-dc48-457f-\
9390-9c8a1740a129"],

Cell["Local Alexandrov curvature", "Section",ExpressionUUID->"d90508ae-d942-4c6d-87f1-ec31269771a7"],

Cell["Curvature at the centre of g.", "CodeText",ExpressionUUID->"a02376db-5653-45af-8b99-3ea398891eb5"],

Cell[BoxData[
 RowBox[{"InfraCurvature", "[", 
  RowBox[{"g", ",", "6"}], "]"}]], "Input",ExpressionUUID->"f3121915-d84c-\
4980-966a-53067345e975"],

Cell["Curvature at every vertex of a 3x3 grid.", "CodeText",ExpressionUUID->"eafb0f7a-e136-49fb-9ffc-3eb5281f9c2d"],

Cell[BoxData[
 RowBox[{"InfraCurvature", "[", 
  RowBox[{"GridGraph", "[", 
   RowBox[{"{", 
    RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"4c25d359-0902-41cf-b80a-d36f2bfd81ae"],

Cell["See also", "Section",ExpressionUUID->"4b3d56bb-1f45-4a0c-99bc-954f455f0015"],

Cell["MetricAlgebraGuide", "Item",ExpressionUUID->"932c217d-c107-4141-9fb7-ab4c5b84b64c"],

Cell["EuclideanGeometryTutorial", "Item",ExpressionUUID->"c3221b22-72bb-4ab0-bfa3-7c925cb9f58b"],

Cell["CoordinatizationTutorial", "Item",ExpressionUUID->"2b182b24-c3b0-4e4c-be71-3f5975544627"]
},
