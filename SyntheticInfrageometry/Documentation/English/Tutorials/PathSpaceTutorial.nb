Notebook[{
Cell["Path Space Tutorial", "Title",ExpressionUUID->"932a0318-8c98-4742-aea6-98469e437aad"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"d5d61cac-0c0e-4371-bba9-c72ed58434b2"],

Cell["\<\
A worked tour of the path-space layer: how to treat the bundle of geodesics \
between two vertices as a finite metric space, pick central / peripheral / \
embedding-closest representatives, and rebuild the underlying geodesic graph.\
\
\>", "Text",ExpressionUUID->"80a2b776-72b7-479e-9ac9-1bb503d9c7ac"],

Cell["Setup", "Section",ExpressionUUID->"6354179c-0501-4fe8-a65f-4f78f137abdd"],

Cell["Load the dev paclet and the package context.", "CodeText",ExpressionUUID->"2439b572-0d46-4e7d-97b6-72aa1bfcbf4d"],

Cell[BoxData[
 RowBox[{"Defer", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<../../..\>\""}], 
       "}"}], "]"}], "]"}], ";"}], ",", 
   RowBox[{
    RowBox[{
    "Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", "]"}], 
    ";"}]}], "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"2bca31aa-7ef2-4b23-a2c9-dda8a8ac1aac"],

Cell["Two working graphs.", "CodeText",ExpressionUUID->"8001ea5e-8d2f-4b50-bca0-7c70ac42a6b7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"4", ",", "4"}], "}"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"f75ac25f-11e7-452f-a5e2-23ffd8829986"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g2", "=", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"5", ",", "5"}], "}"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"e0eed2ff-c2b2-421a-b025-bb2556c64590"],

Cell["The geodesic bundle", "Section",ExpressionUUID->"ed3efe6b-c45f-493e-bf81-0cc876e7081f"],

Cell["Every geodesic between opposite corners of g.", "CodeText",ExpressionUUID->"5468635f-6828-45e7-bd59-dcacfb1f4318"],

Cell[BoxData[
 RowBox[{
  RowBox[{"paths", "=", 
   RowBox[{"FindSegment", "[", 
    RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}]}], ";"}]], "Input",E\
xpressionUUID->"d22e3248-72a4-448e-88b3-784416a38b35"],

Cell["Cardinality.", "CodeText",ExpressionUUID->"9127e6d2-9e0f-4ed9-a87a-1802cb9b6836"],

Cell[BoxData[
 RowBox[{"Length", "[", "paths", "]"}]], "Input",ExpressionUUID->"e73670cd-531c-4ca6-8ac8-92c31f6987af"],

Cell["Diffuse rendering of the whole bundle.", "CodeText",ExpressionUUID->"76dbf237-db9c-44b1-89ab-872d15b9a139"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", "paths", "}"}]}], "]"}]], "Input",ExpressionUUID->"6239ff41-\
4789-4be1-9a7b-80f17af206a3"],

Cell["Central and peripheral selectors", "Section",ExpressionUUID->"8094951a-4002-4690-884b-246fc4a8e335"],

Cell["One central geodesic.", "CodeText",ExpressionUUID->"57e6284b-8452-46bf-923a-5395652aeeff"],

Cell[BoxData[
 RowBox[{"SelectPath", "[", 
  RowBox[{"g", ",", "paths", ",", "1", ",", 
   RowBox[{"\"\<From\>\"", "\[Rule]", "\"\<Center\>\""}]}], "]"}]], "Input",Ex\
pressionUUID->"73308a48-bdcd-451f-a696-f230b79929e3"],

Cell["Two peripheral ones.", "CodeText",ExpressionUUID->"fec6954a-b393-4026-a502-988171a761f7"],

Cell[BoxData[
 RowBox[{"SelectPath", "[", 
  RowBox[{"g", ",", "paths", ",", "2", ",", 
   RowBox[{"\"\<From\>\"", "\[Rule]", "\"\<Periphery\>\""}]}], "]"}]], "Input",\
ExpressionUUID->"863bf2f6-dcf4-48bb-b93a-2bde159de49e"],

Cell["Render the central path against the full bundle.", "CodeText",ExpressionUUID->"3d42daa3-64fe-422b-9e8f-cf1a15066947"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"paths", "\[Rule]", "LightGray"}], ",", 
     RowBox[{
      RowBox[{"SelectPath", "[", 
       RowBox[{"g", ",", "paths", ",", "1", ",", 
        RowBox[{"\"\<From\>\"", "\[Rule]", "\"\<Center\>\""}]}], "]"}], "\[Rule]",
       "Blue"}]}], "}"}]}], "]"}]], "Input",ExpressionUUID->"d0d616c9-413f-\
489d-a09c-cee28ed7e82f"],

Cell["Embedding-closest selector", "Section",ExpressionUUID->"4fdb2102-41fe-4259-93c5-11de514b7619"],

Cell["\<\
Paths whose drawing under GraphEmbedding is Hausdorff-closest to the straight \
Euclidean segment 1-16.\
\>", "CodeText",ExpressionUUID->"e02274c4-0bbb-441b-a52e-5fca6424a0a8"],

Cell[BoxData[
 RowBox[{"EmbeddingClosestPaths", "[", 
  RowBox[{"g", ",", "paths", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "16"}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"feed7dde-d2c9-47b7-9021-7f16e25db5c9"],

Cell["Path-space metric", "Section",ExpressionUUID->"3d88838a-de7a-45af-8fd3-8ea7fa97d754"],

Cell["\<\
Frechet distance is order-sensitive (different from Hausdorff).\
\>", "CodeText",ExpressionUUID->"721d79dd-6230-40c0-846a-e65360f1662e"],

Cell[BoxData[
 RowBox[{"SelectPath", "[", 
  RowBox[{"g", ",", "paths", ",", "1", ",", 
   RowBox[{"\"\<From\>\"", "\[Rule]", "\"\<Center\>\""}], ",", 
   RowBox[{"\"\<Metric\>\"", "\[Rule]", "\"\<Frechet\>\""}]}], "]"}]], "Input",\
ExpressionUUID->"b8b36e82-1c15-4d07-a92a-1cbc2d413e7d"],

Cell["Cycles in path-space", "Section",ExpressionUUID->"643d5351-4316-4ebd-83c4-685c89eb2ded"],

Cell["All separating cycles at radius 2 around the centre of g2.", "CodeText",ExpressionUUID->"a86d4a50-a2f3-40e9-a259-e6fc7e9d42b5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cycles", "=", 
   RowBox[{"FindCircle", "[", 
    RowBox[{"g2", ",", "13", ",", "2", ",", "All"}], "]"}]}], ";"}]], "Input",\
ExpressionUUID->"d0d9a876-e401-4204-af70-b0b5565ca548"],

Cell["One shortest-circumference cycle.", "CodeText",ExpressionUUID->"59c56ef5-20b3-45be-8b58-8463698b6ab1"],

Cell[BoxData[
 RowBox[{"SelectCycle", "[", 
  RowBox[{"g2", ",", "cycles", ",", "1", ",", 
   RowBox[{"\"\<From\>\"", "\[Rule]", "\"\<ShortestCircumference\>\""}]}], 
  "]"}]], "Input",ExpressionUUID->"5846e192-84ba-4807-be31-6fd7dff3d88f"],

Cell["Diffuse rendering of all cycles.", "CodeText",ExpressionUUID->"1fc8461b-1040-450c-b61f-ca93fbc32261"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{"cycles", "\[Rule]", "Green"}], "}"}]}], "]"}]], "Input",Expressio\
nUUID->"81ef297e-ae9a-44ae-8dd0-e5ad8183eb09"],

Cell["Geodesic graph and subgraph", "Section",ExpressionUUID->"30c3235e-c66c-4c12-9e4e-a9f67ae4f608"],

Cell["BFS DAG rooted at the centre of g.", "CodeText",ExpressionUUID->"f7a878df-d0e8-40a5-b337-206fca20dcac"],

Cell[BoxData[
 RowBox[{"GeodesicGraph", "[", 
  RowBox[{"g", ",", "6"}], "]"}]], "Input",ExpressionUUID->"c453f7c5-eb3c-\
4ebd-9801-dccd86df03ce"],

Cell["Union of all geodesics between two pairs.", "CodeText",ExpressionUUID->"27f7a1b0-3bf4-4601-8a30-be199ec334b7"],

Cell[BoxData[
 RowBox[{"GeodesicSubgraph", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "16"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"4", ",", "13"}], "}"}]}], "}"}]}], "]"}]], "Input",ExpressionUU\
ID->"98aea6a5-61b6-446b-96c2-a5304cb988dd"],

Cell["Single-pair shortest-path subgraph.", "CodeText",ExpressionUUID->"175cc166-f53f-4893-9cdc-edee214b8137"],

Cell[BoxData[
 RowBox[{"PathSubgraph", "[", 
  RowBox[{"g", ",", "1", ",", "16"}], "]"}]], "Input",ExpressionUUID->\
"bc71658d-2eb6-48eb-9849-a6496ba50d9b"],

Cell["Metric interval and multiplicity", "Section",ExpressionUUID->"e185892b-175f-4e2e-a18d-dff6675e981a"],

Cell["Vertices on any geodesic between 1 and 16.", "CodeText",ExpressionUUID->"5f4691a3-05df-41dc-a889-f9b8924c6689"],

Cell[BoxData[
 RowBox[{"MetricInterval", "[", 
  RowBox[{"g", ",", "1", ",", "16"}], "]"}]], "Input",ExpressionUUID->\
"0c2ed625-fbdd-4c38-9d37-1f12db02d62c"],

Cell["Number of geodesics.", "CodeText",ExpressionUUID->"e7b01639-0251-41d3-8092-6f6d849b1799"],

Cell[BoxData[
 RowBox[{"GeodesicMultiplicity", "[", 
  RowBox[{"g", ",", "1", ",", "16"}], "]"}]], "Input",ExpressionUUID->\
"11bd51ae-e94c-4abe-aeed-62a83026b25f"],

Cell["See also", "Section",ExpressionUUID->"d6c06dfb-3d44-4627-b9e2-2b126f5d573b"],

Cell["PathSpaceGuide", "Item",ExpressionUUID->"a339138f-eb2f-4c9e-8d6e-21b5c65af274"],

Cell["EuclideanGeometryTutorial", "Item",ExpressionUUID->"707d1016-62d0-4165-86b5-428b509d6ee4"],

Cell["TropicalConvexityTutorial", "Item",ExpressionUUID->"191bcf9b-fcc0-4935-a542-5ba5a65b1e7b"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
