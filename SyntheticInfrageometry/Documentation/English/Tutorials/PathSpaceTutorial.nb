(* Beginning of Notebook Content *)
Notebook[{
Cell["PathSpace Tutorial", "Title",ExpressionUUID->"118aaf7f-276b-4089-ade4-3513708139b1"],

Cell["\<\
This tutorial starts with full Euclidean multiplicity and then filters it \
down by path-space criteria.\
\>", "Text",ExpressionUUID->"f3647a06-8786-459c-982c-0e4214d69a68"],

Cell["Setup", "Section",ExpressionUUID->"0bc61498-f91f-4c15-bd7e-90e0096f6d4c"],

Cell["Load the paclet and define a grid.", "CodeText",ExpressionUUID->"0db48092-58d6-4be5-b39d-363ffabaaf6f"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"ec4b5de0-da36-4c6e-9f89-0d012fc58a9b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"4", ",", "4"}], "}"}], "]"}]}], ";"}]], "Code",ExpressionUUID->\
"ad6d6833-54cd-460b-b499-f629240ee4ea"],

Cell["Path bundles", "Section",ExpressionUUID->"a7918392-9a3f-419f-997f-7f3decd75f61"],

Cell["Enumerate all geodesics between opposite corners.", "CodeText",ExpressionUUID->"37e660e4-1f15-494d-97d8-24fe11a651b1"],

Cell[BoxData[
 RowBox[{"paths", "=", 
  RowBox[{"FindSegment", "[", 
   RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}]}]], "Input",Expressio\
nUUID->"38e57125-a071-4698-90d1-27f4b196ff3b"],

Cell["Keep the central paths.", "CodeText",ExpressionUUID->"3b6eae67-cf9a-4800-8880-1e47134ed8f1"],

Cell[BoxData[
 RowBox[{"SelectPaths", "[",
  RowBox[{"g", ",", "paths", ",", "\"\<Central\>\""}], "]"}]], "Input",ExpressionUUID->"830e4edc-b83b-\
47b7-af5f-12c26eb4f344"],

Cell["Keep the peripheral paths.", "CodeText",ExpressionUUID->"48a0accb-30cf-4de4-be1e-96cea532d55e"],

Cell[BoxData[
 RowBox[{"SelectPaths", "[",
  RowBox[{"g", ",", "paths", ",", "\"\<Peripheral\>\""}], "]"}]], "Input",ExpressionUUID->"d26623f6-26a1-\
4053-84ea-91a34578b85d"],

Cell["Keep the embedding-closest paths.", "CodeText",ExpressionUUID->"f96b49dc-1472-4fd3-beea-b266d4681f8b"],

Cell[BoxData[
 RowBox[{"EmbeddingClosestPaths", "[", 
  RowBox[{"g", ",", "paths", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "16"}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"818daa8d-d40d-4848-8a79-27c8f9839637"],

Cell["Cycle bundles", "Section",ExpressionUUID->"371bb51d-203a-45b7-af51-be61c61518ca"],

Cell["Enumerate separating cycles around the centre.", "CodeText",ExpressionUUID->"aff25113-e5df-4c73-b9ed-9bdf347080f0"],

Cell[BoxData[
 RowBox[{"cycles", "=",
  RowBox[{"FindCircle", "[",
   RowBox[{"g", ",", "6", ",",
    RowBox[{"{",
     RowBox[{"1", ",", "2"}], "}"}], ",", "All"}],
   "]"}]}]], "Input",ExpressionUUID->"3f1a6ee5-346e-46fa-957b-eb0940a0aad8"],

Cell["Keep the central cycles, then the shortest among them.", "CodeText",ExpressionUUID->"00ae17ba-220a-4124-8635-e2a37249467c"],

Cell[BoxData[
 RowBox[{"SelectCycles", "[",
  RowBox[{"g", ",",
   RowBox[{"SelectCycles", "[",
    RowBox[{"g", ",", "cycles", ",", "\"\<Central\>\""}], "]"}], ",",
   "\"\<ShortestCircumference\>\""}], "]"}]], "Input",ExpressionUUID->"7ae67aa9-2f30-478b-9fa5-0765b5c32776"],

Cell["Keep the most circle-like cycles under the embedding.", "CodeText",ExpressionUUID->"f37f4f46-18cc-4fde-bb59-f8165fa206b1"],

Cell[BoxData[
 RowBox[{"EmbeddingClosestCycles", "[", 
  RowBox[{"g", ",", "cycles", ",", 
   RowBox[{"{", 
    RowBox[{"6", ",", "1.5`"}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"e9876b0a-0932-4865-a407-258298849b88"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"44f98e3d-3313-40e3-9475-afdb24a065f6"
]
