Notebook[{
Cell["PathSpace Tutorial", "Title",ExpressionUUID->"ba72db5f-9954-4d06-905a-bb9af749797e"],

Cell["\<\
This tutorial starts with full Euclidean multiplicity and then filters it \
down by path-space criteria.\
\>", "Text",ExpressionUUID->"23951d34-30c1-4abb-96c2-2a1aa970a359"],

Cell["Setup", "Section",ExpressionUUID->"538ca9d4-dd2a-4975-a161-3b32dda3be24"],

Cell["Load the paclet and define a grid.", "CodeText",ExpressionUUID->"2c02cc43-2ed7-409b-b5aa-d88c094cb2cc"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"681716f0-78c2-4eff-b8fd-0a2b997a0e33"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"4", ",", "4"}], "}"}], "]"}]}], ";"}]], "Code",ExpressionUUID->\
"d9c59684-69c4-4296-964b-7e5a7f1d9436"],

Cell["Path bundles", "Section",ExpressionUUID->"bee511ae-df79-4f6d-8804-9ef59ef2d3cf"],

Cell["Enumerate all geodesics between opposite corners.", "CodeText",ExpressionUUID->"1348e3aa-d7ba-4dbf-a383-886904a9728c"],

Cell[BoxData[
 RowBox[{"paths", "=", 
  RowBox[{"FindSegment", "[", 
   RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}]}]], "Input",Expressio\
nUUID->"7f006f00-ca5c-4d19-8c69-ac51a154413d"],

Cell["Keep the central paths.", "CodeText",ExpressionUUID->"23a852cb-196c-48e3-8628-a3ec75a316ae"],

Cell[BoxData[
 RowBox[{"CentralPaths", "[", 
  RowBox[{"g", ",", "paths"}], "]"}]], "Input",ExpressionUUID->"a087f31d-8558-\
4458-8eff-adbeb6492525"],

Cell["Keep the peripheral paths.", "CodeText",ExpressionUUID->"0b0eec98-ba58-44da-ac07-68316968be70"],

Cell[BoxData[
 RowBox[{"PeripheralPaths", "[", 
  RowBox[{"g", ",", "paths"}], "]"}]], "Input",ExpressionUUID->"4db4cb85-e002-\
4051-8387-6af0697a5e62"],

Cell["Keep the embedding-closest paths.", "CodeText",ExpressionUUID->"b79c1404-2b29-43d0-bf0f-fa0f5fd18d36"],

Cell[BoxData[
 RowBox[{"EmbeddingClosestPaths", "[", 
  RowBox[{"g", ",", "paths", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "16"}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"8d62cb95-bf82-4fd2-bd70-87392d066d44"],

Cell["Cycle bundles", "Section",ExpressionUUID->"e0e65bea-2f4e-4f0c-baca-df37e2c8b65b"],

Cell["Enumerate separating cycles around the centre.", "CodeText",ExpressionUUID->"79f84c95-ead9-48a0-a682-21d3c796f129"],

Cell[BoxData[
 RowBox[{"cycles", "=", 
  RowBox[{"FindSphere", "[", 
   RowBox[{"g", ",", "6", ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
    RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], 
   "]"}]}]], "Input",ExpressionUUID->"ede5f710-cd65-4532-a8b9-f6215d5142d5"],

Cell["Keep the central cycles, then the shortest among them.", "CodeText",ExpressionUUID->"7f6ca2f9-df94-4807-8770-53a35023df1e"],

Cell[BoxData[
 RowBox[{"ShortestCircumferenceCycles", "[", 
  RowBox[{
   RowBox[{"CentralCycles", "[", "g", "]"}], "[", "cycles", "]"}], 
  "]"}]], "Input",ExpressionUUID->"fdd229e3-b950-4a26-b493-e93d3d1b0ae4"],

Cell["Keep the most circle-like cycles under the embedding.", "CodeText",ExpressionUUID->"2e89a050-c982-4ce3-a0b5-86f07db124bc"],

Cell[BoxData[
 RowBox[{"EmbeddingClosestCycles", "[", 
  RowBox[{"g", ",", "cycles", ",", 
   RowBox[{"{", 
    RowBox[{"6", ",", "1.5`"}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"4f4d11e7-5f37-47e6-9cd1-de35a7875097"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"5a004e49-8cf7-433b-84af-5db8146de72f"
]
