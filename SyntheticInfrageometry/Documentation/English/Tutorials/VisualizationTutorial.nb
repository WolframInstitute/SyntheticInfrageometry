Notebook[{
Cell["Visualization Tutorial", "Title",ExpressionUUID->"79b8e4f9-1059-4033-b595-e68d7062e885"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"c94e21a0-ed69-4347-9b37-f249e9de1e94"],

Cell["\<\
A walk through the diffuse-visualisation layer: how to feed Find* output into \
InfraSceneHighlight, compose layers with per-entry colour overrides, drive \
interactive viewers, and run a full InfraScene.\
\>", "Text",ExpressionUUID->"2515e78a-8829-44d2-a272-ec8a92ba5104"],

Cell["Setup", "Section",ExpressionUUID->"bd5bccca-68f4-403c-8f8b-51e7209cd9a1"],

Cell["Load the dev paclet and the package context.", "CodeText",ExpressionUUID->"54f1e030-fc70-4d78-b8b6-5b0dcbc2ba52"],

Cell[BoxData[
 RowBox[{"Defer", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<../../..\>\""}], 
       "}"}], "]"}], "]"}], ";"}], ",", 
   RowBox[{
    RowBox[{
    "Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", "]"}], 
    ";"}]}], "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"8f20a9b9-fc88-4abc-b62e-e0181e93a314"],

Cell["A 4x4 working grid.", "CodeText",ExpressionUUID->"d854053c-caf2-41de-909e-42f553df8783"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"4", ",", "4"}], "}"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"70f7145e-82ed-4d08-ad9c-f44e5569807b"],

Cell["Single-layer rendering", "Section",ExpressionUUID->"8ea4e119-477d-494c-ba8b-1efa8a24729c"],

Cell["Render every geodesic between two corners.", "CodeText",ExpressionUUID->"36569fad-c2d3-413f-81f1-f3075aef5e82"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"FindSegment", "[", 
     RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "}"}]}], 
  "]"}]], "Input",ExpressionUUID->"a174a4bd-5740-44bb-b7b6-2bce28e694ee"],

Cell["Same with an explicit colour override.", "CodeText",ExpressionUUID->"3283d698-e291-4306-bb25-7e3adbaa4f8d"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"FindSegment", "[", 
      RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
     "Purple"}], "}"}]}], "]"}]], "Input",ExpressionUUID->"94beab80-40b0-432b-\
af43-5e61676b0007"],

Cell["Composite layers", "Section",ExpressionUUID->"141e3b10-bfe7-4131-9912-2a816446a063"],

Cell["Segment + shell + circle.", "CodeText",ExpressionUUID->"876d69da-f208-44fa-83e2-5e6f55e3466a"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"FindSegment", "[", 
       RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
      "Blue"}], ",", 
     RowBox[{
      RowBox[{"FindShell", "[", 
       RowBox[{"g", ",", "6", ",", "2"}], "]"}], "\[Rule]", "LightBlue"}], ",", 
     RowBox[{
      RowBox[{"FindCircle", "[", 
       RowBox[{"g", ",", "6", ",", "2", ",", "All"}], "]"}], "\[Rule]", 
      "Green"}]}], "}"}]}], "]"}]], "Input",ExpressionUUID->"6ea34c35-ad7c-\
4c2d-bfc7-790e359d2107"],

Cell["Opacity and thickness ranges", "Section",ExpressionUUID->"20df0282-fd33-4448-81f8-c71d1f85fe0f"],

Cell["Custom opacity range.", "CodeText",ExpressionUUID->"f1077137-1b5a-4c01-9cbe-cd6bdb2e684a"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"FindSegment", "[", 
     RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "}"}], ",", 
   RowBox[{"\"\<OpacityRange\>\"", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0.2`", ",", "0.9`"}], "}"}]}]}], "]"}]], "Input",ExpressionUUID->\
"96520871-acbc-4aee-a2e4-6618724d83b2"],

Cell["Custom thickness range.", "CodeText",ExpressionUUID->"1a2c6142-0828-4c9a-aed3-75c48d3b687b"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"FindSegment", "[", 
     RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "}"}], ",", 
   RowBox[{"\"\<ThicknessRange\>\"", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"Tiny", ",", "Medium"}], "}"}]}]}], "]"}]], "Input",ExpressionUUI\
D->"2b2a3002-8873-4661-903d-7a19a77a74c4"],

Cell["Default colours", "Section",ExpressionUUID->"9831c3ec-fb45-47d0-b004-d2ecc691a36a"],

Cell["Per-head defaults are exposed as global colour variables.", "CodeText",ExpressionUUID->"f45d4965-6d18-44cc-ae83-8d6b5d97c044"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "$InfraPointColor", ",", "$InfraSegmentColor", ",", "$InfraShellColor", ",",
    "$InfraCircleColor", ",", "$InfraPlaneColor", ",", "$InfraRayColor"}], 
  "}"}]], "Input",ExpressionUUID->"ccd37670-8747-4807-9552-6915267534d4"],

Cell["Interactive viewers", "Section",ExpressionUUID->"0a900d55-6670-454f-bc33-8b91735121ad"],

Cell["Interactive segment explorer.", "CodeText",ExpressionUUID->"3f7770c5-3c6e-46ca-9b78-9f0f459888a1"],

Cell[BoxData[
 RowBox[{"SegmentViewer", "[", "g", "]"}]], "Input",ExpressionUUID->"d7500780-ddb8-45ca-b1cd-edc83a722744"],

Cell["Interactive shell explorer.", "CodeText",ExpressionUUID->"a8d36523-6fe2-4544-8f3b-204397d94789"],

Cell[BoxData[
 RowBox[{"ShellViewer", "[", "g", "]"}]], "Input",ExpressionUUID->"8c709803-be67-4686-9c1f-1fdc00fc52f7"],

Cell["Scene engine", "Section",ExpressionUUID->"06e9e94e-8c26-459b-8831-d79e9e8d8835"],

Cell["An equilateral-triangle scene (Euclid I.1).", "CodeText",ExpressionUUID->"9c422ed8-13ed-43f0-9cd9-f266fb535dba"],

Cell[BoxData[
 RowBox[{
  RowBox[{"scene", "=", 
   RowBox[{"InfraScene", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "b", ",", "c"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"InfraPointQ", "[", "a", "]"}], ",", 
       RowBox[{"InfraPointQ", "[", "b", "]"}], ",", 
       RowBox[{"InfraPointQ", "[", "c", "]"}], ",", 
       RowBox[{"InfraCircleQ", "[", 
        RowBox[{"InfraCircle", "[", 
         RowBox[{"a", ",", 
          RowBox[{"InfraDistance", "[", 
           RowBox[{"a", ",", "b"}], "]"}]}], "]"}], "]"}], ",", 
       RowBox[{"InfraCircleQ", "[", 
        RowBox[{"InfraCircle", "[", 
         RowBox[{"b", ",", 
          RowBox[{"InfraDistance", "[", 
           RowBox[{"a", ",", "b"}], "]"}]}], "]"}], "]"}], ",", 
       RowBox[{"c", "\[Equal]", 
        RowBox[{"InfraIntersection", "[", 
         RowBox[{
          RowBox[{"InfraCircle", "[", 
           RowBox[{"a", ",", 
            RowBox[{"InfraDistance", "[", 
             RowBox[{"a", ",", "b"}], "]"}]}], "]"}], ",", 
          RowBox[{"InfraCircle", "[", 
           RowBox[{"b", ",", 
            RowBox[{"InfraDistance", "[", 
             RowBox[{"a", ",", "b"}], "]"}]}], "]"}]}], "]"}]}]}], "}"}]}], 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"619133a1-b30a-4f7a-b165-\
bbc99a9d66c2"],

Cell["Step through the scene with an interactive viewer.", "CodeText",ExpressionUUID->"d268a627-155d-4ea7-a147-58d067d1e77d"],

Cell[BoxData[
 RowBox[{"InfraSceneViewer", "[", 
  RowBox[{"scene", ",", "g"}], "]"}]], "Input",ExpressionUUID->"6994eddf-6203-\
4c9e-8d23-6ac27fbc164b"],

Cell["See also", "Section",ExpressionUUID->"1bf04c83-8d51-49b7-82b7-9eafa05f3714"],

Cell["VisualizationGuide", "Item",ExpressionUUID->"c7fcd301-8484-4c06-b12f-3060d4d8c84e"],

Cell["EuclideanGeometryTutorial", "Item",ExpressionUUID->"e8581b4e-d6f0-4a64-8ff2-44c6ca2b3c0a"],

Cell["PathSpaceTutorial", "Item",ExpressionUUID->"d0006a4f-0a87-4498-a2d2-f231c5836cc4"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"d0c0adf3-5051-4eda-8478-4a233b99d813"
]
