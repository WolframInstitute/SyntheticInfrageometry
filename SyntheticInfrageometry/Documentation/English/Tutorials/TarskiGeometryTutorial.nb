Notebook[{
Cell["Tarski Geometry Tutorial", "Title",ExpressionUUID->"3d7e642e-04bd-466d-a896-7b3491da4106"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"ec8cafee-c7dc-40b9-b7d2-d4c0c578eb78"],

Cell["\<\
A compact walk through the Tarski layer on small graphs: the two primitives, \
the eleven axioms as predicates, and the FindTarskiCounterexample finder for \
witnesses of failure.\
\>", "Text",ExpressionUUID->"0a6625a6-2369-4c1f-9366-8c381995e8d4"],

Cell["Setup", "Section",ExpressionUUID->"e78c656c-dc8a-47da-ab7a-da1e2ddfe857"],

Cell["Load the dev paclet and the package context.", "CodeText",ExpressionUUID->"860d7adb-092c-4663-a2ca-17c6e8068a68"],

Cell[BoxData[
 RowBox[{"Defer", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<../../..\>\""}], 
       "}"}], "]"}], "]"}], ";"}], ",", 
   RowBox[{
    RowBox[{
    "Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", "]"}], 
    ";"}]}], "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"0984dabf-401d-41e2-9e1a-67cfbfce32c1"],

Cell["Three working graphs of different combinatorial type.", "CodeText",ExpressionUUID->"e8b4407f-24e5-4e53-8b63-4e4fcb6580cb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g1", "=", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "6", "]"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"c8e44950-ab89-4e8c-b7d9-4d8224ba7729"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g2", "=", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"3", ",", "3"}], "}"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"eeacd636-835e-41d7-910c-794ffb790c69"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g3", "=", 
   RowBox[{"CycleGraph", "[", "6", "]"}]}], ";"}]], "Input",ExpressionUUID->\
"a2894463-3be9-4448-8c2a-befb46734752"],

Cell["Primitives", "Section",ExpressionUUID->"c83ae2b5-c42a-43a2-8d41-905ef4902289"],

Cell["Betweenness on a path graph.", "CodeText",ExpressionUUID->"1f5c5884-28e3-4952-be0b-56b20b816180"],

Cell[BoxData[
 RowBox[{"BetweennessQ", "[", 
  RowBox[{"g1", ",", "1", ",", "3", ",", "5"}], "]"}]], "Input",ExpressionUUID\
->"fc8038c0-a2e9-475c-bc4f-b896d693b354"],

Cell["Equidistance on a grid.", "CodeText",ExpressionUUID->"6e93f9c6-7348-4c61-b729-7fdfd86c7f00"],

Cell[BoxData[
 RowBox[{"EquidistanceQ", "[", 
  RowBox[{"g2", ",", "1", ",", "2", ",", "4", ",", "5"}], "]"}]], "Input",Expr\
essionUUID->"a04d45da-7c2c-4e58-bea3-5d76fb4d4814"],

Cell["Memoised bundle of distances + betweenness + equidistance.", "CodeText",ExpressionUUID->"f589e36b-ee3c-4853-bf2b-60cfd125ed9c"],

Cell[BoxData[
 RowBox[{"TarskiStructure", "[", "g2", "]"}]], "Input",ExpressionUUID->"370658e2-4b89-47f9-a744-dd6564c7d47a"],

Cell["The axiom dashboard", "Section",ExpressionUUID->"4dc76b7b-03be-4c74-9da9-3854ec4feefe"],

Cell["All eleven axioms at once on a path.", "CodeText",ExpressionUUID->"e7332806-6f62-4ded-a200-8712d98d6cc4"],

Cell[BoxData[
 RowBox[{"TarskiAxiomQ", "[", "g1", "]"}]], "Input",ExpressionUUID->"6cde8fd1-213e-4212-a2c5-562fe40898b2"],

Cell["On a grid.", "CodeText",ExpressionUUID->"a394f5fb-b12f-4dd9-9c24-ff7d9cf963e1"],

Cell[BoxData[
 RowBox[{"TarskiAxiomQ", "[", "g2", "]"}]], "Input",ExpressionUUID->"2cfd7241-e6fa-4e1a-b065-80d1084cf53f"],

Cell["On a cycle (A7 / Inner Pasch fails on cycles of length \[GreaterEqual] \
5).", "CodeText",ExpressionUUID->"e860385f-ab89-42b9-abcd-fe9ff630a40c"],

Cell[BoxData[
 RowBox[{"TarskiAxiomQ", "[", "g3", "]"}]], "Input",ExpressionUUID->"c61c9e02-03c6-4a3e-a3b2-decc48225174"],

Cell["Counterexamples", "Section",ExpressionUUID->"dda56838-2c4a-4734-8abb-3288cbf34dbc"],

Cell["Witness of A7 failure on the 6-cycle.", "CodeText",ExpressionUUID->"75901935-648c-47b8-ab1c-2cb80977ee0e"],

Cell[BoxData[
 RowBox[{"FindTarskiCounterexample", "[", 
  RowBox[{"g3", ",", "TarskiInnerPaschQ"}], "]"}]], "Input",ExpressionUUID->\
"424162fa-89d3-4d45-85b4-a9389e088484"],

Cell["All A5 counterexamples.", "CodeText",ExpressionUUID->"9ed92515-9c3f-4b1e-b9cf-ec79d7a506ad"],

Cell[BoxData[
 RowBox[{"FindTarskiCounterexample", "[", 
  RowBox[{"g3", ",", "TarskiFiveSegmentsQ", ",", "All"}], "]"}]], "Input",Expr\
essionUUID->"4d7dc864-373e-463f-9761-dba03d3033e4"],

Cell["Tarski-recipe variants of standard constructions", "Section",ExpressionUUID->"9ef4ef9a-55eb-4249-abf7-0e3f8b11def6"],

Cell["Synthetic midpoint (from B and E).", "CodeText",ExpressionUUID->"5eccc645-c719-4c45-ad8b-799bae43b135"],

Cell[BoxData[
 RowBox[{"FindInfraMidpoint", "[", 
  RowBox[{
   RowBox[{"CycleGraph", "[", "8", "]"}], ",", "1", ",", "5", ",", "All", ",", 
   RowBox[{"Method", "\[Rule]", "\"\<Tarski\>\""}]}], "]"}]], "Input",Expressi\
onUUID->"d1be7a5e-6862-46e5-9fa5-fcaac056d2a2"],

Cell["Tarski A4 segment-extension finder.", "CodeText",ExpressionUUID->"742dace2-8d68-4ab2-ada2-81d0ee9d7d83"],

Cell[BoxData[
 RowBox[{"ExtendInfraSegment", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "10", "]"}], "]"}], ",", "1", ",", "2", ",", "3", ",",
    "4", ",", "All"}], "]"}]], "Input",ExpressionUUID->"bd7562c8-64fa-4361-\
ace5-775d7ee18300"],

Cell["Reflection through a centre vertex.", "CodeText",ExpressionUUID->"3f63c02f-feb2-4f0f-8fb5-0aebe802f9c9"],

Cell[BoxData[
 RowBox[{"FindInfraReflection", "[", 
  RowBox[{"g1", ",", "1", ",", "3", ",", "All"}], "]"}]], "Input",ExpressionUU\
ID->"d4cd0f4a-00ce-4a9b-b122-e5811bad85b6"],

Cell["Median graphs", "Section",ExpressionUUID->"10ae6359-83f0-4c3d-ad3e-3da4639009d4"],

Cell["Median of a triple.", "CodeText",ExpressionUUID->"ad3303e7-bffb-4a04-b089-9ca4cb9636b1"],

Cell[BoxData[
 RowBox[{"MedianVertices", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "3", ",", "7"}], "}"}]}], "]"}]], "Input",ExpressionUUID\
->"37a3b296-45f9-425b-ad68-a722eb140eeb"],

Cell["A5 and A7 hold on median graphs.", "CodeText",ExpressionUUID->"243909e5-7e93-4642-a2a9-82c1f4dc4a05"],

Cell[BoxData[
 RowBox[{"TarskiFiveSegmentsQ", "[", "g1", "]"}]], "Input",ExpressionUUID->"57837988-0b2f-450b-8e6b-d9a7a396435f"],

Cell[BoxData[
 RowBox[{"TarskiInnerPaschQ", "[", "g1", "]"}]], "Input",ExpressionUUID->"df6cb613-6294-4f3c-86cd-a4dd0a96c4a8"],

Cell["See also", "Section",ExpressionUUID->"3e1a7e63-04cb-4101-aaa8-cb316fbd749b"],

Cell["TarskiGeometryGuide", "Item",ExpressionUUID->"6a2d806f-8505-4d33-bc69-88e8201b0b45"],

Cell["EuclideanGeometryTutorial", "Item",ExpressionUUID->"87dcd45a-2239-4d9a-8372-398aa25b70a0"],

Cell["ProjectiveGeometryTutorial", "Item",ExpressionUUID->"f31c0935-872f-4f04-82ef-8d151a64dca0"]
},
