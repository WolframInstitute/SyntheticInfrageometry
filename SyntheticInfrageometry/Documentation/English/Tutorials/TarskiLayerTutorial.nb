Notebook[{
Cell["Tarski Layer Tutorial", "Title",ExpressionUUID->"565416e6-ad35-4406-99b0-fb85b6c644af"],

Cell["\<\
A runnable tour of betweenness, equidistance, the Tarski substrate, the axiom \
dashboard, and the two Tarski-only constructions.\
\>", "Text",ExpressionUUID->"59cd39fa-21fe-4306-9ca6-0758b8710595"],

Cell["Setup", "Section",ExpressionUUID->"357b2b85-679c-49d5-90db-9a061ec3cfdb"],

Cell["Load the paclet and define a substrate panel.", "CodeText",ExpressionUUID->"3451c438-509c-4a40-8e9b-5133b86d032d"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"8a5c9347-f44c-4e0a-8848-e41643573b8b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"substrate", "=", 
   RowBox[{"Association", "[", 
    RowBox[{
     RowBox[{"\"\<Path\>\"", "\[Rule]", 
      RowBox[{"PathGraph", "[", 
       RowBox[{"Range", "[", "5", "]"}], "]"}]}], ",", 
     RowBox[{"\"\<Cycle\>\"", "\[Rule]", 
      RowBox[{"CycleGraph", "[", "6", "]"}]}], ",", 
     RowBox[{"\"\<Grid\>\"", "\[Rule]", 
      RowBox[{"GridGraph", "[", 
       RowBox[{"{", 
        RowBox[{"3", ",", "3"}], "}"}], "]"}]}], ",", 
     RowBox[{"\"\<Cube\>\"", "\[Rule]", 
      RowBox[{"HypercubeGraph", "[", "3", "]"}]}], ",", 
     RowBox[{"\"\<Petersen\>\"", "\[Rule]", 
      RowBox[{"PetersenGraph", "[", "]"}]}]}], "]"}]}], ";"}]], "Code",Express\
ionUUID->"ea0657a3-2e37-470a-a591-7afa93418bd2"],

Cell["Primitive relations", "Section",ExpressionUUID->"608972ce-d1d5-421e-b427-20865a7e1c8c"],

Cell["Betweenness and equidistance on small graphs.", "CodeText",ExpressionUUID->"b4f75cd6-3600-408c-a283-c3dd34bc3e50"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"BetweennessQ", "[", 
    RowBox[{
     RowBox[{"CycleGraph", "[", "6", "]"}], ",", "1", ",", "2", ",", "4"}], 
    "]"}], ",", 
   RowBox[{"EquidistanceQ", "[", 
    RowBox[{
     RowBox[{"CycleGraph", "[", "6", "]"}], ",", "1", ",", "4", ",", "2", ",",
      "5"}], "]"}]}], "}"}]], "Input",ExpressionUUID->"d37a186d-015b-4b0a-\
9414-dfd13c8aaf8d"],

Cell["Hypermatrix substrate", "Section",ExpressionUUID->"2202ea5c-966a-4c17-92ab-9a17d6a82cb3"],

Cell["\<\
Inspect the memoized Tarski bundle and one sparse tensor statistic.\
\>", "CodeText",ExpressionUUID->"b0955476-a055-47ed-9aa2-8ea1832bbc09"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Keys", "[", 
    RowBox[{"TarskiStructure", "[", 
     RowBox[{"HypercubeGraph", "[", "3", "]"}], "]"}], "]"}], ",", 
   RowBox[{"Length", "[", 
    RowBox[{
     RowBox[{"TarskiBetweennessTensor", "[", 
      RowBox[{"HypercubeGraph", "[", "3", "]"}], "]"}], 
     "[", "\"\<NonzeroPositions\>\"", "]"}], "]"}]}], "}"}]], "Input",Expressi\
onUUID->"b7bf2b14-a1d0-4db9-a992-b8c37083cb58"],

Cell["Axiom dashboard", "Section",ExpressionUUID->"6ccb7200-9d43-4651-b7d4-589baa1bb945"],

Cell["Compare the dashboard on a grid and on the Petersen graph.", "CodeText",ExpressionUUID->"aa6598b1-4cfd-43c9-841c-7ecef6a4d734"],

Cell[BoxData[
 RowBox[{"AssociationMap", "[", 
  RowBox[{
   RowBox[{"Quiet", "@*", "TarskiAxiomQ"}], ",", 
   RowBox[{"Association", "[", 
    RowBox[{
     RowBox[{"\"\<Grid\>\"", "\[Rule]", 
      RowBox[{"GridGraph", "[", 
       RowBox[{"{", 
        RowBox[{"3", ",", "3"}], "}"}], "]"}]}], ",", 
     RowBox[{"\"\<Petersen\>\"", "\[Rule]", 
      RowBox[{"PetersenGraph", "[", "]"}]}]}], "]"}]}], "]"}]], "Input",Expres\
sionUUID->"f7008a56-8346-4f54-802e-ec3e0084512f"],

Cell["Constructions", "Section",ExpressionUUID->"68047bdb-021b-40de-a7d1-3ebff048fa17"],

Cell["Compare the synthetic midpoint with the metric midpoint.", "CodeText",ExpressionUUID->"56fbe243-cea7-49f2-807d-95fca93f2928"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"FindTarskiMidpoint", "[", 
    RowBox[{
     RowBox[{"PathGraph", "[", 
      RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "4", ",", 
     "All"}], "]"}], ",", 
   RowBox[{"FindMidpoint", "[", 
    RowBox[{
     RowBox[{"PathGraph", "[", 
      RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "4", ",", 
     "All"}], "]"}]}], "}"}]], "Input",ExpressionUUID->"5ed1ff20-bdf5-4d50-\
b95a-c8a571a2ea2f"],

Cell["Reflect a point through another point on the cube.", "CodeText",ExpressionUUID->"87951d64-757b-4564-913f-7f01b584324e"],

Cell[BoxData[
 RowBox[{"FindTarskiReflection", "[", 
  RowBox[{
   RowBox[{"HypercubeGraph", "[", "3", "]"}], ",", "1", ",", "2", ",", 
   "All"}], "]"}]], "Input",ExpressionUUID->"d48cf121-4cb5-46bc-9b0e-\
b8229f2ae148"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"44f98e3d-3313-40e3-9475-afdb24a065f6"
]
