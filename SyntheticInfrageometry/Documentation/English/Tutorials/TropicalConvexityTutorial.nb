Notebook[{
Cell["Tropical Convexity Tutorial", "Title",ExpressionUUID->"2883dac8-b1c7-41ce-bc22-298f07e9327a"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"3b133b25-9f65-4089-84ce-39fbc6a68e95"],

Cell["\<\
A worked tour of the tropical-convexity layer: the metric-interval / median \
structure, the geodesic convex hull as the graph-intrinsic shadow of tropical \
(min-plus) convexity, and the strong / weak closure tests.\
\>", "Text",ExpressionUUID->"520394da-f32e-4a15-be2a-ee9794fc392e"],

Cell["Setup", "Section",ExpressionUUID->"7e3d09d0-9745-4a76-9e7e-f7391c8b9897"],

Cell["Load the dev paclet and the package context.", "CodeText",ExpressionUUID->"1d21ea31-5162-407c-a6cd-222276c38549"],

Cell[BoxData[
 RowBox[{"Defer", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<../../..\>\""}], 
       "}"}], "]"}], "]"}], ";"}], ",", 
   RowBox[{
    RowBox[{
    "Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", "]"}], 
    ";"}]}], "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"ee90430c-bd4f-4924-96b9-c9f6e9a935b2"],

Cell["Three working graphs.", "CodeText",ExpressionUUID->"4413a86d-8c00-4e45-974f-3476f955b5f0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"4", ",", "4"}], "}"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"cc80ce33-dac1-43c8-b320-a5fc14c08da2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p", "=", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "6", "]"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"30b8e714-e3db-4e00-b8e4-b1b3b000fbfe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"c", "=", 
   RowBox[{"CycleGraph", "[", "6", "]"}]}], ";"}]], "Input",ExpressionUUID->\
"9ee3372c-895c-4195-88f6-c5bed56af215"],

Cell["Metric interval", "Section",ExpressionUUID->"09e05015-7202-4410-94fb-1649fdf2aa64"],

Cell["Vertices on any geodesic between two grid corners.", "CodeText",ExpressionUUID->"23156ec6-fe51-47a7-b188-70570f01908f"],

Cell[BoxData[
 RowBox[{"MetricInterval", "[", 
  RowBox[{"g", ",", "1", ",", "16"}], "]"}]], "Input",ExpressionUUID->\
"da5131bf-e74d-49d4-9675-a666d141183c"],

Cell["Interval on a tree is just the path.", "CodeText",ExpressionUUID->"732de1b7-0a78-49d6-8bb7-ed057dc6c545"],

Cell[BoxData[
 RowBox[{"MetricInterval", "[", 
  RowBox[{"p", ",", "2", ",", "5"}], "]"}]], "Input",ExpressionUUID->\
"48d4e6e9-3652-42dc-bd9e-217405b5745b"],

Cell["Median structure", "Section",ExpressionUUID->"5c54f773-a079-4acc-a375-a0ca7617f026"],

Cell["Median of a triple on the grid.", "CodeText",ExpressionUUID->"d8a78860-6539-49e3-929e-560a47662a8f"],

Cell[BoxData[
 RowBox[{"MedianVertices", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "4", ",", "13"}], "}"}]}], "]"}]], "Input",ExpressionUUI\
D->"5389da7a-6f6b-4121-9392-888df09ab22e"],

Cell["\<\
On a path, the median of two endpoints is the metric interval.\
\>", "CodeText",ExpressionUUID->"c56cad88-a674-4a4f-92ec-1c82f6b3a0e0"],

Cell[BoxData[
 RowBox[{"MedianVertices", "[", 
  RowBox[{"p", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "6"}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"c7b4cf02-c873-4fa2-8836-096441cec60c"],

Cell["Geodesic convex hull", "Section",ExpressionUUID->"c364ba3a-1405-4a62-8696-ab40ba4d3b6f"],

Cell["Closure of a triple of grid vertices under MetricInterval.", "CodeText",ExpressionUUID->"c71522bb-8181-4264-b03d-08f3463a844c"],

Cell[BoxData[
 RowBox[{"FindGeodesicConvexHull", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "4", ",", "13"}], "}"}]}], "]"}]], "Input",ExpressionUUI\
D->"7c7e2bd6-08a5-4285-8a5a-089b0f91668e"],

Cell["Single-pair hull = metric interval.", "CodeText",ExpressionUUID->"1f6c5eeb-7ba3-4b73-a4a9-16edfeb3a40c"],

Cell[BoxData[
 RowBox[{"FindGeodesicConvexHull", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "16"}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"cbd38f73-1713-4a27-bfbb-84d94066468e"],

Cell["Strong and weak convexity", "Section",ExpressionUUID->"3704b0c0-966d-4549-8aeb-69cdfe619d29"],

Cell["A convex hull is geodesically convex (strong).", "CodeText",ExpressionUUID->"267880fb-9f18-4484-a8d3-dea56faf31d0"],

Cell[BoxData[
 RowBox[{"GeodesicallyConvexQ", "[", 
  RowBox[{"g", ",", 
   RowBox[{"FindGeodesicConvexHull", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "4", ",", "13"}], "}"}]}], "]"}]}], "]"}]], "Input",Ex\
pressionUUID->"1cf81cfe-8a0a-482e-bf9e-8dcdc14d126e"],

Cell["A row of the grid is only weakly convex.", "CodeText",ExpressionUUID->"225edf69-5746-45be-95d5-9674f8e206e4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"GeodesicallyConvexQ", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]}], "]"}], ",", 
   RowBox[{"GeodesicallyConvexQ", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}], ",", 
     RowBox[{"Method", "\[Rule]", "\"\<Weak\>\""}]}], "]"}]}], "}"}]], "Input",\
ExpressionUUID->"dc5783e7-d845-4640-81ac-1d8928239956"],

Cell["Non-median examples", "Section",ExpressionUUID->"bd8a6996-f127-4c18-ba26-94bbda09a3eb"],

Cell["\<\
On a cycle of length 6, the median of three vertices is multi-valued.\
\>", "CodeText",ExpressionUUID->"8a25b60c-f4c9-4a08-b0f5-364f83b1713c"],

Cell[BoxData[
 RowBox[{"MedianVertices", "[", 
  RowBox[{"c", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "3", ",", "5"}], "}"}]}], "]"}]], "Input",ExpressionUUID\
->"c980e887-f35a-411f-84f3-9f1768a75de3"],

Cell["Diffuse rendering of a hull", "Section",ExpressionUUID->"7c8075e4-4124-4c8b-9a36-845ef0dce03f"],

Cell["Highlight the geodesic convex hull of three grid vertices.", "CodeText",ExpressionUUID->"4cf1eb70-d20e-496a-98de-db32d317b651"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"FindGeodesicConvexHull", "[", 
      RowBox[{"g", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "4", ",", "13"}], "}"}]}], "]"}], "\[Rule]", 
     "LightOrange"}], "}"}]}], "]"}]], "Input",ExpressionUUID->"3b7cdb1a-1eb3-\
4b0d-b1fc-21c2283284bf"],

Cell["See also", "Section",ExpressionUUID->"dcbd5d4e-52ea-4cc3-8d8b-00e4e723ad67"],

Cell["TropicalConvexityGuide", "Item",ExpressionUUID->"db3dd815-faad-439b-bfcc-de3a22d193af"],

Cell["PathSpaceTutorial", "Item",ExpressionUUID->"9a1437b9-e1f9-44b4-b59c-dfdff9d58d50"],

Cell["EuclideanGeometryTutorial", "Item",ExpressionUUID->"3a4bb0ee-1d7e-48a4-835c-843347a4b825"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"d0c0adf3-5051-4eda-8478-4a233b99d813"
]
