Notebook[{
Cell["Tropical Convexity Tutorial", "Title",ExpressionUUID->"0db0fd07-faf6-46e8-a975-d6df4d1e64c3"],

Cell["\<\
A walkthrough of the graph translation of tropical convexity: tropical \
segments as geodesics, geodesic convex hulls, the T1 axiom. Worked examples \
on paths, cycles, grids, and median graphs.\
\>", "Text",ExpressionUUID->"e9f05092-a633-4378-8aa3-293621f1dd7d"],

Cell["Setup", "Section",ExpressionUUID->"a4e34287-739e-4e22-9ef5-eb31df511889"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"5057e7ff-c440-4e1d-bfbc-f445de29df1a"],

Cell["Tropical segments", "Section",ExpressionUUID->"1754e4cb-668d-4010-8ba8-a2d306b26cf4"],

Cell["\<\
A tropical segment from u to v is the vertex set of any geodesic between \
them. Multi-valued when the geodesic is non-unique.\
\>", "Text",ExpressionUUID->"73d99230-c2df-4477-9715-2425261c3fcb"],

Cell["FindTropicalSegment[PathGraph[Range[5]], 1, 5, All]", "Input",ExpressionUUID->"854c596b-b1fb-4b96-b0fe-89193260a0d7"],

Cell["\<\
A 6-cycle: antipodal vertices admit two distinct tropical segments.\
\>", "CodeText",ExpressionUUID->"ed04a3d8-4c75-43a2-b05e-63caa41b9534"],

Cell["FindTropicalSegment[CycleGraph[6], 1, 4, All]", "Input",ExpressionUUID->"98039970-b571-4dbd-98c5-40bb647b13c8"],

Cell["\<\
Both segments have the same vertex set in the path-graph case but different \
vertex sets in the cycle case (the two halves of the cycle are different sets \
even though they have equal length).\
\>", "Text",ExpressionUUID->"9c89efe1-8c09-4590-89ec-eb473b321994"],

Cell["The TropicalSegmentQ predicate", "Section",ExpressionUUID->"77a88cb9-a91a-44e4-8047-29ea0b98b662"],

Cell["Test whether a vertex set realises a tropical segment.", "Text",ExpressionUUID->"a3be6528-fa06-43fb-9edc-4431eb76dbd7"],

Cell["TropicalSegmentQ[PathGraph[Range[5]], {1, 2, 3}, 1, 3]", "Input",ExpressionUUID->"b915b7f7-1196-481b-9267-a273551c33fd"],

Cell["TropicalSegmentQ[CycleGraph[6], {1, 2, 3, 4}, 1, 4]", "Input",ExpressionUUID->"4ddf00da-7038-4718-bb82-f743823ca1e6"],

Cell["Geodesic convexity", "Section",ExpressionUUID->"0fff885e-dc35-47ae-a8c7-7f20c6817ce8"],

Cell["\<\
A vertex set S is geodesically convex if every geodesic between vertices in S \
stays inside S.\
\>", "Text",ExpressionUUID->"b1371635-a82b-4f7c-bcd8-d421bf7ca9a3"],

Cell["\<\
A path is convex (geodesics in a path graph are unique and stay on the path):\
\
\>", "CodeText",ExpressionUUID->"eba8c342-e252-466b-8f56-8cf3473a732f"],

Cell["GeodesicallyConvexQ[PathGraph[Range[7]], {2, 3, 4, 5}]", "Input",ExpressionUUID->"95518a4f-00c8-4483-9c5d-1dbd3e1d1caf"],

Cell["\<\
A grid corner pair plus the centre is not convex (geodesics may detour \
through other vertices):\
\>", "CodeText",ExpressionUUID->"f5cc084c-6ac9-47d2-b313-278933b30edc"],

Cell["GeodesicallyConvexQ[GridGraph[{3, 3}], {1, 5, 9}]", "Input",ExpressionUUID->"0284f763-b148-4536-8021-96a4a7ec03dc"],

Cell["Geodesic convex hull", "Section",ExpressionUUID->"af8ee22f-ac1b-4727-adca-9814c0c487ae"],

Cell["The smallest geodesically convex superset of a vertex set.", "Text",ExpressionUUID->"313f6dae-8204-4554-b232-bb729919992b"],

Cell["FindGeodesicConvexHull[GridGraph[{3, 3}], {1, 9}]", "Input",ExpressionUUID->"8ca067ef-3aaa-4f34-b09b-c269e3ab7960"],

Cell["\<\
The hull of two opposite corners in a 3x3 grid is the entire grid (every \
vertex sits on some 1-9 geodesic).\
\>", "Text",ExpressionUUID->"d4ef408b-18b0-4326-a048-54e9fe27f79e"],

Cell["FindGeodesicConvexHull[PathGraph[Range[7]], {3, 5}]", "Input",ExpressionUUID->"d49c9e86-419a-42e5-a7bd-9e778d579ce6"],

Cell["\<\
In a path graph the hull of {3, 5} is the closed sub-path {3, 4, 5}.\
\>", "Text",ExpressionUUID->"dc8fa4e5-ff41-47c6-8592-46c3bfe62b91"],

Cell["The T1 axiom", "Section",ExpressionUUID->"4ea298cf-a8e9-496d-825b-1f3755fc9b0b"],

Cell["\<\
The first tropical axiom states that every two vertices admit a tropical \
segment. In our reading this is exactly graph connectedness.\
\>", "Text",ExpressionUUID->"89b28f9e-a791-4cf1-9312-8c554ef9863b"],

Cell["TropicalT1Q[GridGraph[{3, 3}]]", "Input",ExpressionUUID->"1afb71aa-72de-4bd4-8d71-535ef0e1bbc8"],

Cell["TropicalT1Q[Graph[{1 -> 2, 3 -> 4}]]", "Input",ExpressionUUID->"64d6fc32-033d-4800-a7e6-1864ea1ebd50"],

Cell["Uniqueness", "Section",ExpressionUUID->"59213b15-a1da-4cdd-96cb-c8a368b521c2"],

Cell["\<\
UniqueTropicalSegmentQ tests whether the tropical segment from u to v is \
single-valued. On a tree it is always true (geodesics are unique); on a cycle \
the antipode breaks uniqueness.\
\>", "Text",ExpressionUUID->"227c795c-df6c-4649-9d96-412ac72787b9"],

Cell["UniqueTropicalSegmentQ[PathGraph[Range[7]], 2, 6]", "Input",ExpressionUUID->"2df06e80-d944-474f-952f-7715600cde15"],

Cell["UniqueTropicalSegmentQ[CycleGraph[6], 1, 4]", "Input",ExpressionUUID->"f4021e80-f230-49ca-8c8b-dac0ec77c4ca"],

Cell["Median graphs and convexity", "Section",ExpressionUUID->"d8c83ff2-5baa-4841-873f-bf810730c6fc"],

Cell["\<\
A graph is a median graph iff every triple of vertices has a unique median (a \
vertex minimising sum of distances to the triple). Median graphs have \
especially well-behaved tropical convexity: the geodesic convex hull is \
closed under tropical median.\
\>", "Text",ExpressionUUID->"5b09f032-977f-4317-83fe-0a1b4afc8d54"],

Cell["MedianVertices[HypercubeGraph[3], {1, 4, 6}]", "Input",ExpressionUUID->"08e53a4f-35aa-45a0-8bd5-fd502cc8fa17"],

Cell["Hypercubes are median graphs; trees are too.", "Text",ExpressionUUID->"0e9c7daf-3be6-4ebb-afb7-2bcc2e694a82"],

Cell["Visualization", "Section",ExpressionUUID->"6ffdeafb-08fe-4ec3-888f-9252c88e7b86"],

Cell["\<\
Render geodesic hulls and segments through the same diffuse-rendering \
pipeline as the Euclidean layer.\
\>", "Text",ExpressionUUID->"da354673-9994-4c35-82a8-c592f744ce17"],

Cell["g = GridGraph[{3, 3}]", "Input",ExpressionUUID->"45327051-f3dd-4663-9b04-b49a9c8c7513"],

Cell["\<\
With[{hull = FindGeodesicConvexHull[g, {1, 9}]}, InfraSceneHighlight[g, \
{InfraPoint[hull] -> Red}]]\
\>", "Input",ExpressionUUID->"2397824b-50b6-49e1-acef-df2bef835d06"],

Cell["See also", "Section",ExpressionUUID->"e0399d5d-2851-4853-ba8e-07bbbce9dd21"],

Cell["TropicalConvexityGuide -- categorical overview.", "Item",ExpressionUUID->"2cc494c4-9db2-4905-b2c5-5f8392a1b5fa"],

Cell["TropicalOperationsGuide -- min-plus arithmetic (sense 1).", "Item",ExpressionUUID->"98f44a34-4269-4f57-abaf-a2e5b8308f19"],

Cell["\<\
MetricAlgebraGuide -- MetricInterval, GeodesicCount, MedianVertices.\
\>", "Item",ExpressionUUID->"9d2bfe0d-e464-4246-b9e9-cb3616fb8524"],

Cell["EuclideanGeometryTutorial -- the underlying FindSegment family.", "Item",ExpressionUUID->"ce903710-7543-4bad-aa5a-24924672d233"],

Cell["References", "Section",ExpressionUUID->"59189f52-d453-4002-9bae-cdc45a763d3f"],

Cell["\<\
Maclagan and Sturmfels, Introduction to Tropical Geometry, AMS GSM 161, 2015, \
https://janos.cs.technion.ac.il/COURSES/238900-13/Tropical/MaclaganSturmfels.\
pdf\
\>", "Item",ExpressionUUID->"22dff7ed-fa9f-4ec4-831e-17700d3d4c66"],

Cell["\<\
Develin and Sturmfels, Tropical Convexity, Documenta Math. 9, 2004, \
https://arxiv.org/abs/math/0308254\
\>", "Item",ExpressionUUID->"23f1e168-3462-4273-a08a-42861f36b343"],

Cell["\<\
Mulder, The Interval Function of a Graph, Mathematical Centre Tracts 132, \
1980.\
\>", "Item",ExpressionUUID->"4ec459dc-0797-4aa5-88db-c6cca23c21f4"],

Cell["\<\
Bandelt and Mulder, Distance-Hereditary Graphs, J. Combin. Theory Ser. B 41, \
182-208, 1986.\
\>", "Item",ExpressionUUID->"8b8377b5-8f17-4d3f-96da-a05159c38374"]
},
