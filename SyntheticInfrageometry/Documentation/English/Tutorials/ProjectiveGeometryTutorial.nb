Notebook[{
Cell["Projective Geometry Tutorial", "Title",ExpressionUUID->"7921924f-163d-4fa8-aacf-70a7166f0711"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"8cf1ee12-8cfe-49a3-b9e5-bd0090fc793d"],

Cell["\<\
A worked tour of the projective layer: directions at a centre, pencils, the \
canonical line set, the Whitehead axioms, and the synthetic projective-plane \
test.\
\>", "Text",ExpressionUUID->"8eba07af-8ebc-48cc-a605-021f318c622f"],

Cell["Setup", "Section",ExpressionUUID->"c5697a50-df2f-45ae-a26f-94aedb9af37a"],

Cell["Load the dev paclet and the package context.", "CodeText",ExpressionUUID->"2e68ec1e-b9fb-48a9-bc03-2e9b0e7c1a44"],

Cell[BoxData[
 RowBox[{"Defer", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<../../..\>\""}], 
       "}"}], "]"}], "]"}], ";"}], ",", 
   RowBox[{
    RowBox[{
    "Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", "]"}], 
    ";"}]}], "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"d05b6f82-c9d4-4be2-ad2b-86c9f7a45576"],

Cell["Two working graphs.", "CodeText",ExpressionUUID->"ec5b55ec-2114-442e-89f3-1a69eb2af408"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"3", ",", "3"}], "}"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"066b2d23-5c86-46c5-9810-8ac932b42287"],

Cell[BoxData[
 RowBox[{
  RowBox[{"k4", "=", 
   RowBox[{"CompleteGraph", "[", "4", "]"}]}], ";"}]], "Input",ExpressionUUID->\
"81cc763b-bffb-43df-abe3-bc1ed3511605"],

Cell["Pencils and direction classes", "Section",ExpressionUUID->"72822dfe-e8f4-4fd8-97fe-b4a6a18b1fb7"],

Cell["Pencil at the centre of a 3x3 grid.", "CodeText",ExpressionUUID->"954ebfa4-3227-44ec-bb8d-647aded85fde"],

Cell[BoxData[
 RowBox[{"PencilDirections", "[", 
  RowBox[{"g", ",", "5"}], "]"}]], "Input",ExpressionUUID->"c5d2a97f-781f-\
48a5-a270-240fab0bdc32"],

Cell["Number of direction classes at every vertex.", "CodeText",ExpressionUUID->"190fed75-ed69-44fd-a576-4554d019afea"],

Cell[BoxData[
 RowBox[{"AssociationMap", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"PencilCardinality", "[", 
     RowBox[{"g", ",", "#1"}], "]"}], "&"}], ",", 
   RowBox[{"VertexList", "[", "g", "]"}]}], "]"}]], "Input",ExpressionUUID->\
"44d67af4-4edf-4bc2-83fe-26fd0fae7527"],

Cell["Total number of canonical lines.", "CodeText",ExpressionUUID->"33209f4a-78c1-4433-9143-d4361e59d520"],

Cell[BoxData[
 RowBox[{"LineCount", "[", "g", "]"}]], "Input",ExpressionUUID->"c21f6cfd-ceb2-4f3b-ab02-d101761e08fe"],

Cell["Pointwise incidence", "Section",ExpressionUUID->"0c141a2b-ed13-4bb0-ae1d-514b6d9ab9e7"],

Cell["Two vertices in the same direction at the centre.", "CodeText",ExpressionUUID->"79687491-d7d9-46e0-8b41-93dd1fd6768e"],

Cell[BoxData[
 RowBox[{"SameDirectionQ", "[", 
  RowBox[{"g", ",", "5", ",", "4", ",", "6"}], "]"}]], "Input",ExpressionUUID->\
"57681ebb-f573-4714-b0a2-0283f67ece64"],

Cell["Three collinear path vertices.", "CodeText",ExpressionUUID->"0f7d6cfd-66a2-4e7e-842c-d2befcb2a1eb"],

Cell[BoxData[
 RowBox[{"CollinearQ", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "6", "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "3", ",", "5"}], "}"}]}], "]"}]], "Input",ExpressionUUID\
->"b6932766-6513-4687-a36f-9fbcc1b79645"],

Cell["Two diagonals concurrent at the grid centre.", "CodeText",ExpressionUUID->"5aa0d378-4988-4134-bac4-48eb09349373"],

Cell[BoxData[
 RowBox[{"ConcurrentQ", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "5", ",", "9"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "5", ",", "7"}], "}"}]}], "}"}]}], "]"}]], "Input",Exp\
ressionUUID->"60ee7cde-16ad-40ee-bc77-be33189b7d34"],

Cell["Find common point / common line", "Section",ExpressionUUID->"b4398a25-8bef-406b-8165-ce5664dc2eb0"],

Cell["Common point of two crossing diagonals.", "CodeText",ExpressionUUID->"e55b8ad8-7501-41e8-b003-33d4d477a9f1"],

Cell[BoxData[
 RowBox[{"FindInfraCommonPoint", "[", 
  RowBox[{"g", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "5", ",", "9"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "5", ",", "7"}], "}"}]}], "}"}], ",", "All"}], 
  "]"}]], "Input",ExpressionUUID->"aa344e30-10ac-4c66-a342-eb34ceb76939"],

Cell["Common line of three collinear path vertices.", "CodeText",ExpressionUUID->"240f80a5-0a50-4ba3-b58f-a3567216a689"],

Cell[BoxData[
 RowBox[{"FindInfraCommonLine", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "6", "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "3", ",", "5"}], "}"}], ",", "All"}], "]"}]], "Input",Ex\
pressionUUID->"80b7a8b4-4cc9-4c52-b23e-a67bab3eac92"],

Cell["Uniqueness", "Section",ExpressionUUID->"acc532e3-008f-4973-b08c-92b4ff79bb9b"],

Cell["Unique pencil test at the grid centre.", "CodeText",ExpressionUUID->"ce76a4cd-a4fb-4b76-aad8-a6b25d89a4c9"],

Cell[BoxData[
 RowBox[{"UniquePencilQ", "[", 
  RowBox[{"g", ",", "5"}], "]"}]], "Input",ExpressionUUID->"afd09b82-407d-\
41a1-8c9f-608e5be1ac64"],

Cell["Unique-line test on three collinear path vertices.", "CodeText",ExpressionUUID->"d720e318-5f5c-4bbb-833b-8d67a5f1d86b"],

Cell[BoxData[
 RowBox[{"UniqueCollinearQ", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "6", "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "3", ",", "5"}], "}"}]}], "]"}]], "Input",ExpressionUUID\
->"4779ca78-ee3b-48c7-8a17-b28b72b4ad18"],

Cell["Whitehead axioms and projective plane", "Section",ExpressionUUID->"4c645341-7b3f-4197-b880-62f8932e5e2b"],

Cell["Axioms on K4.", "CodeText",ExpressionUUID->"89e8cb8c-e6d7-475a-953a-e9c391bbe4d5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"WhiteheadW1Q", "[", "k4", "]"}], ",", 
   RowBox[{"WhiteheadW2Q", "[", "k4", "]"}], ",", 
   RowBox[{"WhiteheadW3Q", "[", "k4", "]"}]}], "}"}]], "Input",ExpressionUUID->\
"6fcf44cb-eb7c-414b-b4f5-857e5c684742"],

Cell["Projective plane test on K4.", "CodeText",ExpressionUUID->"21e5d668-f72a-4275-831f-6459c7cce463"],

Cell[BoxData[
 RowBox[{"ProjectivePlaneGraphQ", "[", "k4", "]"}]], "Input",ExpressionUUID->"e6f580a9-fffc-4a4a-adba-385d0a491812"],

Cell["And on the 3x3 grid.", "CodeText",ExpressionUUID->"7639d370-b365-46cd-9fc0-80fc55baf7d3"],

Cell[BoxData[
 RowBox[{"ProjectivePlaneGraphQ", "[", "g", "]"}]], "Input",ExpressionUUID->"b285adab-db3f-4b60-9325-2213936131b9"],

Cell["Rays", "Section",ExpressionUUID->"b0ddfe30-8061-4e52-afc3-4ad86bd74670"],

Cell["All rays from the grid centre in vertex 6's direction.", "CodeText",ExpressionUUID->"cec490d0-015f-489d-b90b-86656da142fd"],

Cell[BoxData[
 RowBox[{"FindInfraRay", "[", 
  RowBox[{"g", ",", "5", ",", "6", ",", "All"}], "]"}]], "Input",ExpressionUUI\
D->"b84f2dd5-a65a-4a9b-9047-430137817d0a"],

Cell["See also", "Section",ExpressionUUID->"682f184a-d92f-44b2-bcf1-e6bd676282c1"],

Cell["ProjectiveGeometryGuide", "Item",ExpressionUUID->"ff0afaf9-ab87-4599-be89-cc146baf6dbb"],

Cell["EuclideanGeometryTutorial", "Item",ExpressionUUID->"def90f3c-0c20-49e0-9d51-5cc67bb3d627"],

Cell["TarskiGeometryTutorial", "Item",ExpressionUUID->"b02380f0-45aa-44dd-b12e-ddef33974a0d"]
},
