Notebook[{
Cell["Euclidean Geometry Tutorial", "Title",ExpressionUUID->"76ab1683-8da7-4b1c-a068-2397913405f1"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"9bb7d003-7efd-4f28-b68f-ec6fc4c39cd7"],

Cell["\<\
A compact tour of the Euclidean layer on paths and grids: segments, lines, \
shells, circles, midpoints, perpendiculars, parallels, and the bisecting \
hyperplane. Every Find* returns a wrapped multi-realisation that \
InfraSceneHighlight can render directly.\
\>", "Text",ExpressionUUID->"85c35db2-1f3e-4dc4-aeae-40862d3eae10"],

Cell["Setup", "Section",ExpressionUUID->"df0d95f1-35b5-4ea8-a47f-cd4ff9512ed4"],

Cell["\<\
Load the dev paclet from its checkout and the package context.\
\>", "CodeText",ExpressionUUID->"c7129b04-dd11-4015-a00b-8c23db3ed6e5"],

Cell[BoxData[
 RowBox[{"Defer", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<../../..\>\""}], 
       "}"}], "]"}], "]"}], ";"}], ",", 
   RowBox[{
    RowBox[{
    "Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", "]"}], 
    ";"}]}], "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"df849f63-d7ea-4d8e-871e-1c00cea79295"],

Cell["Two working graphs: a path and a small grid.", "CodeText",ExpressionUUID->"761f3c63-ea0b-4594-83a1-be5bec972801"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g1", "=", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "7", "]"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"af6555ca-32f2-40e9-8d89-3f59fee6c4e8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g2", "=", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"4", ",", "4"}], "}"}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"c02cb148-641e-44aa-8a4f-a896dcabb9c2"],

Cell["Segments", "Section",ExpressionUUID->"d437e034-d754-4f32-a3f4-78d23309ee4d"],

Cell["Every geodesic between opposite corners of the grid.", "CodeText",ExpressionUUID->"61c49767-01e7-4d00-b975-7f91c8a90b75"],

Cell[BoxData[
 RowBox[{"FindSegment", "[", 
  RowBox[{"g2", ",", "1", ",", "16", ",", "All"}], "]"}]], "Input",ExpressionU\
UID->"7e7b8402-24b6-443d-a068-b6b06c9594b2"],

Cell["Render the geodesic bundle as a diffuse picture.", "CodeText",ExpressionUUID->"9fa3ce24-4a5e-47a1-b155-2751f7e7df69"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{"FindSegment", "[", 
     RowBox[{"g2", ",", "1", ",", "16", ",", "All"}], "]"}], "}"}]}], 
  "]"}]], "Input",ExpressionUUID->"192b8245-362d-4127-96e9-04d70fd8eb6b"],

Cell["Cardinality of the multi-realisation.", "CodeText",ExpressionUUID->"f758f4f8-9980-4790-93cc-2cc3edab6240"],

Cell[BoxData[
 RowBox[{"Length", "[", 
  RowBox[{"FindSegment", "[", 
   RowBox[{"g2", ",", "1", ",", "16", ",", "All"}], "]"}], "]"}]], "Input",Exp\
ressionUUID->"4784eadf-2f33-46bb-8c90-580465f69fdb"],

Cell["Lines", "Section",ExpressionUUID->"05ef5e1a-e008-4e1c-860d-12c0ae12ceae"],

Cell["Maximal geodesic extensions through two interior vertices.", "CodeText",ExpressionUUID->"bb44bd07-b75b-4408-ab50-00e2f3c3ee4b"],

Cell[BoxData[
 RowBox[{"FindLine", "[", 
  RowBox[{"g2", ",", "6", ",", "11", ",", "All"}], "]"}]], "Input",ExpressionU\
UID->"1e1a55e1-efae-4be8-90c2-0cc71997fb3e"],

Cell["Diffuse rendering.", "CodeText",ExpressionUUID->"8bc60b5a-3b82-4b20-b52e-8ee104a396e6"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"FindLine", "[", 
      RowBox[{"g2", ",", "6", ",", "11", ",", "All"}], "]"}], "\[Rule]", 
     "Blue"}], "}"}]}], "]"}]], "Input",ExpressionUUID->"4638e0ee-bbde-4bf2-\
912c-1ad445d5784f"],

Cell["Shells and circles", "Section",ExpressionUUID->"b315fe6f-5da9-49a2-b3c9-c38e2917fe3e"],

Cell["The distance-2 metric shell around the centre of the grid.", "CodeText",ExpressionUUID->"372dbc2d-b366-40d0-9b61-2567679f3056"],

Cell[BoxData[
 RowBox[{"FindShell", "[", 
  RowBox[{"g2", ",", "6", ",", "2"}], "]"}]], "Input",ExpressionUUID->\
"181b543c-7c6a-4370-bae1-dceccf5f7a97"],

Cell["Separating cycles in the level surface.", "CodeText",ExpressionUUID->"3ee22856-b635-41b7-9281-a48a1b6b6d2e"],

Cell[BoxData[
 RowBox[{"FindCircle", "[", 
  RowBox[{"g2", ",", "6", ",", "2", ",", "All"}], "]"}]], "Input",ExpressionUU\
ID->"bcf5c7b0-fb91-424c-9b35-d838dbf3ea26"],

Cell["Render shell and circles together.", "CodeText",ExpressionUUID->"45e44bd1-58e0-45d7-93d5-2983483cd327"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"FindShell", "[", 
       RowBox[{"g2", ",", "6", ",", "2"}], "]"}], "\[Rule]", "LightBlue"}], ",", 
     RowBox[{
      RowBox[{"FindCircle", "[", 
       RowBox[{"g2", ",", "6", ",", "2", ",", "All"}], "]"}], "\[Rule]", 
      "Green"}]}], "}"}]}], "]"}]], "Input",ExpressionUUID->"5bbbc0df-cb3f-\
4c67-95dd-2923ea26cbff"],

Cell["Midpoints and perpendiculars", "Section",ExpressionUUID->"68931cd8-bafb-4d1c-849d-25285f08f2eb"],

Cell["Midpoints on the path graph.", "CodeText",ExpressionUUID->"1eb4312f-f19e-426e-8e28-97733e08cc4c"],

Cell[BoxData[
 RowBox[{"FindMidpoint", "[", 
  RowBox[{"g1", ",", "1", ",", "7", ",", "All"}], "]"}]], "Input",ExpressionUU\
ID->"513a6447-2bfe-46aa-aefe-f16dd25155e8"],

Cell["Feet of perpendicular from an off-line vertex on the grid.", "CodeText",ExpressionUUID->"e08c75c8-91d0-4bbe-8584-43560fb88849"],

Cell[BoxData[
 RowBox[{"FindPerpendicular", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "5", ",", "9", ",", "13"}], "}"}], ",", "11", ",", 
   "All"}], "]"}]], "Input",ExpressionUUID->"73139c13-c909-49f5-a07f-\
6ef45ce77004"],

Cell["Parallels", "Section",ExpressionUUID->"1ea2eed2-4a68-4326-8abd-be6411af308d"],

Cell["Lines through a point parallel to a given line in a grid.", "CodeText",ExpressionUUID->"eda06eb4-3b7d-41f8-b85f-13bd70cef047"],

Cell[BoxData[
 RowBox[{"FindParallel", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "5", ",", "9", ",", "13"}], "}"}], ",", "2", ",", 
   "All"}], "]"}]], "Input",ExpressionUUID->"4a63090d-b075-4eab-ab6d-\
d275462ac0df"],

Cell["Bisecting hyperplane", "Section",ExpressionUUID->"ca5b37f7-fefd-45cf-b3ae-2ca4ecb8eb56"],

Cell["On an odd-length path there is one bisecting separator.", "CodeText",ExpressionUUID->"8f3e6e4f-35b8-4ba3-ac32-6917889ea0e9"],

Cell[BoxData[
 RowBox[{"FindBisectingHyperplane", "[", 
  RowBox[{"g1", ",", "1", ",", "7", ",", "All"}], "]"}]], "Input",ExpressionUU\
ID->"e9057f0d-3d84-4fcb-8376-70ce1c39754d"],

Cell["\<\
On an even-length path the bisector is empty; widen the window to recover the \
two adjacent cuts.\
\>", "CodeText",ExpressionUUID->"89f018dd-6975-4a8e-b6cb-767270760401"],

Cell[BoxData[
 RowBox[{"FindBisectingHyperplane", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "6", "]"}], "]"}], ",", "1", ",", "6", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "All"}], "]"}]], "Input",Expr\
essionUUID->"718b5dda-d7ec-4076-a807-4ed7190828b6"],

Cell["Predicates", "Section",ExpressionUUID->"90a8e998-3a97-4282-9959-6e4ecaddc6ae"],

Cell["A geodesic-DAG path is a segment.", "CodeText",ExpressionUUID->"7934c6b6-7179-4e72-ae2b-0be8b99bcc37"],

Cell[BoxData[
 RowBox[{"SegmentQ", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]}], "]"}]], "Input",Expr\
essionUUID->"5c227c25-3471-4e9e-80ad-c54fa2e9997f"],

Cell["A maximal geodesic is recognised as a line.", "CodeText",ExpressionUUID->"c25929ae-fcfe-4112-8a91-d6d2c10c0f52"],

Cell[BoxData[
 RowBox[{"LineQ", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "5", ",", "9", ",", "13"}], "}"}]}], "]"}]], "Input",Exp\
ressionUUID->"62558fb6-8a46-42ea-b3db-aabe19501c7e"],

Cell["Parallels detected by constant pairwise distance.", "CodeText",ExpressionUUID->"a6136c8d-37b2-4fc0-b5eb-dd1685ad37c9"],

Cell[BoxData[
 RowBox[{"ParallelQ", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "5", ",", "9", ",", "13"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"2", ",", "6", ",", "10", ",", "14"}], "}"}]}], "]"}]], "Input",Ex\
pressionUUID->"ee3e3ec3-3ecf-4b45-bdf2-7f00558cb58e"],

Cell["See also", "Section",ExpressionUUID->"6c33f65e-c6ab-4a89-9af9-5e67036240d4"],

Cell["EuclideanGeometryGuide", "Item",ExpressionUUID->"63f4ba88-0017-4a4f-b571-4fcb39ed93fb"],

Cell["PathSpaceGuide", "Item",ExpressionUUID->"5a8320a5-187a-496d-bdce-b076a92a8325"],

Cell["CoordinatizationTutorial", "Item",ExpressionUUID->"34eae20e-420c-4e7b-b990-ec0c92d13751"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"d0c0adf3-5051-4eda-8478-4a233b99d813"
]
