Notebook[{

Cell[CellGroupData[{
Cell["Euclidean Geometry Tutorial", "Title",ExpressionUUID->"ec449d37-5d3a-407e-aafb-71534b0ad421"],

Cell["\<\
A compact tour of the Euclidean layer on paths and grids: segments, spheres, \
and the separating bisector.
Euclidean geometry is supported if there would be some affine structure.\
\>", "Text",
 CellChangeTimes->{{3.987089439010808*^9, 
  3.987089457600532*^9}},ExpressionUUID->"71effd71-0116-4cee-814d-\
257ad4e8bbc6"],

Cell["\<\
Affine geometry = projective geometry + choice of hyperplane at infinity . \
Euclidean geometry = affine geometry + inner product .\
\>", "Text",
 CellChangeTimes->{{3.9870895682932367`*^9, 
  3.987089570621019*^9}},ExpressionUUID->"137c4417-b2b7-40f8-b68a-\
1d43f03a0441"],

Cell["\<\
Graph does not have a structure of a Euclidean space - real vector space with \
inner product. \
\>", "Text",
 CellChangeTimes->{{3.9870895964262867`*^9, 
  3.987089616793516*^9}},ExpressionUUID->"8cc41154-6e8f-44a1-8607-\
9a0ca13f7546"],

Cell[CellGroupData[{

Cell["Setup", "Section",ExpressionUUID->"e749490e-80fa-4337-b20b-901a71910c16"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PacletDirectoryLoad", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", " ", "\"\<../../..\>\""}],
      "}"}], "]"}], "]"}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.987236867917878*^9, 3.987236893357332*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"97faa8f3-f843-4d5c-89a0-783aba663a84"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",
 CellChangeTimes->{{3.987182523057169*^9, 3.987182523262128*^9}, {
  3.987236073493876*^9, 3.987236097253687*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"eac4bb35-1bca-43ad-9858-6e0cf7098708"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", " ", 
   RowBox[{"MeshConnectivityGraph", "[", " ", 
    RowBox[{"DiscretizeRegion", "[", 
     RowBox[{
      RowBox[{"Rectangle", "[", "]"}], ",", " ", 
      RowBox[{"MaxCellMeasure", "->", ".02"}], ",", " ", 
      RowBox[{"PrecisionGoal", "->", "Infinity"}]}], "]"}], " ", "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellLabel->"In[3]:=",ExpressionUUID->"a673a86f-7631-4730-b629-ed4d02d79b87"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Segments", "Section",ExpressionUUID->"d3064aca-18a6-42e0-b244-e9795fd1aad3"],

Cell["Enumerate all geodesics between opposite grid corners.", "CodeText",ExpressionUUID->"92210a53-c779-48e0-96d9-cb9403da072a"],

Cell[BoxData[
 RowBox[{"FindSegment", "[", 
  RowBox[{"g2", ",", "1", ",", "16", ",", "All"}], "]"}]], "Input",ExpressionU\
UID->"5859cde5-bcf0-4603-ac60-0e66167fca15"],

Cell["Render the geodesic bundle as a diffuse picture.", "CodeText",ExpressionUUID->"ba17cd5d-59ea-4864-bbd7-a82eb7321a09"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"FindSegment", "[", 
      RowBox[{"g2", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
     "Blue"}], "}"}]}], "]"}]], "Input",ExpressionUUID->"f4920de6-3d3a-42c5-\
bd60-83be18b407ee"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Circles", "Section",ExpressionUUID->"1bfbbbec-87e2-42e9-b91b-643ddf9cfac1"],

Cell["Compute separating cycles around the grid centre.", "CodeText",ExpressionUUID->"b0f75ddc-1ee3-43ab-b7d2-daa9a6046191"],

Cell[BoxData[
 RowBox[{"FindCircle", "[", 
  RowBox[{"g2", ",", "6", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2"}], "}"}], ",", "All"}], "]"}]], "Input",ExpressionUU\
ID->"a764e439-488e-4754-ad04-c7e9027e2fd3"],

Cell["Render the separating-cycle bundle.", "CodeText",ExpressionUUID->"76b7dc90-1599-4ffd-9366-7c5f718eb9ca"],

Cell[BoxData[
 RowBox[{"InfraSceneHighlight", "[", 
  RowBox[{"g2", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"FindCircle", "[", 
      RowBox[{"g2", ",", "6", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}], ",", "All"}], "]"}], "\[Rule]", 
     "Green"}], "}"}]}], "]"}]], "Input",ExpressionUUID->"fc4c7855-d09e-4c5d-\
8810-028f824d6e2c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Bisecting hyperplanes", "Section",ExpressionUUID->"7d6ea771-b8ae-49bb-b4df-d42b0a289c44"],

Cell["\<\
On an odd path there is one separator in the strict bisector.\
\>", "CodeText",ExpressionUUID->"ba490f78-d070-4e72-9e3a-f7bb08543bd3"],

Cell[BoxData[
 RowBox[{"FindBisectingHyperplane", "[", 
  RowBox[{"g1", ",", "1", ",", "5", ",", "All"}], "]"}]], "Input",ExpressionUU\
ID->"7e822a87-8b49-49be-b20e-514361dc73d5"],

Cell["\<\
On an even path, widen the window to recover the middle cuts.\
\>", "CodeText",ExpressionUUID->"735f11b0-96e2-4386-8415-32cb0ce96dc6"],

Cell[BoxData[
 RowBox[{"FindBisectingHyperplane", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "6", "]"}], "]"}], ",", "1", ",", "6", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "All"}], "]"}]], "Input",Expr\
essionUUID->"699f464a-50c4-4def-8db9-d8fcfecc8c53"]
}, Open  ]]
}, Open  ]]
},
