Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"bb", "=", 
   RowBox[{"GroupBy", "[", 
    RowBox[{
     RowBox[{"Subsets", "[", 
      RowBox[{
       RowBox[{"VertexList", "[", "g", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"Length", " ", "@", " ", "b"}], "}"}]}], "]"}], ",", 
     RowBox[{
      RowBox[{"RadarBasisQ", "[", 
       RowBox[{"g", ",", "#"}], "]"}], "&"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Length", " ", "/@", " ", "bb"}]}], "Input",
