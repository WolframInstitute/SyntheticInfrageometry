Cell[BoxData[{
 RowBox[{
  RowBox[{"c", "=", 
   RowBox[{"OrthogonalCoordinates", "[", 
    RowBox[{"g", ",", "center", ",", "axes"}], "]"}]}], ";"}], "\n", 
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", "=", 
     RowBox[{"Length", "@", 
      RowBox[{"First", "@", 
       RowBox[{"Values", "@", "c"}]}]}]}], "}"}], ",", 
   RowBox[{"Row", "@", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"levelSets", "=", 
           RowBox[{"KeySort", "[", 
            RowBox[{"GroupBy", "[", 
             RowBox[{
              RowBox[{"Keys", "[", "c", "]"}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"c", "[", "#", "]"}], "[", 
                RowBox[{"[", "i", "]"}], "]"}], "&"}]}], "]"}], "]"}]}], ",", 
          
          RowBox[{"maxAbs", "=", 
           RowBox[{"Max", "[", 
            RowBox[{
             RowBox[{"Abs", "/@", 
              RowBox[{
               RowBox[{"Values", "[", "c", "]"}], "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "i"}], "]"}], "]"}]}], ",", "1"}], 
            "]"}]}], ",", 
          RowBox[{"baseHue", "=", 
           RowBox[{"i", "/", 
            RowBox[{"(", 
             RowBox[{"d", "+", "1"}], ")"}]}]}], ",", 
          RowBox[{"axisVertices", "=", 
           RowBox[{"Replace", "[", 
            RowBox[{
             RowBox[{"axes", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"InfraSegment", "|", "InfraLine"}], ")"}], "[", 
                 "reps_List", "]"}], ":>", 
                RowBox[{"First", "@", "reps"}]}], ",", 
               RowBox[{"dag_Graph", ":>", 
                RowBox[{"VertexList", "@", "dag"}]}], ",", 
               RowBox[{"seq_List", ":>", "seq"}]}], "}"}]}], "]"}]}]}], "}"}],
         ",", 
        RowBox[{"HighlightGraph", "[", 
         RowBox[{"g", ",", 
          RowBox[{"Append", "[", 
           RowBox[{
            RowBox[{"KeyValueMap", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"coordinate", ",", "vertices"}], "}"}], "|->", 
               RowBox[{"Style", "[", 
                RowBox[{
                 RowBox[{"Subgraph", "[", 
                  RowBox[{"g", ",", "vertices"}], "]"}], ",", 
                 RowBox[{"Directive", "[", 
                  RowBox[{"Thick", ",", 
                   RowBox[{"Hue", "[", 
                    RowBox[{"baseHue", ",", "0.9", ",", 
                    RowBox[{"1.0", "-", 
                    RowBox[{"0.7", "*", 
                    RowBox[{
                    RowBox[{"Abs", "[", "coordinate", "]"}], "/", 
                    "maxAbs"}]}]}]}], "]"}]}], "]"}]}], "]"}]}], ",", 
              "levelSets"}], "]"}], ",", 
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"Subgraph", "[", 
               RowBox[{"g", ",", "axisVertices"}], "]"}], ",", 
              RowBox[{"Directive", "[", 
               RowBox[{"Red", ",", "Thick"}], "]"}]}], "]"}]}], "]"}], ",", 
          RowBox[{"ImageSize", "->", "Medium"}]}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "d"}], "}"}]}], "]"}]}]}], "]"}], "\n"}], "Input",
 CellChangeTimes->{{3.9873273372082157`*^9, 
  3.98732733721005*^9}},ExpressionUUID->"5b08eb58-5717-4115-908c-\
19b7c4cf7fa6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Rectilinear coordinates", "Section",
 CellChangeTimes->{{3.987274475534059*^9, 
  3.987274488193825*^9}},ExpressionUUID->"b1b561e2-df6c-4ad3-aac1-\
ef5b27342584"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
  "Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", "]"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"MeshConnectivityGraph", "@", 
    RowBox[{"DiscretizeRegion", "[", 
     RowBox[{
      RowBox[{"Rectangle", "[", "]"}], ",", 
      RowBox[{"MaxCellMeasure", "->", "0.02"}], ",", 
      RowBox[{"PrecisionGoal", "->", "Infinity"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"c", "=", 
    RowBox[{"First", "@", 
     RowBox[{"Nearest", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"GraphEmbedding", "[", "g", "]"}], "->", 
        RowBox[{"VertexList", "[", "g", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"0.5", ",", "0.5"}], "}"}]}], "]"}]}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"--", 
     RowBox[{"--", 
      RowBox[{"--", 
       RowBox[{"--", 
        RowBox[{"--", "1."}]}]}]}]}], " ", "Frames", " ", "by", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"radius", "--"}], "--"}], "--"}], "--"}], "--"}]}], "*)"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Row", "@", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"frame", "=", 
          RowBox[{"Replace", "[", 
           RowBox[{
            RowBox[{"FindOrthogonalFrame", "[", 
             RowBox[{"g", ",", "c", ",", 
              RowBox[{"\"\<AxisLength\>\"", "->", "r"}]}], "]"}], ",", 
            RowBox[{"$Failed", "->", 
             RowBox[{"{", "}"}]}]}], "]"}]}], ",", 
         RowBox[{"bdry", "=", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"VertexList", "@", "g"}], ",", 
