85452678defc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"b", " ", "=", " ", 
  RowBox[{"First", " ", "@", " ", 
   RowBox[{"MinimalBy", "[", 
    RowBox[{
     RowBox[{"bb", "[", "True", "]"}], ",", 
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"GraphDistance", "[", 
          RowBox[{"g", ",", "##"}], "]"}], "&"}], "@@@", 
        RowBox[{"Subsets", "[", 
         RowBox[{"#", ",", 
          RowBox[{"{", "2", "}"}]}], "]"}]}], "]"}], "&"}]}], 
    "]"}]}]}]], "Input",
