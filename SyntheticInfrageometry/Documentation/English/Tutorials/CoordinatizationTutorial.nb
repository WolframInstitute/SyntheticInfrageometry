Cell[CellGroupData[{

Cell["Orthogonal Coordinates", "Section",
 CellChangeTimes->{{3.987273797689374*^9, 
  3.9872738134085903`*^9}},ExpressionUUID->"58ed310b-29c5-415c-b770-\
b3fc78f3673a"],

Cell["\<\
Pick a small set of well-separated longest paths (or DAGs) as axes; project \
each vertex onto each axis and take the layer index. The result is a tuple of \
non-negative integers (or signed integers, when an origin is chosen). The \
algorithm is constructed in such a way that the orthogonal projections onto \
axes on the graph agree with the orthogonal projections on the axes in the \
pulled back Euclidean structure.\
\>", "Text",
 CellChangeTimes->{{3.9872527583790817`*^9, 
  3.987252822518712*^9}},ExpressionUUID->"4913ecb3-6415-4c28-874b-\
bc0a88e21c04"],

Cell[CellGroupData[{

Cell[BoxData["c"], "Input",
 CellChangeTimes->{3.987327365564081*^9},
 CellLabel->"In[72]:=",ExpressionUUID->"ba89fdef-3ff7-404a-b32f-3dafe0599cf9"],

Cell[BoxData[
 RowBox[{"InfraPoint", "[", 
  RowBox[{"{", 
   RowBox[{"{", 
    RowBox[{"0", ",", "239"}], "}"}], "}"}], "]"}]], "Output",
 CellChangeTimes->{3.987327366093286*^9},
 CellLabel->"Out[72]=",ExpressionUUID->"adbb3944-8082-4a75-ab0d-5e0291572ab9"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"orthogonalFrames", "=", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"frame", "=", 
           RowBox[{"FindOrthogonalFrame", "[", 
            RowBox[{"g", ",", "c", ",", 
             RowBox[{"\"\<AxisLength\>\"", "->", "r"}], ",", 
             RowBox[{"\"\<BranchSampleSize\>\"", "->", "3"}], ",", 
             RowBox[{"\"\<AllowPartial\>\"", "->", "True"}]}], "]"}]}], ",", 
          RowBox[{"bdry", "=", 
           RowBox[{"Select", "[", 
            RowBox[{
             RowBox[{"VertexList", "[", "g", "]"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"InfraDistance", "[", 
                RowBox[{"g", ",", "c", ",", "#"}], "]"}], "==", "r"}], 
              "&"}]}], "]"}]}]}], "}"}], ",", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Radius\>\"", "->", "r"}], ",", 
          RowBox[{"\"\<Frame\>\"", "->", "frame"}], ",", 
          RowBox[{"\"\<Boundary\>\"", "->", "bdry"}]}], "|>"}]}], "]"}], ",", 
      
      RowBox[{"{", 
       RowBox[{"r", ",", "1", ",", 
        RowBox[{"VertexEccentricity", "[", 
         RowBox[{"g", ",", 
          RowBox[{"c", "[", "\"\<First\>\"", "]"}]}], "]"}]}], "}"}]}], 
     "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Row", "[", 
  RowBox[{"frames", "/.", " ", 
   RowBox[{"data_", ":>", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"r", "=", 
         RowBox[{"data", "[", "\"\<Radius\>\"", "]"}]}], ",", 
        RowBox[{"frame", "=", 
         RowBox[{"data", "[", "\"\<Frame\>\"", "]"}]}], ",", 
        RowBox[{"bdry", "=", 
         RowBox[{"data", "[", "\"\<Boundary\>\"", "]"}]}]}], "}"}], ",", 
      RowBox[{"HighlightGraph", "[", 
       RowBox[{"g", ",", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"Catenate", "@", 
           RowBox[{"MapThread", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"axis", ",", "color"}], "}"}], "|->", 
              RowBox[{"Join", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"Style", "[", 
                   RowBox[{"#", ",", "color", ",", 
                    RowBox[{"PointSize", "[", "Medium", "]"}]}], "]"}], "&"}],
                  "/@", "axis"}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Style", "[", 
                   RowBox[{"#", ",", "color", ",", "Thick"}], "]"}], "&"}], "/@", 
                 RowBox[{"(", 
                  RowBox[{"UndirectedEdge", "@@@", 
                   RowBox[{"Partition", "[", 
                    RowBox[{"axis", ",", "2", ",", "1"}], "]"}]}], ")"}]}]}], 
               "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"frame", ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"Hue", "[", 
                  RowBox[{"#", ",", "0.35", ",", "0.9"}], "]"}], "&"}], "/@", 
                
                RowBox[{"Subdivide", "[", 
                 RowBox[{"0.33", ",", "0.78", ",", 
                  RowBox[{"Max", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", "frame", "]"}], "-", "1"}], ",", 
                    "1"}], "]"}]}], "]"}]}]}], "}"}]}], "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{"#", ",", "Red", ",", 
              RowBox[{"PointSize", "[", "Medium", "]"}]}], "]"}], "&"}], "/@",
            "bdry"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{"#", ",", "Red", ",", "Thick"}], "]"}], "&"}], "/@", 
           RowBox[{"EdgeList", "[", 
            RowBox[{"Subgraph", "[", 
             RowBox[{"g", ",", "bdry"}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"Style", "[", 
            RowBox[{
             RowBox[{"c", "[", "\"\<First\>\"", "]"}], ",", "Red", ",", 
             RowBox[{"PointSize", "[", "Large", "]"}]}], "]"}], "}"}]}], 
         "]"}], ",", 
        RowBox[{"ImageSize", "->", "180"}]}], "]"}]}], "]"}]}]}], 
  "]"}], "\n"}], "Input",
 CellChangeTimes->{{3.9873230662128353`*^9, 3.987323092422175*^9}, {
   3.987323210422001*^9, 3.987323211900873*^9}, {3.9873252753965797`*^9, 
   3.987325283289674*^9}, 3.987325401916958*^9, 3.987326850161345*^9, {
   3.98732737610413*^9, 
   3.9873273933718653`*^9}},ExpressionUUID->"c3839649-f68a-4658-88a1-\
9c5aed1f1fd1"],

