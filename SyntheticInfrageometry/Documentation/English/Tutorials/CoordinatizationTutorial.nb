Cell[CellGroupData[{

Cell["Radar coordinates", "Section",
 CellChangeTimes->{{3.9871825503280573`*^9, 
  3.9871825516069317`*^9}},ExpressionUUID->"21c29505-d066-490a-bc2d-\
61d50ab19b42"],

Cell[TextData[{
 "Given a tuple of vertices, ",
 StyleBox["radar coordinates",
  FontWeight->"Bold"],
 " of another vertex is a vector of distances to these points. A ",
 StyleBox["spanning set ",
  FontWeight->"Bold"],
 "is a tuple of points such that the radar coordinates are injective; that \
is, they distinguish every vertex. A ",
 StyleBox["radar basis",
  FontWeight->"Bold"],
 " is a minimal spanning set."
}], "Text",
 CellChangeTimes->{{3.9872579606146317`*^9, 3.987258058289448*^9}, {
   3.987258227308435*^9, 3.987258259306147*^9}, {3.987258314173193*^9, 
   3.9872583832810307`*^9}, 3.987258788190995*^9, {3.987334848189114*^9, 
