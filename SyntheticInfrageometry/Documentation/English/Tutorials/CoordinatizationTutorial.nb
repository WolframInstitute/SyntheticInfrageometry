Cell["\<\
Find radar coordinates and visualize their level sets (shells)\
\>", "CodeText",
 CellChangeTimes->{{3.987237396779749*^9, 3.987237403602436*^9}, {
  3.9872376076795187`*^9, 3.987237623844433*^9}, {3.9872409369303303`*^9, 
  3.987240936965617*^9}, {3.987334895896432*^9, 
  3.987334898989032*^9}},ExpressionUUID->"0c778fe9-796b-42f9-8491-\
bc30f646c2b6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"c", " ", "=", " ", 
   RowBox[{"RadarCoordinates", "[", 
    RowBox[{"g", ",", " ", "b"}], "]"}]}], ";"}], "\n", 
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d", " ", "=", " ", 
     RowBox[{"Length", "[", 
      RowBox[{"First", "[", 
       RowBox[{"Values", "[", "c", "]"}], "]"}], "]"}]}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{"Row", " ", "@", " ", 
    RowBox[{"Table", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", "\n", "      ", 
         RowBox[{
          RowBox[{"levelSets", " ", "=", " ", 
           RowBox[{"KeySort", "[", 
            RowBox[{"GroupBy", "[", 
             RowBox[{
              RowBox[{"Keys", "[", "c", "]"}], ",", " ", 
              RowBox[{
               RowBox[{
                RowBox[{"c", "[", "#", "]"}], "[", 
                RowBox[{"[", "i", "]"}], "]"}], " ", "&"}]}], "]"}], "]"}]}], 
          ",", "\n", "      ", 
          RowBox[{"maxCoordinate", " ", "=", " ", 
           RowBox[{"Max", "[", 
            RowBox[{
             RowBox[{"Values", "[", "c", "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", " ", "i"}], "]"}], "]"}], "]"}]}], ",", 
          "\n", "      ", 
          RowBox[{"baseHue", " ", "=", " ", 
           RowBox[{"i", " ", "/", " ", 
            RowBox[{"(", 
             RowBox[{"d", " ", "+", " ", "1"}], ")"}]}]}]}], "\n", "    ", 
         "}"}], ",", "\n", "      ", 
        RowBox[{"HighlightGraph", "[", 
         RowBox[{"g", ",", "\n", "        ", 
          RowBox[{"Append", "[", "\n", "          ", 
           RowBox[{
            RowBox[{"KeyValueMap", "[", "\n", "            ", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"coordinate", ",", " ", "vertices"}], "}"}], " ", "|->",
                " ", 
               RowBox[{"Style", "[", "\n", "              ", 
                RowBox[{
                 RowBox[{"Subgraph", "[", 
                  RowBox[{"g", ",", " ", "vertices"}], "]"}], ",", "\n", 
                 "              ", 
                 RowBox[{"Directive", "[", 
                  RowBox[{"Thick", ",", " ", 
                   RowBox[{"Hue", "[", 
                    RowBox[{"baseHue", ",", " ", "0.9", ",", " ", 
                    RowBox[{"1.0", " ", "-", " ", 
                    RowBox[{"0.7", " ", "*", " ", 
                    RowBox[{
                    "coordinate", " ", "/", " ", "maxCoordinate"}]}]}]}], 
                    "]"}]}], "]"}]}], "\n", "            ", "]"}]}], ",", 
              "\n", "            ", "levelSets"}], "\n", "          ", "]"}], 
            ",", "\n", "          ", 
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"Labeled", "[", 
               RowBox[{
                RowBox[{"b", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], ",", "i"}], "]"}], ",", " ", 
              
              RowBox[{"Directive", "[", 
               RowBox[{"Red", ",", " ", 
                RowBox[{"PointSize", "[", "Large", "]"}]}], "]"}]}], "]"}]}], 
           "\n", "        ", "]"}], ",", "\n", "        ", 
          RowBox[{"ImageSize", " ", "->", " ", "Medium"}]}], "\n", "      ", 
         "]"}]}], "\n", "    ", "]"}], ",", "\n", "    ", 
      RowBox[{"{", 
       RowBox[{"i", ",", " ", "d"}], "}"}]}], "\n", "  ", "]"}]}]}], "\n", 
  "]"}]}], "Input",
 InitializationCell->False,
 CellChangeTimes->{{3.987240455966034*^9, 3.987240460250671*^9}, {
   3.9872405415458937`*^9, 3.9872405486418037`*^9}, 3.987240616646822*^9, 
