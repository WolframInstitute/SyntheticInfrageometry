Notebook[{
Cell["Coordinatization", "Title",ExpressionUUID->"88fdebc0-72e7-4a2f-8b53-28784e3f0a85"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"9b1e8ee9-5ee4-4b67-9d10-1b9d62f4ecdf"],

Cell["\<\
Coordinatisation makes the graph-intrinsic vertex space into a coordinate \
space the infra-observer can compute with: radar coordinates (distance \
vectors to a resolving / radar basis), orthogonal coordinates along a fixed \
frame, and resistance-matching spectral coordinates from the Laplacian.\
\>", "Text",ExpressionUUID->"cf681dc6-5823-4b80-9678-de290be6ee1a"],

Cell["Setup", "Section",ExpressionUUID->"e578aab0-3848-4cc3-a172-4738cfe73166"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"95de53f1-f777-446c-bd5e-82a79657d5eb"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"54d56b52-3926-42ba-9ef6-b2dd525ef5c2"],

Cell["Radar coordinates", "Section",ExpressionUUID->"c2fa33e2-4c7a-4b08-8cf9-89f066f9952f"],

Cell["Distance vectors to a chosen resolving set (a radar basis).", "Text",ExpressionUUID->"74243e70-17eb-4090-acc5-966c95d2574c"],

Cell["FindInfraRadarBasis", "Item",ExpressionUUID->"c4e7a3ff-a9c1-43e9-ad6f-81a220e44985"],

Cell["InfraRadarBasisQ", "Item",ExpressionUUID->"9f332064-4b44-4f6a-bf74-c926b96d69f3"],

Cell["RadarCoordinates", "Item",ExpressionUUID->"f7e2274a-1f7d-4ccd-81ce-b1694cb94ac1"],

Cell["Orthogonal coordinates", "Section",ExpressionUUID->"d2cb5478-ca05-4b72-9bc9-dacd2887ecc1"],

Cell["Z-valued displacements along axes through a centre vertex.", "Text",ExpressionUUID->"c0e65153-12d5-460e-9de5-879f920408d7"],

Cell["FindInfraOrthogonalFrame", "Item",ExpressionUUID->"daf88845-119f-4c17-883e-f2c915400b54"],

Cell["OrthogonalCoordinates", "Item",ExpressionUUID->"f8a49081-8172-4558-9afa-5d1566afce1a"],

Cell["FindInfraSpanningAxes", "Item",ExpressionUUID->"2b462b02-407b-42ca-ae4a-6dfccc8c3a3a"],

Cell["Resistance coordinates", "Section",ExpressionUUID->"83c2cef5-71af-47e0-a96c-6b772469ed48"],

Cell["\<\
Spectral coordinates rescaled so that Euclidean distance matches effective \
resistance.\
\>", "Text",ExpressionUUID->"d5f21e9e-69aa-4d76-9e02-6c1a5372c380"],

Cell["ResistanceCoordinates", "Item",ExpressionUUID->"afec0542-6ea1-4f1c-b69f-57007208a179"],

Cell["Tutorial", "Section",ExpressionUUID->"4ebc67b3-281e-4221-9e08-16c7d9786570"],

Cell["See CoordinatizationTutorial for runnable examples.", "Item",ExpressionUUID->"e0ad9861-27d3-4ee6-bf7f-3e2fbbc3b925"],

Cell["References", "Section",ExpressionUUID->"19335553-6618-4daa-9f4d-0489e30fd5d8"],

Cell["\<\
Slater, Leaves of trees, Congressus Numerantium 14, 549-559, 1975 (resolving \
sets)\
\>", "Item",ExpressionUUID->"f65b3a9f-f4f2-4d72-8ad0-98adb0883dd1"],

Cell["\<\
Chartrand, Eroh, Johnson, Oellermann, Resolvability in graphs and the metric \
dimension of a graph, Discrete Appl. Math. 105, 99-113, 2000\
\>", "Item",ExpressionUUID->"32405189-c6b0-4205-8908-dad3a74e6087"],

Cell["\<\
Klein and Randic, Resistance distance, J. Math. Chem. 12, 81-95, 1993\
\>", "Item",ExpressionUUID->"2081cbf7-8714-4b4f-bc9f-6d35016a92ed"],

Cell["\<\
Doyle and Snell, Random Walks and Electric Networks, MAA Carus Monograph 22, \
1984 (resistance metric)\
\>", "Item",ExpressionUUID->"23d3404d-e853-4d57-9ac3-ce7929e18fab"],

Cell["\<\
Coifman and Lafon, Diffusion maps, Appl. Comput. Harmon. Anal. 21(1), 5-30, \
2006\
\>", "Item",ExpressionUUID->"6da526fc-dcc8-434c-87e3-f7c68ab1854f"]
},
