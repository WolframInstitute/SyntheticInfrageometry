Cell["TarskiGeometryGuide", "Item",ExpressionUUID->"b1c2d3e4-0031-4000-8000-000000000031"],

Cell["DistanceMatrixQ", "Item",ExpressionUUID->"b1c2d3e4-0032-4000-8000-000000000032"],

Cell["GraphDistanceMatrix", "Item",ExpressionUUID->"b1c2d3e4-0033-4000-8000-000000000033"],

Cell["AdjacencyMatrix", "Item",ExpressionUUID->"b1c2d3e4-0034-4000-8000-000000000034"],

Cell["GraphDiameter", "Item",ExpressionUUID->"b1c2d3e4-0035-4000-8000-000000000035"],

Cell["Inner", "Item",ExpressionUUID->"b1c2d3e4-0036-4000-8000-000000000036"],

Cell["Min", "Item",ExpressionUUID->"b1c2d3e4-0037-4000-8000-000000000037"],

Cell["Plus", "Item",ExpressionUUID->"b1c2d3e4-0038-4000-8000-000000000038"],

Cell["References", "Section",ExpressionUUID->"b1c2d3e4-0039-4000-8000-000000000039"],

Cell["\<\
Maclagan and Sturmfels, Introduction to Tropical Geometry, AMS Graduate \
Studies in Mathematics 161, 2015. Ch. 1 (tropical arithmetic) and Ch. 5 \
(tropical linear algebra). \
https://janos.cs.technion.ac.il/COURSES/238900-13/Tropical/MaclaganSturmfels.\
pdf\
\>", "Item",ExpressionUUID->"b1c2d3e4-003a-4000-8000-00000000003a"],

Cell["\<\
Butkovic, Max-linear Systems: Theory and Algorithms, Springer 2010. The \
tropical Kleene-star fixed point and shortest paths in min-plus.\
\>", "Item",ExpressionUUID->"b1c2d3e4-003b-4000-8000-00000000003b"],

Cell["\<\
Pin, Tropical semirings, in Idempotency, J. Gunawardena (ed.), Cambridge \
University Press 1998. Foundational survey.\
\>", "Item",ExpressionUUID->"b1c2d3e4-003c-4000-8000-00000000003c"]
},
