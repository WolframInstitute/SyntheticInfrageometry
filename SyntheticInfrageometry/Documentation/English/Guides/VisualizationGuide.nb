Notebook[{
Cell["Visualization", "Title",ExpressionUUID->"911d6ae1-e5c0-48db-91f5-79f81d7406ee"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"e2a51d0b-8d13-40c6-9cbe-4d4b84dae930"],

Cell["\<\
Visualisation in SyntheticInfrageometry is organised around a single \
primitive \[LongDash] InfraSceneHighlight \[LongDash] that renders \
multi-realisation Infra* objects diffusely on a graph, with intensity scaling \
by overlap and colour-blending across objects. The InfraScene engine and the \
per-primitive viewers are thin shells on top.\
\>", "Text",ExpressionUUID->"fc987dfb-cb7f-4df7-bc3c-5813332f5bfa"],

Cell["Setup", "Section",ExpressionUUID->"15cdbfbc-7ff4-4e44-8767-8576802d9b32"],

