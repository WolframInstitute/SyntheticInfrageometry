Notebook[{
Cell["Tarski Geometry", "Title",ExpressionUUID->"64a7f3be-8eaa-4594-b58d-5fcd30fca1a4"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"0db24bee-545e-47af-bfe5-2a7215f50db7"],

Cell["\<\
The Tarski layer hosts the two primitives (betweenness B and equidistance ==) \
plus the eleven first-class axioms A1\[Dash]A11, each as its own predicate on \
a graph. The dashboard predicate TarskiAxiomQ collects all eleven; \
FindTarskiCounterexample produces witnesses of failure.\
\>", "Text",ExpressionUUID->"c33843ec-3daf-4598-be4e-cf745cb4fcee"],

Cell["Setup", "Section",ExpressionUUID->"09f2b225-cb0c-4d93-b78a-e3373facecf4"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"ef2b9f97-2d3f-43f0-8f54-f501bb86082e"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"7ddde3bc-f080-4928-9421-a3fea1aa1de9"],

Cell["Primitives", "Section",ExpressionUUID->"1b0ccb8d-44af-450e-bf6b-a18f1a4b87cf"],

Cell["BetweennessQ", "Item",ExpressionUUID->"8cff7c28-5b3b-4309-ae3c-980c6ec1d314"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"aab39044-e5f3-43bc-a27b-e90f1bb2e514"],

Cell["Memoized bundles", "Section",ExpressionUUID->"a33314bd-d091-412a-9b08-171d6ba2cb2e"],

Cell["TarskiStructure", "Item",ExpressionUUID->"3c600001-a50e-46e3-9828-5a2975c6b7e7"],

Cell["TarskiBetweennessTensor", "Item",ExpressionUUID->"1f69d8f6-9c53-4479-bd0d-749d7e69038d"],

Cell["TarskiEquidistanceClasses", "Item",ExpressionUUID->"901260bd-052f-477a-93aa-4187e4083e0a"],

Cell["The eleven axioms", "Section",ExpressionUUID->"d0d81aa1-3cbe-4612-98b8-8804fa06cedd"],

Cell["TarskiCongruenceReflexivityQ \[LongDash] A1: ab == ba", "Item",ExpressionUUID->"548650d4-402c-48b4-a6d2-b515738919fe"],

Cell["TarskiCongruenceTransitivityQ \[LongDash] A2: transitivity of ==", \
"Item",ExpressionUUID->"2071f89d-fe66-4532-9a75-fdd3ccde0eea"],

Cell["TarskiCongruenceIdentityQ \[LongDash] A3: ab == cc implies a == b", \
"Item",ExpressionUUID->"c61418d9-762e-484b-acbe-650a5a65165d"],

Cell["TarskiSegmentConstructionQ \[LongDash] A4: segment construction", "Item",ExpressionUUID->"e2df9c7c-b8af-4366-974e-c62c30261541"],

Cell["TarskiFiveSegmentsQ \[LongDash] A5: five segments", "Item",ExpressionUUID->"2d6adada-4991-4647-b11a-41edf3fe80de"],

Cell["TarskiBetweennessIdentityQ \[LongDash] A6: B(a, b, a) implies a == b", \
"Item",ExpressionUUID->"17553cb1-5e4a-4b0e-a451-05d0dc98c330"],

Cell["TarskiInnerPaschQ \[LongDash] A7: Inner Pasch", "Item",ExpressionUUID->"49de5d08-34b9-4a52-9ffe-09f72e70868e"],

Cell["TarskiLowerDimensionQ \[LongDash] A8: three non-collinear points \
exist", "Item",ExpressionUUID->"8866ba4b-3b65-4294-bd63-84eb0915b4e9"],

Cell["\<\
TarskiUpperDimensionQ \[LongDash] A9: three points equidistant from two \
distinct points are collinear\
\>", "Item",ExpressionUUID->"b1bc11e7-8a08-4f77-9bce-ae54af2d12ec"],

Cell["\<\
TarskiEuclidAxiomQ \[LongDash] A10: Euclid's parallel-axiom variant \
(currently a stub)\
\>", "Item",ExpressionUUID->"55395c24-3d84-4910-b79b-79431f92e77c"],

Cell["\<\
TarskiContinuityQ \[LongDash] A11: Dedekind continuity (always False on \
finite graphs)\
\>", "Item",ExpressionUUID->"ab0a0fa2-ddb3-4034-9f4f-1e668f1c4d70"],

Cell["Dashboard and counterexamples", "Section",ExpressionUUID->"aa9cc5d2-d02d-44dc-8e95-7c0260c9e2a0"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"d6ec48af-ccce-432a-b1f8-7df421451538"],

Cell["FindTarskiCounterexample", "Item",ExpressionUUID->"06d86aca-7090-4066-b39a-a2877b9a100e"],

Cell["Tarski-recipe variants on primitive Find-functions", "Section",ExpressionUUID->"188cb928-4c47-4f07-8bee-3806f2e07695"],

Cell["\<\
Tarski synthetic versions of standard Euclidean constructions are folded into \
Method -> \"Tarski\".\
\>", "Text",ExpressionUUID->"d95008e1-7b57-44fb-b823-a6a9fe50afd5"],

Cell["FindMidpoint with Method -> \"Tarski\"", "Item",ExpressionUUID->"1cfa8729-a146-44fd-9999-fd2d0051c360"],

Cell["The 5-vertex ExtendSegment form (A4 in finder shape)", "Item",ExpressionUUID->"34bcf39d-a323-4361-bd8e-c4174e94610d"],

Cell["FindReflection (synthetic from B and =)", "Item",ExpressionUUID->"1f476adc-591e-4de4-9477-4e96c936d6bf"],

Cell["Tutorial", "Section",ExpressionUUID->"0ab9991e-e464-45a7-9c80-a47e1f856ac9"],

Cell["See TarskiGeometryTutorial for runnable examples.", "Item",ExpressionUUID->"8a854cb0-6154-46de-b361-d889075c1386"],

Cell["References", "Section",ExpressionUUID->"760a595a-32b1-41f6-b7fb-b5acca46c222"],

Cell["\<\
Tarski and Givant, Tarski's System of Geometry, Bull. Symb. Logic 5(2), \
175-214, 1999, \
https://projecteuclid.org/journals/bulletin-of-symbolic-logic/volume-5/issue-\
2/Tarskis-system-of-geometry/bsl/1182353717\
\>", "Item",ExpressionUUID->"f58de625-add1-4f7a-ae44-19e4b9222004"],

Cell["\<\
Schwabhauser, Szmielew and Tarski, Metamathematische Methoden in der \
Geometrie, Springer 1983\
\>", "Item",ExpressionUUID->"a4c61f6a-1c45-4b68-bc14-ee4ff3860cc1"],

Cell["\<\
Beeson, Foundations of Constructive Geometry: Euclid Book I, Mem. AMS \
234(1102), 2014\
\>", "Item",ExpressionUUID->"b3374f12-e8f7-4adf-8f66-0776f5d9d521"],

Cell["Mulder, The Interval Function of a Graph (graph betweenness)", "Item",ExpressionUUID->"1c469b65-d620-43c6-a683-ff412101a2a2"]
},
