Notebook[{
Cell["Projective Geometry", "Title",ExpressionUUID->"6954daae-25b3-4479-a7cb-79b6127d7aa8"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"83d23b14-f0ff-42ce-b1de-421efa8074db"],

Cell["\<\
The projective layer treats incidence \[LongDash] points on lines, lines \
through points, directions at a centre \[LongDash] as first-class graph \
predicates. It exposes the Whitehead axiom triple W1\[Dash]W3 and a synthetic \
projective-plane test.\
\>", "Text",ExpressionUUID->"f14709b7-898b-4f5f-95f6-32cf6ddf8d70"],

Cell["Setup", "Section",ExpressionUUID->"dd71bb3e-2018-457f-bac0-b9208c04d519"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"150075b2-9749-4720-aa95-f3c4d88e53b5"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"5e1051ed-0f1b-416e-9499-a39117dc2246"],

Cell["Pointwise predicates", "Section",ExpressionUUID->"a271cd2d-2b04-4c53-a3ed-4c0c37fe90fb"],

Cell["SameDirectionQ", "Item",ExpressionUUID->"0725beca-8aeb-43f1-bd38-ad9276b6a8d6"],

