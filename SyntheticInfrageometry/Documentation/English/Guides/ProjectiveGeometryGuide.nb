Cell["ConcurrentQ", "Item",ExpressionUUID->"dc6ff3a3-fe0b-4917-b4ec-207e69670794"],

Cell["Uniqueness predicates", "Section",ExpressionUUID->"2567d73f-e945-4bff-b17b-83ce88546d0d"],

Cell["UniquePencilQ", "Item",ExpressionUUID->"9dfb97f8-6501-414e-8edb-3e7d647b4fd2"],

Cell["UniqueCollinearQ", "Item",ExpressionUUID->"83b6cd87-c50d-4469-aa27-11fd94d55613"],

Cell["UniqueConcurrentQ", "Item",ExpressionUUID->"e0c30020-b4e6-41de-9cee-6c1878d4bb37"],

Cell["Pencil readouts", "Section",ExpressionUUID->"ac39fdd7-497b-4b74-9b02-2ea4ecb43ffe"],

Cell["PencilDirections", "Item",ExpressionUUID->"c4b9e748-68f7-4884-9b32-3babb12c337f"],

Cell["PencilCardinality", "Item",ExpressionUUID->"7cd4be1b-9395-4189-8e25-12f4f25b6f40"],

Cell["LineCount", "Item",ExpressionUUID->"b05ecd81-f1c1-4993-84ea-de0bae83b18c"],

Cell["Whitehead axioms", "Section",ExpressionUUID->"b88ae61a-204f-41e9-89d0-3bb979f65a4d"],

Cell["WhiteheadW1Q \[LongDash] every line has at least three vertices", "Item",ExpressionUUID->"c49a45fa-46d7-47e3-8972-d77456598cc3"],

Cell["\<\
WhiteheadW2Q \[LongDash] through any two distinct vertices there is exactly \
one line\
\>", "Item",ExpressionUUID->"b245afc8-022f-48ab-8d8c-074cc0b97263"],

Cell["WhiteheadW3Q \[LongDash] intersection / Pasch-type axiom", "Item",ExpressionUUID->"cee3bbe9-4912-4a8b-a122-c8f2e5ceb56c"],

Cell["ProjectivePlaneGraphQ \[LongDash] W1 \[And] W2 \[And] W3 with \
non-degeneracy", "Item",ExpressionUUID->"1bd335b3-02ed-4939-9a8e-\
2f0e23acae86"],

Cell["Find-shaped primitives", "Section",ExpressionUUID->"15366d5b-a460-49f7-80e0-caca86943983"],

Cell["FindRay", "Item",ExpressionUUID->"f33b7e98-dc1e-4099-9cd0-d829e442c0c1"],

