Notebook[{
Cell["Metric Algebra", "Title",ExpressionUUID->"0ddac17f-1cc0-4201-8f91-242278658bf2"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"5b382065-75da-4fdb-b61f-4e4327f1e0b6"],

Cell["\<\
The metric-algebra layer is the algebraic substrate that turns the \
shortest-path metric into something the infra-observer can compute on \
\[LongDash] inner products from distances, angles from triples of vertices, \
and comparison-triangle / CAT(k) curvature bounds from triangles.\
\>", "Text",ExpressionUUID->"ee8f961b-0690-429f-b3c3-eca94d1f51d2"],

Cell["Setup", "Section",ExpressionUUID->"654fadc5-39bf-40e0-86ba-b501a555de65"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"ba41de4b-b165-42be-8c04-1413e86558be"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"f3a3bd90-87a0-4b11-bb7f-c624b0df55bd"],

Cell["Inner product and linear combinations", "Section",ExpressionUUID->"a92faf42-169c-4f00-a486-2c511650ec7c"],

Cell["InfraScalarProduct", "Item",ExpressionUUID->"f31989ff-dc20-4f57-9a5f-70bf5f5c3d05"],

Cell["FindInfraLinearCombination", "Item",ExpressionUUID->"09698839-877e-4868-91f8-eb8cef09eb5e"],

Cell["Angles", "Section",ExpressionUUID->"ae43a261-13d5-4604-8c93-25cde993b2c8"],

Cell["InfraAngle", "Item",ExpressionUUID->"07bcffad-9922-471c-99f1-138858ab2485"],

Cell["InfraSegmentLineAngle", "Item",ExpressionUUID->"04508e8f-6a9e-4483-accb-53219899ccfc"],

Cell["Comparison triangles and Alexandrov curvature", "Section",ExpressionUUID->"7c2e4c63-d6d1-44cb-a164-a3893555996d"],

Cell["ComparisonTriangle", "Item",ExpressionUUID->"36a30932-d836-4951-99ce-cac4e9ac745a"],

Cell["InfraComparisonTriangle", "Item",ExpressionUUID->"2783b102-827a-4154-8e3f-fab3da278f76"],

Cell["CATInequalityQ", "Item",ExpressionUUID->"dfe4c78b-bfe8-4496-a569-7e939c3a58cd"],

Cell["InfraCurvature", "Item",ExpressionUUID->"7eb19eb6-dac4-4f5c-ad01-b5ef65f3efbe"],

Cell["Tutorial", "Section",ExpressionUUID->"cf8771ad-85ad-430a-b0da-25b295c60d97"],

Cell["See MetricAlgebraTutorial for runnable examples.", "Item",ExpressionUUID->"4f0587a7-540c-464f-af6e-02c6096999c2"],

Cell["References", "Section",ExpressionUUID->"971a7d5d-ab7c-41d0-8162-e9ae63f44687"],

Cell["\<\
Schoenberg, Remarks to Maurice Frechet's article \"Sur la definition \
axiomatique d'une classe d'espace distancies vectoriellement applicable sur \
l'espace de Hilbert\", Ann. Math. 36, 724-732, 1935\
\>", "Item",ExpressionUUID->"0277c8c6-1cc6-4d60-84b5-d8be63a10adc"],

Cell["\<\
Burago, Burago and Ivanov, A Course in Metric Geometry, AMS GSM 33, 2001 \
(CAT(k) and Alexandrov geometry)\
\>", "Item",ExpressionUUID->"fcfeef4a-1dfb-4edb-a20e-c41be7b52c7d"],

Cell["\<\
Alexandrov, A theorem on triangles in a metric space and some applications, \
Trudy Mat. Inst. Steklov. 38, 5-23, 1951\
\>", "Item",ExpressionUUID->"9a361f15-0108-414c-858e-f78afa08e150"],

Cell["\<\
Bridson and Haefliger, Metric Spaces of Non-Positive Curvature, Springer 1999\
\
\>", "Item",ExpressionUUID->"1d7925a0-b53d-4c65-ac01-e7010870a60a"]
},
