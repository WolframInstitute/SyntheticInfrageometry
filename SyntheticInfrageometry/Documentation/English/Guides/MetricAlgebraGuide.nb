Notebook[{
Cell["Metric Algebra", "Title",ExpressionUUID->"23e6cb30-695e-43f9-abfd-125fc19867e7"],

Cell["\<\
The metric-algebra layer is the quantitative substrate that sits under the \
synthetic Euclidean and Tarski layers. It exposes the master interval \
function I(u, v), the geodesic-multiplicity matrix, and the metric median -- \
the algebraic objects that the higher layers query through one-equation \
conditions on the distance matrix D and the cost-adjacency matrix A.\
\>", "Text",ExpressionUUID->"78440072-13e8-4c53-a889-d0be21c0e34b"],

Cell["\<\
The reading: every higher-level primitive (BetweennessQ, FindMidpoint, \
FindGeodesicConvexHull, ...) reduces to a one-line query on the pair (A, D).\
\>", "Text",ExpressionUUID->"c98441eb-5a14-4302-bac8-0581d1d5de11"],

Cell["Setup", "Section",ExpressionUUID->"154e816b-842b-44b3-aa30-841e4ca1dd79"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"06575712-432d-4eec-b570-a8fed9ed29c5"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"318aa6a6-ca55-4106-ae48-b9e4a1100ddb"],

Cell["Master operation", "Section",ExpressionUUID->"c0cf877c-3880-4c98-95d7-38ca5d709d32"],

Cell["\<\
MetricInterval -- the geodesic interval I(u, v) = { w : d(u, w) + d(w, v) = \
d(u, v) }, i.e. the union of all geodesics from u to v. Every other primitive \
in this layer (and the Tarski betweenness predicate) reduces to it.\
\>", "Item",ExpressionUUID->"863b2e73-1793-461c-ada9-4da656bc9b31"],

Cell["Geodesic counts and multiplicities", "Section",ExpressionUUID->"05951fcf-2024-4ecd-ac10-5c36d81fd74e"],

Cell["\<\
GeodesicMultiplicity -- the number of geodesics between u and v, computed in \
polynomial time as (A^d)[u, v] where d = d(u, v). Walks of length d(u, v) \
from u to v are automatically simple geodesics.\
\>", "Item",ExpressionUUID->"920dfbee-2cd9-4405-9cf4-31131ef8c3a4"],

Cell["\<\
GeodesicMultiplicityMatrix -- the pair (D, M): D is the graph distance \
matrix, M[i, j] counts geodesics from i to j. The multiplicity counterpart of \
the metric.\
\>", "Item",ExpressionUUID->"a92783ac-b39a-4b5d-8c16-f8cc2174e659"],

Cell["Metric centroids", "Section",ExpressionUUID->"9cb676f9-798c-4103-8fa7-5208d083bbc7"],

Cell["\<\
MedianVertices -- the metric medians of a vertex set vs: argmin over w of the \
total distance Sum d(w, x) for x in vs. A graph is a median graph iff every \
triple has a unique median.\
\>", "Item",ExpressionUUID->"003e423b-1f61-4638-9fa8-404700b57822"],

Cell["Geodesic convexity", "Section",ExpressionUUID->"05df8f0b-e548-4ba2-b8d2-ade04f6bdcce"],

Cell["\<\
FindGeodesicConvexHull -- the smallest geodesically convex superset of a \
vertex set.\
\>", "Item",ExpressionUUID->"78c1aeb3-ee63-49cc-9f27-c311e9275e5a"],

Cell["\<\
GeodesicallyConvexQ -- test whether a vertex set is closed under FindSegment.\
\
\>", "Item",ExpressionUUID->"1b697fa1-8d54-4917-ad41-868dcd97f9a9"],

Cell["Examples", "Section",ExpressionUUID->"be94339e-5b13-42eb-b6d2-e89cbe88edec"],

Cell[BoxData[{Cell["\<\
The geodesic interval between opposite corners of a 3 x 3 grid.\
\>", "CodeText",ExpressionUUID->
  "c9c5db87-2780-492b-b462-1f535820a33c"], "\n", \
Cell["MetricInterval[GridGraph[{3, 3}], 1, 9]", "Input",ExpressionUUID->
  "c15f4f46-fc2b-43b9-88de-be638aa55010"]}], "Input",ExpressionUUID->\
"046098b9-052a-4d7f-a74d-871a6f4428e4"],

Cell[BoxData[{Cell["\<\
Number of geodesics between two corners of a 4 x 4 grid -- the central \
binomial coefficient C(6, 3) = 20.\
\>", "CodeText",ExpressionUUID->
  "3836ae35-6fec-4bcb-85d0-2e8f474d2ad4"], "\n", \
Cell["GeodesicMultiplicity[GridGraph[{4, 4}], 1, 16]", "Input",ExpressionUUID->
  "1405b9eb-c147-49b0-be09-6bb022eee6e3"]}], "Input",ExpressionUUID->\
"7151b558-abf3-4d47-88de-3a563f54c9c8"],

Cell[BoxData[{Cell["Distance and multiplicity matrices of the cycle C_5.", 
  "CodeText",ExpressionUUID->
  "572f0647-5ed3-463a-be1f-43676fe6143a"], "\n", \
Cell["GeodesicMultiplicityMatrix[CycleGraph[5]]", "Input",ExpressionUUID->
  "cd3bbc7c-c80f-444e-9b53-42d1ab25b4d2"]}], "Input",ExpressionUUID->\
"b9289bb8-a700-4840-8bab-368c9f176f7e"],

Cell[BoxData[{Cell["Median vertices of a triple in a complete bipartite \
graph.", "CodeText",ExpressionUUID->
  "ac2ac967-1a5c-4b7e-ae29-c9ee768277c7"], "\n", \
Cell["MedianVertices[CompleteGraph[{2, 3}], {1, 2, 3}]", "Input",
  ExpressionUUID->"895944f6-574e-4711-af51-815de5bb89ca"]}], "Input",Expressio\
nUUID->"43b58e5a-8f38-43c4-8d7b-b35efdaac051"],

Cell[BoxData[{Cell["Geodesic convex hull of a vertex set on a 4 x 4 grid.", 
  "CodeText",ExpressionUUID->
  "d747ab09-5ca1-4520-add2-50cce012e7ff"], "\n", \
Cell["FindGeodesicConvexHull[GridGraph[{4, 4}], {1, 4, 16}]", "Input",
  ExpressionUUID->"09374009-c3a0-481f-81ee-ac657e988083"]}], "Input",Expressio\
nUUID->"2fa4a40c-d968-4623-8fa5-8f3cd868ca47"],

Cell["See also", "Section",ExpressionUUID->"0c9c0ce6-9a5b-4934-b500-8e7a164743f7"],

Cell["TarskiGeometryGuide", "Item",ExpressionUUID->"ed2a02d0-1b02-4d76-a07a-a62017a2bc4a"],

Cell["EuclideanGeometryGuide", "Item",ExpressionUUID->"bad888e2-7adb-4c8f-90ae-8e1b77936024"],

Cell["PathSpaceGuide", "Item",ExpressionUUID->"5df1fa91-49f4-49ee-a516-481094a73759"],

Cell["TropicalConvexityGuide", "Item",ExpressionUUID->"32854867-8294-4121-95e2-4d8fe665f2dc"],

Cell["BetweennessQ", "Item",ExpressionUUID->"9f8c1d05-5d9c-440f-ba3d-90dd745dd066"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"f61da7b7-1435-4dec-8a05-a51e4d773c79"],

Cell["References", "Section",ExpressionUUID->"6c908f04-cf33-40e7-a708-3c4b90964508"],

Cell["\<\
Linial, Geodesic Geometry on Graphs, \
https://www.cs.huji.ac.il/~nati/PAPERS/ge_ge_gr.pdf\
\>", "Item",ExpressionUUID->"76717c24-0214-465e-9bdb-9b23b90ee549"],

Cell["\<\
Mulder, The Interval Function of a Graph, Mathematical Centre Tracts 132, \
Amsterdam 1980\
\>", "Item",ExpressionUUID->"631fe78b-e795-4e84-ae5d-1e34e4062126"],

Cell["\<\
Bandelt and Mulder, Distance-hereditary graphs, J. Combin. Theory Ser. B 41, \
1986\
\>", "Item",ExpressionUUID->"e1afe31d-9b0a-4410-ad20-42bbca13327f"],

Cell["\<\
Deza and Laurent, Geometry of Cuts and Metrics, Springer Algorithms and \
Combinatorics 15, 1997\
\>", "Item",ExpressionUUID->"efc9109d-1281-44a4-bd02-ceef60fe0fed"],

Cell["Buckley and Harary, Distance in Graphs, Addison-Wesley 1990", "Item",ExpressionUUID->"ec60d26f-c134-450d-a54e-93d084dd2ad2"],

Cell["\<\
Hammack, Imrich, Klavzar, Handbook of Product Graphs, CRC Press 2011\
\>", "Item",ExpressionUUID->"87524443-2b83-4754-a1d5-ccd4dbcbbf66"]
},
