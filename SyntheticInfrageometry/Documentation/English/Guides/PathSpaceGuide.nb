Notebook[{
Cell["PathSpace Layer", "Title",ExpressionUUID->"dc354bb9-8b31-4541-b217-abedd8e8a18c"],

Cell["\<\
PathSpace selectors are post-filters: enumerate full multiplicity first, then \
keep central, peripheral, embedding-closest, shortest, or longest \
representatives.\
\>", "Text",ExpressionUUID->"25710b2e-8581-4aec-952f-c6cfe0f8eabe"],

Cell["Path selectors", "Section",ExpressionUUID->"b4c09a93-fc3e-4007-9c19-43cb2dbf5899"],

Cell["CentralPaths", "Item",ExpressionUUID->"5244962c-cea6-47f9-98d2-e97d6f6bfd78"],

Cell["PeripheralPaths", "Item",ExpressionUUID->"9a868631-c0a7-47ad-b6ca-4fae49c15ba2"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"5605d0d8-702b-4c88-b5aa-9bbe882c9d55"],

Cell["Cycle selectors", "Section",ExpressionUUID->"5e8cc301-7b52-475a-be78-871700ee47c5"],

Cell["CentralCycles", "Item",ExpressionUUID->"79615348-1e0b-4b0e-8560-33727a37b10d"],

Cell["PeripheralCycles", "Item",ExpressionUUID->"b3bcc0fb-fc61-4bc7-8d9b-bea451bebea0"],

Cell["EmbeddingClosestCycles", "Item",ExpressionUUID->"aefdf5df-b7a7-435f-80ea-9a5b13bea637"],

Cell["ShortestCircumferenceCycles", "Item",ExpressionUUID->"231dbc05-6c47-4b10-b40d-ddc73ce26d92"],

Cell["LongestCircumferenceCycles", "Item",ExpressionUUID->"81d120eb-1a00-416d-975e-752459beff23"],

Cell["Typical pipeline", "Section",ExpressionUUID->"b5a313ab-8821-47ca-b4d7-5a3503dbed04"],

Cell["Enumerate first, then filter.", "CodeText",ExpressionUUID->"f19d932d-7945-4b67-a1bf-bb37a88d6faa"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"EmbeddingClosestPaths", "[", 
     RowBox[{"g", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "16"}], "}"}]}], "]"}], "[", 
    RowBox[{
     RowBox[{"CentralPaths", "[", "g", "]"}], "[", 
     RowBox[{"FindSegment", "[", 
      RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "]"}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"72e1cbb0-f9c3-4419-b142-8b9ebc50f989"],

Cell["Tutorial", "Section",ExpressionUUID->"f87a9767-6390-4b6d-8c92-3c5fce1f8962"],

Cell["\<\
See PathSpaceTutorial for end-to-end segment and cycle examples.\
\>", "Item",ExpressionUUID->"2eada757-e214-441a-be4b-2783a564a636"],

Cell["References", "Section",ExpressionUUID->"ebb5a041-905d-497a-ab54-5af721770bb2"],

Cell["\<\
Linial, Geodesic Geometry on Graphs, \
https://www.cs.huji.ac.il/~nati/PAPERS/ge_ge_gr.pdf\
\>", "Item",ExpressionUUID->"486a26ae-9b42-42a4-a4cc-7dc7527162ca"],

Cell["\<\
Mulder, The Interval Function of a Graph, Mathematical Centre Tracts 132, \
Amsterdam 1980\
\>", "Item",ExpressionUUID->"967c03b6-47a7-46de-b338-da42904f6055"],

Cell["\<\
Alt and Godau, Computing the Frechet Distance Between Two Polygonal Curves, \
International Journal of Computational Geometry and Applications 5, 75-91, \
1995\
\>", "Item",ExpressionUUID->"9ff93b50-8375-4fae-8e2e-05107017dedd"],

Cell["\<\
Buchin, Buchin, van Kreveld and Luo, Finding Long and Similar Parts of \
Trajectories, Computational Geometry 44, 465-476, 2011\
\>", "Item",ExpressionUUID->"5601dfba-0b8e-47a0-8c26-1c354d7eea4a"],

Cell["\<\
Hausdorff, Grundzuege der Mengenlehre, Veit 1914 (chapter on the Hausdorff \
metric), https://archive.org/details/grundzgedermen00hausuoft\
\>", "Item",ExpressionUUID->"81e18395-9991-448f-be7d-a63741382b4d"]
