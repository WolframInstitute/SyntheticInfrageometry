Notebook[{
Cell["Path Space", "Title",ExpressionUUID->"a35bded2-915b-4c27-abc8-457b38fae069"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"7c0cc5c7-627b-43bd-a60a-1fb38f590064"],

Cell["\<\
The path-space layer treats the bundle of geodesics (or cycles) between \
vertices as a finite metric space in its own right \[LongDash] with \
Hausdorff, Frechet, and mean-Frechet metrics on paths \[LongDash] and exposes \
FindPoint-shaped selectors over that space.\
\>", "Text",ExpressionUUID->"a49b041b-4b70-42f4-8a93-b2d3b5458f80"],

Cell["Setup", "Section",ExpressionUUID->"8a92ed7f-5661-4df7-9104-393babed461d"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"92311498-da15-4fb0-8d9e-14fd38dc419f"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"d114656b-7080-42fa-aa73-43e410670b14"],

Cell["Selectors", "Section",ExpressionUUID->"d805c12f-8c2f-455c-ab58-8d6dd8efd369"],

Cell["\<\
FindPoint-shaped on path-space; calling triple n_Integer | UpTo[n] | All.\
\>", "Text",ExpressionUUID->"9382fbd2-b667-42cf-ac59-3307b6f8c4d8"],

Cell["SelectPath", "Item",ExpressionUUID->"982ba3dd-3d68-4c98-83e7-c0ea51a84e1e"],

Cell["SelectCycle", "Item",ExpressionUUID->"63d00637-dee7-46d1-b275-f697d3e41c79"],

Cell["Embedding-closest filters", "Section",ExpressionUUID->"99b7ac7d-5057-49af-a5fa-4626c6cd982c"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"bebcebd2-7cd0-47bc-b756-97fee94f3ea9"],

Cell["EmbeddingClosestCycles", "Item",ExpressionUUID->"762d1468-a403-46f3-9a2e-a9099fe8ca53"],

Cell["Geodesic-graph machinery", "Section",ExpressionUUID->"9f31f337-9a68-41fc-b574-66ef4b3ebbb6"],

Cell["GeodesicGraph", "Item",ExpressionUUID->"1e2512af-db89-47fe-b68d-b462c0fa4d45"],

Cell["GeodesicSubgraph", "Item",ExpressionUUID->"828e1d9e-3bf8-4f09-8b25-ff8b44e47973"],

Cell["PathSubgraph", "Item",ExpressionUUID->"dc522690-f930-4907-b984-c130c29f6ad4"],

Cell["Metric-geometry building blocks", "Section",ExpressionUUID->"7f6cca8e-1ef3-4533-8152-34b03ea4d10b"],

Cell["MetricInterval", "Item",ExpressionUUID->"763893c6-36bc-4b50-a5c8-ed08614f6df0"],

Cell["GeodesicMultiplicity", "Item",ExpressionUUID->"ee91536a-6b4c-4583-bee6-c265b33026ad"],

Cell["GeodesicMultiplicityMatrix", "Item",ExpressionUUID->"907dd299-95de-445a-8b2d-ca13077b0464"],

Cell["MedianVertices", "Item",ExpressionUUID->"afae3338-b860-499f-8f8d-9af7471ac2db"],

Cell["Path-space \"From\" values", "Section",ExpressionUUID->"fe297f91-5af3-47d2-9605-e87b27200b5a"],

Cell["All (default) \[LongDash] no anchor", "Item",ExpressionUUID->"554807a4-802e-4206-9960-7d9c68ba91c8"],

Cell["\<\
\"Center\" / \"Periphery\" \[LongDash] central / peripheral elements in \
path-space\
\>", "Item",ExpressionUUID->"6b47f11c-9d34-4bab-989b-8d56b05ecbfe"],

Cell["\"MostVisited\" \[LongDash] paths through the most-shared vertex", \
"Item",ExpressionUUID->"c644ee8e-27fa-417b-8450-7fb8b6092bdf"],

Cell["anchor -> spec \[LongDash] pull toward a vertex / InfraPoint", "Item",ExpressionUUID->"f343e491-091a-4469-971b-05a19f2321c5"],

Cell["InfraSegment[{...}] -> spec \[LongDash] pull toward a known segment", \
"Item",ExpressionUUID->"6e14ae4f-49f7-4780-979b-43b6b6321172"],

Cell["\<\
(SelectCycle only) \"ShortestCircumference\" / \"LongestCircumference\"\
\>", "Item",ExpressionUUID->"86573fd7-0d84-452e-8b02-361b67b259e5"],

Cell["Path-space metrics", "Section",ExpressionUUID->"ae8e3b8c-1fed-4fa9-b1d9-1b980003446d"],

Cell["\"Hausdorff\" (default) \[LongDash] symmetric set distance", "Item",ExpressionUUID->"b7cf2d78-dc8d-4009-8fbe-19cc255d7bae"],

Cell["\"Frechet\" \[LongDash] order-sensitive walk-coupling distance", "Item",ExpressionUUID->"091606a8-360d-40d7-8225-24914e3e0a21"],

Cell["\"MeanFrechet\" \[LongDash] averaged Frechet", "Item",ExpressionUUID->"c03e8841-536e-456e-a029-b2d26abde0f1"],

Cell["Tutorial", "Section",ExpressionUUID->"a545d28d-3f2a-45f7-afdd-e497bb5ffb61"],

Cell["See PathSpaceTutorial for runnable examples.", "Item",ExpressionUUID->"30869aa1-fe19-47fd-933f-cc0ea3bd0a2f"],

Cell["References", "Section",ExpressionUUID->"15ceca68-78f4-450e-a0b2-a2db51183924"],

Cell["\<\
Mulder, The Interval Function of a Graph, Mathematical Centre Tracts 132, \
Amsterdam 1980\
\>", "Item",ExpressionUUID->"0992eef4-8888-4676-bab5-3a079fb55cc4"],

Cell["\<\
Bandelt and Mulder, Distance-Hereditary Graphs, J. Combin. Theory Ser. B 41, \
182-208, 1986\
\>", "Item",ExpressionUUID->"6072648d-a7eb-43cd-9cef-ad5f3a9eb7f8"],

Cell["\<\
Klavzar and Mulder, Median graphs: characterizations, location theory and \
related structures, JCMCC 30, 103-127, 1999\
\>", "Item",ExpressionUUID->"8cde7dc9-b875-49be-ad13-ee29748c8719"],

Cell["\<\
Bridson and Haefliger, Metric Spaces of Non-Positive Curvature, Springer 1999 \
(Hausdorff / Frechet metrics on path space)\
\>", "Item",ExpressionUUID->"61012a6a-b204-405c-8508-10a5986531e9"]
},
