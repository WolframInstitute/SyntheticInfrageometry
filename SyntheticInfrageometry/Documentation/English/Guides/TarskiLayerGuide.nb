Notebook[{
Cell["Tarski Layer", "Title",ExpressionUUID->"d1c03c6c-4d41-4cee-8d1e-d6499860debb"],

Cell["\<\
The Tarski layer exposes betweenness and equidistance as first-class graph \
relations, bundles them into a memoized hypermatrix substrate, and evaluates \
the eleven first-order Tarski axioms directly on graphs.\
\>", "Text",ExpressionUUID->"49b23104-b517-4d7c-8241-2478258ac17f"],

