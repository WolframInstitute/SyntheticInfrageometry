Notebook[{
Cell["SyntheticInfrageometry", "Title",ExpressionUUID->"f30a21f0-1b9d-4398-bb6e-66fd8345718d"],

Cell["\<\
SyntheticInfrageometry organizes Euclidean, path-space, Tarski, projective, \
tropical, and scene-building layers around multivalued constructions on \
graphs. This guide points to the main entry points for the newly documented \
Euclidean, PathSpace, and Tarski surfaces.\
\>", "Text",ExpressionUUID->"07813557-69a1-4e1d-a265-f73f690f6e31"],

Cell["Setup", "Section",ExpressionUUID->"d906f957-5508-4371-a34c-1fe0e0542bcb"],

