Notebook[{
Cell["SyntheticInfrageometry", "Title",ExpressionUUID->"c83a1b14-bdb2-41bb-99ca-6c968a5d386c"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"e2f20821-8378-4654-bbf8-3f9c4760feba"],

Cell["\<\
SyntheticInfrageometry organises Euclidean (metric), path-space (selectors), \
coordinatisation, Tarski (betweenness + equidistance), projective \
(incidence), tropical convexity (graph-only), Alexandrov / \
comparison-triangle, metric algebra, and visualisation layers around \
multivalued constructions on graphs and hypergraphs. Every direction has a \
Guide (categorical overview) and a Tutorial (worked walkthrough).\
\>", "Text",ExpressionUUID->"28058d83-00cb-4367-ab90-7fae666a3a24"],

Cell["Setup", "Section",ExpressionUUID->"4bea9d52-7fcf-4700-98f0-9d5fe787d1c6"],

