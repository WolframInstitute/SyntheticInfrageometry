(* Beginning of Notebook Content *)
Notebook[{
Cell["Tropical Convexity (graph-translated)", "Title",ExpressionUUID->"b30d141e-778e-40fb-bc15-f3963dd8081a"],

Cell["\<\
The graph translation of tropical convexity in (R^n)_min: tropical segments, \
geodesically convex sets, the convex hull. This is sense 2 of \"tropical\" in \
the literature -- the convex-figure side of the picture (Maclagan and \
Sturmfels, Develin and Sturmfels). The companion sense 1 -- the min-plus \
arithmetic on scalars and matrices -- now lives in the Code/ folder of the \
dev repo as TropicalOperations.wl and is no longer part of the public paclet.\
\
\>", "Text",ExpressionUUID->"8e6783a4-2402-43d8-ad94-9fbc729aeaea"],

Cell["\<\
The reading: under the shortest-path metric, a tropical segment between two \
graph vertices is the vertex set of any geodesic between them; a geodesically \
convex set is one closed under FindSegment; the geodesic convex hull is the \
smallest such superset.\
\>", "Text",ExpressionUUID->"80ea2ab5-e634-4f21-bfc2-9f802a508f8e"],

Cell["Setup", "Section",ExpressionUUID->"ce043b2e-a03c-4357-975d-6027eea830cb"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"e31c7645-44ab-4d8d-9342-b1ea21058532"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"8ec7cea0-a384-4815-8ca3-5ea17ca9d7bc"],

Cell["Postulates", "Section",ExpressionUUID->"534205ad-c048-4ec4-aa79-11e07426e508"],

Cell["\<\
FindSegment -- enumerate geodesics from u to v (the tropical segment \
realisations on the graph).\
\>", "Item",ExpressionUUID->"39815ba6-b587-4d33-b11c-f462f3985ca2"],

Cell["\<\
FindGeodesicConvexHull -- the smallest geodesically convex superset of a \
vertex set.\
\>", "Item",ExpressionUUID->"0f3c5907-e22b-4ee0-a057-b6e7073ee5f9"],

Cell["Predicates", "Section",ExpressionUUID->"7adeeb1f-367b-4d5a-afc6-0573a538d640"],

Cell["\<\
GeodesicallyConvexQ -- test whether a vertex set is closed under FindSegment.\
\
\>", "Item",ExpressionUUID->"04f9e3d2-262a-4d68-b5bb-3f9da666441e"],

Cell["Examples", "Section",ExpressionUUID->"ce255393-bc6e-41d9-af62-42a453e66895"],

Cell[BoxData[{Cell["All tropical segments between two corners of a 4 x 4 \
grid.", "CodeText",ExpressionUUID->
  "83bc2a10-cb48-4769-92e8-aa96b3817ce4"], "\n", \
Cell["FindSegment[GridGraph[{4, 4}], 1, 16, All]", "Input",ExpressionUUID->
  "5f3ad771-3ced-4c90-9bd6-17013fa35083"]}], "Input",ExpressionUUID->\
"b0a8ed89-ea9a-4368-81e0-71657fba2f2d"],

Cell[BoxData[{Cell["Geodesic convex hull of three vertices on a grid.", 
  "CodeText",ExpressionUUID->
  "b581fbae-ba22-4665-8e21-e23cdc6b5d98"], "\n", \
Cell["FindGeodesicConvexHull[GridGraph[{4, 4}], {1, 4, 16}]", "Input",
  ExpressionUUID->"f1b7bc86-4bd8-4494-b3e4-97fc53e87fdd"]}], "Input",Expressio\
nUUID->"0369395d-d0fa-4d62-b5f6-d3adabb16661"],

Cell[BoxData[{Cell["Test whether a vertex set is geodesically convex.", 
  "CodeText",ExpressionUUID->
  "92c21dd8-0528-499b-bbf2-ced66195b929"], "\n", \
Cell["GeodesicallyConvexQ[GridGraph[{4, 4}], {1, 2, 3, 4}]", "Input",
  ExpressionUUID->"d66bff34-f371-4240-a17d-bb280ccfefc7"]}], "Input",Expressio\
nUUID->"1b76aa9a-6aca-482e-b29d-4a6614921727"],

Cell["See also", "Section",ExpressionUUID->"3539223f-5f71-497d-979c-98d385db10a8"],

Cell["EuclideanGeometryGuide", "Item",ExpressionUUID->"66e5ac6b-bdfd-4e1a-9347-9a982444786e"],

Cell["MetricAlgebraGuide", "Item",ExpressionUUID->"63931547-fbb6-4f95-be12-479031c4bbd5"],

Cell["PathSpaceGuide", "Item",ExpressionUUID->"9d968c1f-79e4-47e0-8362-7ef9dee781de"],

Cell["FindSegment", "Item",ExpressionUUID->"b7998565-21d1-4d9d-b8a2-cacf63c23d99"],

Cell["FindGeodesicConvexHull", "Item",ExpressionUUID->"f7404fcc-b204-4602-9fff-2db454303ea8"],

Cell["GeodesicallyConvexQ", "Item",ExpressionUUID->"4b266f87-94d4-408e-8f74-4cb8065f8be2"],

Cell["MetricInterval", "Item",ExpressionUUID->"245983da-0b04-491a-972a-d789f6a6954d"],

Cell["References", "Section",ExpressionUUID->"51793320-d731-4eb8-a410-b3b765dde392"],

Cell["\<\
Maclagan and Sturmfels, Introduction to Tropical Geometry, AMS GSM 161, 2015, \
https://janos.cs.technion.ac.il/COURSES/238900-13/Tropical/MaclaganSturmfels.\
pdf\
\>", "Item",ExpressionUUID->"ec23b879-8e86-4a09-82ad-5b7a9e6b668c"],

Cell["\<\
Develin and Sturmfels, Tropical Convexity, Documenta Math. 9, 1-27, 2004, \
https://arxiv.org/abs/math/0308254\
\>", "Item",ExpressionUUID->"228ce266-f899-4880-8272-96ae38ce1a09"],

Cell["\<\
van der Pol, A Tropical Approach to the Median, in Combinatorial Convexity \
(Bjorner, Linial, eds.), 2009 (median-graph background).\
\>", "Item",ExpressionUUID->"781ce2d3-c81b-4176-908d-e99196fdc726"],

Cell["\<\
Mulder, The Interval Function of a Graph, Mathematical Centre Tracts 132, \
Amsterdam 1980 (foundational treatment of geodesic convexity on graphs).\
\>", "Item",ExpressionUUID->"4feb3fc7-9ace-4172-85aa-926f0d3f8fb3"]
},
