Notebook[{
Cell["TarskiUpperDimensionQ", "Title",ExpressionUUID->"78e69f89-0c41-4748-a6c9-9ae24ca1f9d1"],

Cell["\<\
TarskiUpperDimensionQ[graph] tests Tarski axiom A9: three points equidistant \
from two distinct points are collinear. False on graphs of effective \
dimension >= 3 (hypercubes, 3D grids).\
\>", "Text",ExpressionUUID->"c1ffe9c6-29ae-47f7-b038-99921ff1c23a"],

Cell["Setup", "Section",ExpressionUUID->"2cecd68a-ab86-4d2c-8d7f-6a80edb17345"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"831ac10d-ce0a-43bc-9f9f-b329016be22e"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"4795e171-83f3-4d3e-969d-ddd98303fd16"],

Cell["Usage", "Section",ExpressionUUID->"82a2f7a0-72fd-464a-9a8c-0322893221ce"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"c8205022-cfbc-42cc-9370-2ea7eb79f869"],

Cell[BoxData[
 RowBox[{"TarskiUpperDimensionQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"1e6a9274-3edb-4315-b4ce-9bd46ea38ddd"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"7935ba26-393b-4e0f-9b5d-2e0484105a78"],

Cell[BoxData[
 RowBox[{"TarskiUpperDimensionQ", "[", 
  RowBox[{"tarskiSecondExample", "[", "\"\<TarskiUpperDimensionQ\>\"", "]"}], 
  "]"}]], "Input",ExpressionUUID->"04873fb9-0539-4e6f-8008-7ae54eac8fec"],

Cell["Examples", "Section",ExpressionUUID->"61737e7a-c75e-4204-a61b-3a5ae0dd6e8d"],

Cell["Compare a grid with the 3D hypercube.", "CodeText",ExpressionUUID->"087e058d-8052-4065-bf31-bf28f079c8c3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"TarskiUpperDimensionQ", "[", 
    RowBox[{"GridGraph", "[", 
     RowBox[{"{", 
      RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}], ",", 
   RowBox[{"TarskiUpperDimensionQ", "[", 
    RowBox[{"HypercubeGraph", "[", "3", "]"}], "]"}]}], "}"}]], "Input",Expres\
sionUUID->"caf01f7e-6e0f-4182-bb09-a4bba12937bf"],

Cell["Read the dashboard entry.", "CodeText",ExpressionUUID->"8f2b50fa-1e29-4348-87da-b2db7ac39b0d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TarskiAxiomQ", "[", 
   RowBox[{"HypercubeGraph", "[", "3", "]"}], "]"}], 
  "[", "\"\<UpperDimension\>\"", "]"}]], "Input",ExpressionUUID->"e5c9f638-\
4c72-4852-becb-6f20a5afb613"],

Cell["See also", "Section",ExpressionUUID->"76a7d1ee-79d9-44ce-95ff-3ec19dd3e14e"],

Cell["BetweennessQ", "Item",ExpressionUUID->"f556ab82-1c71-4e29-b133-3d31dde1a98c"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"e0dfc34b-8554-4a76-bb1b-5983ef84519e"],

Cell["TarskiStructure", "Item",ExpressionUUID->"51c5e711-5002-413b-b251-4a5edc845fd5"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"ac228516-7604-45d8-a79f-863c37246b12"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"340525b0-8d68-44fd-9cdf-a0ba57f2a30e"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"116a6e88-a070-450f-9cf8-7288bbc297d8"],

Cell["MetricInterval", "Item",ExpressionUUID->"ac3ae836-555a-4708-9395-cd3506a14dd6"]
},
