Notebook[{
Cell["TarskiUpperDimensionQ", "Title",ExpressionUUID->"03b21b79-17b5-439b-b221-9dc4bb010c52"],

Cell["\<\
TarskiUpperDimensionQ[graph] tests Tarski axiom A9: three points equidistant \
from two distinct points are collinear. False on graphs of effective \
dimension >= 3 (hypercubes, 3D grids).\
\>", "Text",ExpressionUUID->"f5fc5808-be23-40ec-8a14-cd1fef1c292b"],

Cell["Setup", "Section",ExpressionUUID->"ec367237-91d1-4713-b07d-2a92d6600149"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"c59d7a35-4aab-4269-9f1c-4739ebfa1333"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"43681917-9d83-4a50-aafe-1ea9fe0c07b8"],

Cell["Usage", "Section",ExpressionUUID->"7399bce9-0716-4c3e-9930-eac6ebf7e10f"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"84c564c2-c08a-4713-9001-5b4c57de2d61"],

Cell[BoxData[
 RowBox[{"TarskiUpperDimensionQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"f1383c59-659c-4c83-95a3-d50a762eee72"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"416ef28e-0082-4f1d-9827-e41aa54c85b4"],

Cell[BoxData[
 RowBox[{"TarskiUpperDimensionQ", "[", 
  RowBox[{"Graph", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6", ",", "7", ",", 
      "8"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"Null", ",", 
      RowBox[{"SparseArray", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{"8", ",", "8"}], "}"}], ",", "0", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "0", ",", "3", ",", "6", ",", "9", ",", "12", ",", "15", ",", 
              "18", ",", "21", ",", "24"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "5", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "7", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "8", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "7", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "5", "}"}], ",", 
              RowBox[{"{", "8", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "5", "}"}], ",", 
              RowBox[{"{", "8", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "7", "}"}]}], "}"}]}], "}"}], ",", "Pattern"}], 
         "}"}]}], "]"}]}], "}"}]}], "]"}], "]"}]], "Input",ExpressionUUID->\
"b87bcf0c-f1d2-4c91-9d40-4c8bea4d9458"],

Cell["Examples", "Section",ExpressionUUID->"743cc086-9a45-41b8-b548-9c8af63d4288"],

Cell["Compare a grid with the 3D hypercube.", "CodeText",ExpressionUUID->"f0c119d6-8fce-4d10-b061-fcd4c180720d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"TarskiUpperDimensionQ", "[", 
    RowBox[{"GridGraph", "[", 
     RowBox[{"{", 
      RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}], ",", 
   RowBox[{"TarskiUpperDimensionQ", "[", 
    RowBox[{"HypercubeGraph", "[", "3", "]"}], "]"}]}], "}"}]], "Input",Expres\
sionUUID->"7b77d3b7-1f6a-4fcd-9697-b451f7d6297e"],

Cell["Read the dashboard entry.", "CodeText",ExpressionUUID->"c43469c8-0e57-4d5b-8ef3-9d72703c7402"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TarskiAxiomQ", "[", 
   RowBox[{"HypercubeGraph", "[", "3", "]"}], "]"}], 
  "[", "\"\<UpperDimension\>\"", "]"}]], "Input",ExpressionUUID->"ce03b5e0-\
d097-4709-9bf8-680d30eb7a66"],

Cell["See also", "Section",ExpressionUUID->"c0db7b9a-d1da-46ad-8fc2-5db0cebc9cd1"],

