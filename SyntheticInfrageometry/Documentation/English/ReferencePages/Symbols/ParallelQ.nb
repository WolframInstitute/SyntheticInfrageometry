Notebook[{
Cell["InfraParallelQ", "Title",ExpressionUUID->"81bf2e7d-0056-4ebd-bdd1-479148a4958b"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"65ea9cdc-3ab5-4b81-b20b-5b95e6305274"],

Cell["\<\
InfraParallelQ[g, l1, l2] tests whether two lines are parallel: every vertex on l2 \
is at constant distance from l1. InfraParallelQ[g, l1, l2, threshold] allows \
distance variation up to threshold.\
\>", "Text",ExpressionUUID->"6314cb5f-97bd-4cf3-8d68-6082b854d360"],

