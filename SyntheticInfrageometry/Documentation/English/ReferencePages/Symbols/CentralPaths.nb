Notebook[{
Cell["CentralPaths", "Title",ExpressionUUID->"4c45e2a4-ce5b-4012-9033-dd3b1590114f"],

Cell["\<\
CentralPaths[graph, paths] keeps the paths whose maximum path-space distance \
to the rest of the bundle is minimal -- the metric centres of the bundle. \
Option Method -> \"Frechet\" (default) | \"Hausdorff\" | \"MeanFrechet\" \
picks the underlying base metric. Operator form CentralPaths[graph, \
opts][paths] is provided for piping after FindSegment / FindLine.\
\>", "Text",ExpressionUUID->"16125150-4d2b-4050-8cb5-801047e941f0"],

Cell["Setup", "Section",ExpressionUUID->"919045f5-413a-4656-8789-ae5d733f3ba0"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"68eeb0b9-4903-42e5-a67e-8933b75f5c61"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"b9297625-7148-45ab-8014-ca7e0bbe5859"],

Cell["Usage", "Section",ExpressionUUID->"2cb17a5f-8cb1-41f1-99c9-74792e313a98"],

Cell["Pick the path-space centres of a geodesic bundle.", "CodeText",ExpressionUUID->"785f5f23-bc72-42fa-afb2-29a37683731c"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"CentralPaths", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSegment", "[", 
      RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}]}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"511bc9aa-2d24-496a-9eac-bcf367d5c6e5"],

Cell["Use the operator form for piping.", "CodeText",ExpressionUUID->"43664f32-2b7c-4e30-92e7-f5282e7213aa"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"CentralPaths", "[", "g", "]"}], "[", 
    RowBox[{"FindSegment", "[", 
     RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"7c98e3ed-0235-4735-b56c-7bf2430eef92"],

Cell["Examples", "Section",ExpressionUUID->"83b5367a-6bcd-4298-a913-7ab5b8e92921"],

Cell["Switch to the Hausdorff path-space metric.", "CodeText",ExpressionUUID->"0fe4bb17-a974-4c30-882b-237d6fe3b436"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"CentralPaths", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSegment", "[", 
      RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], ",", 
     RowBox[{"Method", "\[Rule]", "\"\<Hausdorff\>\""}]}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"808464f1-25e0-4259-b66e-1c177758f8e3"],

Cell["Render only the central subbundle.", "CodeText",ExpressionUUID->"d5dff0e4-3437-41ce-b0ba-d9469c9badaf"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"CentralPaths", "[", 
        RowBox[{"g", ",", 
         RowBox[{"FindSegment", "[", 
          RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}]}], "]"}], "\[Rule]",
        "Blue"}], "}"}]}], "]"}]}], "]"}]], "Input",ExpressionUUID->"a1fc053b-\
74cf-4951-a570-90da97509a17"],

Cell["See also", "Section",ExpressionUUID->"e75c4c54-88af-48f8-9280-0d4fbf3287a4"],

Cell["FindSegment", "Item",ExpressionUUID->"246f8e6b-b1d9-4242-909c-89c485f937df"],

Cell["FindLine", "Item",ExpressionUUID->"289c64d1-b630-4249-a471-5bfcb6f73f77"],

Cell["FindSphere", "Item",ExpressionUUID->"f18e84b6-c01a-4ec7-9641-a2b31236e480"],

Cell["CentralCycles", "Item",ExpressionUUID->"bcddf959-a760-43ee-8ef3-cabc37872d06"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"fa94a964-6d5a-4eae-b08e-8ed164ad277c"],

Cell["EmbeddingClosestCycles", "Item",ExpressionUUID->"5afddf1a-43bb-42f3-be4b-02e78165dccd"]
},
