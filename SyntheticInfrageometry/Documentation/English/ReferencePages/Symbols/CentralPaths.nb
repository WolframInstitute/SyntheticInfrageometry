Notebook[{
Cell["CentralPaths", "Title",ExpressionUUID->"bd4bf80e-7050-4c0a-b0ea-1de3b37af2ab"],

Cell["\<\
CentralPaths[graph, paths] keeps the paths whose maximum path-space distance \
to the rest of the bundle is minimal -- the metric centres of the bundle. \
Option Method -> \"Frechet\" (default) | \"Hausdorff\" | \"MeanFrechet\" \
picks the underlying base metric. Operator form CentralPaths[graph, \
opts][paths] is provided for piping after FindSegment / FindLine.\
\>", "Text",ExpressionUUID->"1882cd9c-8174-47db-96ba-08111bc2703b"],

Cell["Setup", "Section",ExpressionUUID->"430fadb7-9812-496a-9c67-f03366ca67dc"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"5f79f658-4695-40f3-874a-cd47e580a831"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"f4722f13-030d-447d-8828-738b51097c42"],

Cell["Usage", "Section",ExpressionUUID->"2b02b9e2-1b3e-42f1-b3d3-11f3fc452103"],

Cell["Pick the path-space centres of a geodesic bundle.", "CodeText",ExpressionUUID->"f94e38fc-d5f5-4ca8-95e7-f3c1342c73c8"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"CentralPaths", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSegment", "[", 
      RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}]}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"f7e0eb71-fc1a-4f6b-a724-13e10a024028"],

Cell["Use the operator form for piping.", "CodeText",ExpressionUUID->"5320259e-3cb2-4ab2-880b-98d922f43956"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"CentralPaths", "[", "g", "]"}], "[", 
    RowBox[{"FindSegment", "[", 
     RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"82655079-6829-46a9-8d0f-4dea7ba00bdf"],

Cell["Examples", "Section",ExpressionUUID->"bfa7bd9d-70fc-49f9-9a69-185b156af65b"],

Cell["Switch to the Hausdorff path-space metric.", "CodeText",ExpressionUUID->"ac8e439c-f078-4467-9f47-36b09c445aef"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"CentralPaths", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSegment", "[", 
      RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], ",", 
     RowBox[{"Method", "\[Rule]", "\"\<Hausdorff\>\""}]}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"bdb15c7d-c6b3-46c1-8e05-64b4b23714be"],

Cell["Render only the central subbundle.", "CodeText",ExpressionUUID->"defd9b00-bfe0-4189-bf28-cd3e24d0d416"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"CentralPaths", "[", 
        RowBox[{"g", ",", 
         RowBox[{"FindSegment", "[", 
          RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}]}], "]"}], "\[Rule]",
        "Blue"}], "}"}]}], "]"}]}], "]"}]], "Input",ExpressionUUID->"238ea7cc-\
7484-4f4e-8448-3155bd9bad28"],

Cell["See also", "Section",ExpressionUUID->"851071c9-1595-4b06-a3a1-7006bc22637a"],

Cell["FindSegment", "Item",ExpressionUUID->"235d8e57-16e9-457e-b915-40fda533a223"],

Cell["FindLine", "Item",ExpressionUUID->"38215517-2cb8-4d03-b1be-d92516c695a7"],

Cell["FindSphere", "Item",ExpressionUUID->"1c64f900-740c-4b73-9b3e-cbca3db5cd14"],

Cell["CentralCycles", "Item",ExpressionUUID->"20d43a47-eb75-406f-8906-6db6e1e82e9a"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"9c40f443-d1ee-4d44-8ce1-b64839622c2b"],

Cell["EmbeddingClosestCycles", "Item",ExpressionUUID->"20573b6d-9ade-4921-9728-b329e1f00a9d"]
},
