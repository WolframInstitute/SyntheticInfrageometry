Notebook[{
Cell["FindCommonPoint", "Title",ExpressionUUID->"1027f481-48b8-4a0d-b5d1-e8efc0eb91db"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"3ffa642b-8332-40d1-b3c8-a2fcd0977a49"],

Cell["\<\
FindCommonPoint[g, lines] returns the vertices lying on every line in the \
given list. Returns a List of unary InfraPoint[{v}] wrappers or $Failed; n / \
UpTo[n] / All control multiplicity. Entries may be bare vertex sequences or \
InfraSegment / InfraRay wrappers.\
\>", "Text",ExpressionUUID->"cd9ad76c-4776-4143-af88-94bbd7a5d9c0"],

Cell["Setup", "Section",ExpressionUUID->"0bd11f60-0d14-4782-a6a7-699efbc76081"],

