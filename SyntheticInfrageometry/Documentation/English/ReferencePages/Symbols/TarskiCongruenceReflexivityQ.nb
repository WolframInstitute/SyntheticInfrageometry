Notebook[{
Cell["TarskiCongruenceReflexivityQ", "Title",ExpressionUUID->"82891b67-187c-49a0-a049-6eb57ab7497e"],

Cell["\<\
TarskiCongruenceReflexivityQ[graph] tests Tarski axiom A1: for all a, b, ab \
== ba. Always True on undirected simple graphs.\
\>", "Text",ExpressionUUID->"c5179fed-588d-44a8-b2b0-831c353f2c38"],

Cell["Setup", "Section",ExpressionUUID->"faa1ab91-665b-46a2-a72a-b2527dfc4f9e"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"e7c7d079-1e29-4746-bd63-216cb97ae8f4"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"c5dd8e42-df7b-4a6e-8d55-b012b2534ff0"],

Cell["Usage", "Section",ExpressionUUID->"fa87de9d-37c8-4145-9b2b-687b1b078c77"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"c8f4907f-147a-458d-8069-137efcd5eae2"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceReflexivityQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"3290cee1-e597-4267-b944-6c960586eb24"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"db49bdb8-e52d-4f72-91cc-78137a54dc0d"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceReflexivityQ", "[", 
  RowBox[{"Graph", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"Null", ",", 
      RowBox[{"SparseArray", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{"6", ",", "6"}], "}"}], ",", "0", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "0", ",", "2", ",", "4", ",", "6", ",", "8", ",", "10", ",", 
              "12"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "5", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "5", "}"}]}], "}"}]}], "}"}], ",", "Pattern"}], 
         "}"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"GraphLayout", "\[Rule]", "\"\<CircularEmbedding\>\""}], "}"}]}],
    "]"}], "]"}]], "Input",ExpressionUUID->"45f19973-cc76-4d8c-b5c9-\
d2bf9d81d970"],

Cell["Examples", "Section",ExpressionUUID->"9c16b3c1-f07d-4ea7-9d63-01c92645d336"],

Cell["Compare with the dashboard entry.", "CodeText",ExpressionUUID->"d52bcbad-4ad0-4048-aa5a-a0258eafecc7"],

Cell[BoxData[
 RowBox[{"TarskiAxiomQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"9497ec07-a212-42eb-ae59-78dd236a86f4"],

Cell["Evaluate the predicate on a grid as a second check.", "CodeText",ExpressionUUID->"d0ff935d-bf58-489e-af3f-d7345cbbc194"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceReflexivityQ", "[", 
  RowBox[{"GridGraph", "[", 
   RowBox[{"{", 
    RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"36f257b8-908b-412f-aac1-fa7b61777699"],

