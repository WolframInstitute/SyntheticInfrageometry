Notebook[{
Cell["TarskiCongruenceReflexivityQ", "Title",ExpressionUUID->"b9e47a29-5664-4100-9bb5-1bea8ce6b44f"],

Cell["\<\
TarskiCongruenceReflexivityQ[graph] tests Tarski axiom A1: for all a, b, ab \
== ba. Always True on undirected simple graphs.\
\>", "Text",ExpressionUUID->"a8ebc876-36b6-4c96-918d-f48d68c2fb6f"],

Cell["Setup", "Section",ExpressionUUID->"635a7434-20df-4de8-b030-f990205d4f75"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"83189d95-bea4-4a32-baf0-f783ff4b0132"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"3159a74f-4ef3-47e5-bb62-1dbec82a7a14"],

Cell["Usage", "Section",ExpressionUUID->"ccf8cab3-060f-4e70-9a32-be0f21b340c9"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"f9d1b2d3-8597-4ac9-92d3-4325f9e278e2"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceReflexivityQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"280f0fa7-7186-4d1c-9061-9d41d6f7527d"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"7bd89abc-0f9f-426f-a8f6-be720abd70a3"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceReflexivityQ", "[", 
  RowBox[{
  "tarskiSecondExample", "[", "\"\<TarskiCongruenceReflexivityQ\>\"", "]"}], 
  "]"}]], "Input",ExpressionUUID->"58c10f01-9ec3-47be-bf03-551a8637a8b7"],

Cell["Examples", "Section",ExpressionUUID->"58bd6ff1-23ef-4852-9dd5-0d4cdd045229"],

Cell["Compare with the dashboard entry.", "CodeText",ExpressionUUID->"311330c7-969c-48ad-9444-f34e7a0f28d4"],

Cell[BoxData[
 RowBox[{"TarskiAxiomQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"be92ae7c-8830-43d4-ae0f-f21246f4f835"],

Cell["Evaluate the predicate on a grid as a second check.", "CodeText",ExpressionUUID->"a837ca2d-7976-47a1-91f2-8768f3d842da"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceReflexivityQ", "[", 
  RowBox[{"GridGraph", "[", 
   RowBox[{"{", 
    RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"fea9e03b-c0e5-4e43-80e9-1c95b71c8104"],

Cell["See also", "Section",ExpressionUUID->"138eb859-c2e1-40f5-9815-32e8dd66bab1"],

Cell["BetweennessQ", "Item",ExpressionUUID->"7c8a0158-d964-402d-b518-a66557741b10"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"ebce1a4c-afdb-4983-8a02-b54d21367cf7"],

Cell["TarskiStructure", "Item",ExpressionUUID->"e664e215-2801-4902-b642-bc6a25a015b0"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"3dcf40ce-4b14-40a0-bbcc-f9bc7a69563c"],

