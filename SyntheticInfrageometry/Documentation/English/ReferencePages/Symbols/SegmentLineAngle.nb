  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"32b47a75-bdb6-4005-9c95-2c28540b28cd"],

Cell["Examples", "Section",ExpressionUUID->"86777904-8bcd-4e7d-ac2e-7824dc882a84"],

