Notebook[{
Cell["InfraSegmentLineAngle", "Title",ExpressionUUID->"0a79478c-a6c4-4554-87e2-acaa1264ee2b"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"203d9059-8f79-4190-b7c4-10a128a32aa7"],

Cell["\<\
InfraSegmentLineAngle[g, p1, p2, line] (or InfraSegmentLineAngle[g, segment, line]) \
measures the distance from one endpoint of a segment to a line, given that \
the other endpoint lies on the line. The name is historical \[LongDash] the \
value is a length, not a normalised angle. Option Method (\"Metric\" \
(default); \"Spectral\" reserved).\
\>", "Text",ExpressionUUID->"ca297a92-feb9-4f46-96da-eeb7920ac585"],

Cell["Setup", "Section",ExpressionUUID->"4b4997dc-83c9-4454-97ae-1957cac2c840"],

