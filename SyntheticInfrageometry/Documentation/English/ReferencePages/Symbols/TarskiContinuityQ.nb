Notebook[{
Cell["TarskiContinuityQ", "Title",ExpressionUUID->"326145a3-1bd3-4ba1-a9fd-3e19e6ce4a86"],

Cell["\<\
TarskiContinuityQ[graph] tests Tarski axiom A11 (first-order Dedekind \
continuity schema). Always False on finite discrete graphs -- the failure is \
structural and has no finite vertex-tuple witness.\
\>", "Text",ExpressionUUID->"efaa3ef4-c3f9-42c3-b935-17f86c888b1e"],

Cell["Setup", "Section",ExpressionUUID->"5885d6f5-9b11-4a16-9d9c-7dcf00ec1110"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"7bedb9c8-eefa-46d8-b2d6-6db4c7f98689"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"2aa6938d-534d-4b79-b84f-fe0ce2cb8e83"],

Cell["Usage", "Section",ExpressionUUID->"303d7da0-05a1-42e8-95d3-22a9592dc650"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"b05ec173-54ac-41b0-a8d9-add3e3d52e30"],

Cell[BoxData[
 RowBox[{"TarskiContinuityQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"227280b7-1247-4fd1-abf8-821d2adea9d7"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"9bbcad32-8b16-4a68-811d-46328d4f808a"],

Cell[BoxData[
 RowBox[{"TarskiContinuityQ", "[", 
  RowBox[{"Graph", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6", ",", "7", ",", 
      "8", ",", "9"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"Null", ",", 
      RowBox[{"SparseArray", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{"9", ",", "9"}], "}"}], ",", "0", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "0", ",", "2", ",", "5", ",", "7", ",", "10", ",", "14", ",", 
              "17", ",", "19", ",", "22", ",", "24"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "5", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "5", "}"}], ",", 
              RowBox[{"{", "7", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "8", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "5", "}"}], ",", 
              RowBox[{"{", "9", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "8", "}"}], ",", 
              RowBox[{"{", "5", "}"}], ",", 
              RowBox[{"{", "7", "}"}], ",", 
              RowBox[{"{", "9", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "8", "}"}]}], "}"}]}], "}"}], ",", "Pattern"}], 
         "}"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"GraphLayout", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<GridEmbedding\>\"", ",", 
        RowBox[{"\"\<Dimension\>\"", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"3", ",", "3"}], "}"}]}]}], "}"}]}], "}"}]}], "]"}], 
  "]"}]], "Input",ExpressionUUID->"1502a9d3-2e2b-440f-984b-69795f18ee88"],

Cell["Examples", "Section",ExpressionUUID->"04cf3f33-e8dc-41ac-b698-bab3a4c277e1"],

Cell["The dashboard reports the same structural failure.", "CodeText",ExpressionUUID->"6f8ef1e6-c88b-47e8-b903-bc02689dbc07"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TarskiAxiomQ", "[", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}], "[", "\"\<Continuity\>\"", 
  "]"}]], "Input",ExpressionUUID->"aed3f92e-dd65-4431-9607-ccda1fefc419"],

Cell["Continuity has no finite counterexample witness.", "CodeText",ExpressionUUID->"bf33a1cf-ee6a-4281-9ea1-e543b7cdc530"],

Cell[BoxData[
 RowBox[{"Quiet", "[", 
  RowBox[{"FindTarskiCounterexample", "[", 
   RowBox[{
    RowBox[{"GridGraph", "[", 
     RowBox[{"{", 
      RowBox[{"3", ",", "3"}], "}"}], "]"}], ",", "TarskiContinuityQ", ",", 
    "All"}], "]"}], "]"}]], "Input",ExpressionUUID->"fc3a28ec-d902-419f-b790-\
347d0c544edc"],

Cell["See also", "Section",ExpressionUUID->"dcb7f423-2aa3-459e-abed-804248407f67"],

Cell["BetweennessQ", "Item",ExpressionUUID->"a08a1984-2bdf-44e6-9ad2-a4406833e7ce"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"73e770d8-6bb8-443d-a9d1-c8dcdaca4ac7"],

Cell["TarskiStructure", "Item",ExpressionUUID->"87136f8d-a3ea-45d6-bc2a-cb71dace7cd9"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"6b458299-b5c3-49fa-ad01-43fc79d6c0b7"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"5a847a7c-c491-48a3-8e87-a6cbba85dc3c"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"3cbd021d-7c17-4343-a727-25c4d0ab38ab"],

Cell["MetricInterval", "Item",ExpressionUUID->"e2871e40-5a16-455c-9923-8d2027c2e6aa"]
},
