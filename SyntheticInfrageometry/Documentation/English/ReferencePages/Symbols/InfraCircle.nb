Notebook[{
Cell["InfraCircle", "Title",ExpressionUUID->"768128ad-c6c3-4a95-a857-570588285f4d"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"2b17feef-a465-4d6f-b6fe-96ed747b628a"],

Cell["\<\
InfraCircle is the wrapper head for separating-cycle realisations. \
InfraCircle[{cycle}] is the unary form; InfraCircle[{cycle1, \[Ellipsis], \
cyclek}] is the multi-realisation form. FindCircle emits a List of unary \
InfraCircle[{cycle}] wrappers. The multi form is consumed by \
InfraSceneHighlight with sequential edges plus auto-closure.\
\>", "Text",ExpressionUUID->"34aefa2c-93dc-402f-8ffa-d6be8e11d039"],

Cell["Setup", "Section",ExpressionUUID->"6a22e011-969d-4b83-af99-e79d26248552"],

