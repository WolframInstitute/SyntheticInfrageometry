(* Beginning of Notebook Content *)
Notebook[{
Cell["ShortestCircumferenceCycles", "Title",ExpressionUUID->"60049712-5873-4e89-9f02-ab32beaa5abd"],

Cell["\<\
ShortestCircumferenceCycles[cycles] keeps the cycles whose vertex count \
(circumference) is minimal in the bundle. \
ShortestCircumferenceCycles[InfraCircle[cycles]] returns InfraCircle of the \
result. Used after FindCircle to keep only the smallest separating cycles.\
\>", "Text",ExpressionUUID->"678f4a9c-1d57-4a56-9a26-3c9aaf79fb8a"],

Cell["Setup", "Section",ExpressionUUID->"129e02ed-a689-4228-8c26-8963db6c44d5"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"7179cbf5-13fb-47dd-9e47-d7141daaa98a"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"f7c66b0f-2636-45cf-90f4-03e809f9c9c9"],

Cell["Usage", "Section",ExpressionUUID->"b172bdfb-f563-4761-9db4-ba925e98007f"],

Cell["Keep only the shortest separating cycles.", "CodeText",ExpressionUUID->"c7c5f68d-54b8-4f02-9b49-26ea6a798ad0"],

Cell["\<\
With[{g = GridGraph[{4, 4}]}, ShortestCircumferenceCycles @ FindCircle[g, 6, \
{1, 2}, All]]\
\>", "Input",ExpressionUUID->"bad568ae-e49c-4b3b-93d5-4a1f1b9b336f"],

Cell["\<\
Render the shortest-circumference cycles on top of the graph.\
\>", "CodeText",ExpressionUUID->"fc90d814-2d0f-457e-b8c9-dbe497113c9f"],

Cell["\<\
With[{g = GridGraph[{4, 4}]}, InfraSceneHighlight[g, \
{ShortestCircumferenceCycles @ FindCircle[g, 6, {1, 2}, All] -> Red, \
InfraPoint[{6}] -> Blue}]]\
\>", "Input",ExpressionUUID->"e2d7c373-4fa5-4a6e-88be-2031fa89661a"],

Cell["Examples", "Section",ExpressionUUID->"1e7f740f-23b8-40ce-988f-998b3d1f91ae"],

Cell["\<\
Compare shortest vs longest circumference subbundles side by side.\
\>", "CodeText",ExpressionUUID->"215fdef7-094d-4684-b2c3-f1a154dc03ed"],

Cell["\<\
With[{g = GridGraph[{4, 4}], cycles = FindCircle[g, 6, {1, 2}, All]}, \
Row[{InfraSceneHighlight[g, {ShortestCircumferenceCycles @ cycles -> Red, \
InfraPoint[{6}] -> Blue}, ImageSize -> 200], InfraSceneHighlight[g, \
{LongestCircumferenceCycles @ cycles -> Blue, InfraPoint[{6}] -> Green}, \
ImageSize -> 200]}]]\
\>", "Input",ExpressionUUID->"692c8724-1d34-4fa7-9966-d53689f8efdd"],

Cell["See also", "Section",ExpressionUUID->"d2f02f74-8def-4740-bbbf-6d1d4ed9b604"],

Cell["LongestCircumferenceCycles", "Item",ExpressionUUID->"7ad30e42-6730-4f9c-94a9-1a73998b07cd"],

Cell["CentralCycles", "Item",ExpressionUUID->"c5610571-8220-4cf4-8cbf-f6b99cbd6d62"],

Cell["FindCircle", "Item",ExpressionUUID->"f88fefa3-f24f-4862-9277-28fc5886ff36"],

Cell["InfraSceneHighlight", "Item",ExpressionUUID->"2233cdc1-21bf-438f-87a6-6a1466959053"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
