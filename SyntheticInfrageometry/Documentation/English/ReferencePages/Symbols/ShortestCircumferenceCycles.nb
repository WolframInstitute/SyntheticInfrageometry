Notebook[{
Cell["ShortestCircumferenceCycles", "Title",ExpressionUUID->"99c7bb29-42b8-4ed9-96ea-94c80aa31227"],

Cell["\<\
ShortestCircumferenceCycles[cycles] keeps the cycles of minimum length -- the \
combinatorial-girth filter. Pure list operation, no graph required.\
\>", "Text",ExpressionUUID->"a9e2af86-7e02-416b-a397-4f96d77e26ab"],

Cell["Setup", "Section",ExpressionUUID->"4ba52742-c3f9-43cd-ad3c-73e41328142e"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"540e9644-d40e-4ba9-8ee2-c394062f6097"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"82c214c5-1e51-4899-a985-767d0e79eead"],

Cell["Usage", "Section",ExpressionUUID->"c06302d3-f973-42b3-9049-c86d8b5125d5"],

Cell["Keep the shortest cycles in a list.", "CodeText",ExpressionUUID->"27d38682-3333-4dbd-954a-bafec6ece7e6"],

Cell[BoxData[
 RowBox[{"ShortestCircumferenceCycles", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"4", ",", "5", ",", "6"}], "}"}]}], "}"}], "]"}]], "Input",Expres\
sionUUID->"f446fd50-f994-4f42-bc1b-5aad876bd626"],

Cell["Apply the filter to a separating-cycle bundle.", "CodeText",ExpressionUUID->"e4ca483f-63ed-4d11-a481-9547ff4382df"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"ShortestCircumferenceCycles", "[", 
    RowBox[{"FindSphere", "[", 
     RowBox[{"g", ",", "6", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
      RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"dc5ecbac-b6b8-4748-81be-\
12dff7fb4d65"],

Cell["Examples", "Section",ExpressionUUID->"c6881888-0516-4087-b2f3-53702e5abce8"],

Cell["Compose the filter with cycle centrality.", "CodeText",ExpressionUUID->"78b63a39-e28d-42cf-a7fb-9107e7587daa"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"CentralCycles", "[", "g", "]"}], "[", 
    RowBox[{"ShortestCircumferenceCycles", "[", 
     RowBox[{"FindSphere", "[", 
      RowBox[{"g", ",", "6", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
       RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], 
     "]"}], "]"}]}], "]"}]], "Input",ExpressionUUID->"c9213d31-3e7c-4519-a24c-\
0a7fecf263cb"],

Cell["Count how many shortest cycles survive a tie.", "CodeText",ExpressionUUID->"0744a70c-c23c-4a55-97cc-2d72e5b6ef31"],

Cell[BoxData[
 RowBox[{"Length", "[", 
  RowBox[{"ShortestCircumferenceCycles", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"4", ",", "5", ",", "6"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]}], "}"}], "]"}], 
  "]"}]], "Input",ExpressionUUID->"b5efb47b-2a2b-4447-8182-92b118633f85"],

Cell["See also", "Section",ExpressionUUID->"51b326a8-d792-466b-8eaf-6581cd0e676f"],

Cell["FindSegment", "Item",ExpressionUUID->"253a3358-d47e-41fb-a23d-f85cd0d8814c"],

Cell["FindLine", "Item",ExpressionUUID->"2252ffb3-cf34-4be4-8c4c-1d7dc7b8d778"],

Cell["FindSphere", "Item",ExpressionUUID->"61216b18-ed29-43a4-836b-84b89dad7a15"],

Cell["CentralPaths", "Item",ExpressionUUID->"14021234-cdf4-4b89-937c-20eb01a616c0"],

Cell["CentralCycles", "Item",ExpressionUUID->"7bdafa6d-5deb-413b-8f59-711741861729"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"353ebbf5-7310-4aa8-8039-f2a8f9b90323"],

Cell["EmbeddingClosestCycles", "Item",ExpressionUUID->"18a94845-0c8d-4c15-9bc9-4d66ab675ec1"]
},
