Notebook[{
Cell["TarskiEquidistanceClasses", "Title",ExpressionUUID->"fc942665-c67e-4ace-8bbe-918338e13cb3"],

Cell["\<\
TarskiEquidistanceClasses[graph] returns the partition of unordered vertex \
pairs by distance value -- each class is a list of {a, b} pairs with a common \
d(a, b).\
\>", "Text",ExpressionUUID->"5fbf3f82-2495-4c4a-8972-eef8d133d872"],

Cell["Setup", "Section",ExpressionUUID->"b5a21ff1-2d60-4c43-8768-ababcaf4fe50"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"280412fa-8eea-4a33-887a-ce268dcc8d33"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"7d1e0d2b-558e-4033-ab51-3a1c7aa53bc4"],

Cell["Usage", "Section",ExpressionUUID->"1f7ce927-9fde-445f-a49b-6558e3d18ac2"],

Cell["Return the partition of unordered pairs by distance value.", "CodeText",ExpressionUUID->"a7c5306b-9f95-4f58-81fe-dbf485fe2c44"],

Cell[BoxData[
 RowBox[{"TarskiEquidistanceClasses", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"10eed37e-fa8c-4751-bded-056e53e32a80"],

Cell["Count the distance classes on a cycle.", "CodeText",ExpressionUUID->"5d5a0455-e951-450d-8c94-86bd3264763b"],

Cell[BoxData[
 RowBox[{"Length", "[", 
  RowBox[{"TarskiEquidistanceClasses", "[", 
   RowBox[{"CycleGraph", "[", "6", "]"}], "]"}], "]"}]], "Input",ExpressionUUI\
D->"fb7180bb-6c7c-4dc8-b98c-2d90a0b549a1"],

Cell["Examples", "Section",ExpressionUUID->"acd8d85a-b96f-40f7-b0a9-422259ca49b5"],

Cell["Inspect one class of equal-distance pairs.", "CodeText",ExpressionUUID->"809ce309-8e5c-440c-9eb3-bd08b6e35c01"],

Cell[BoxData[
 RowBox[{"First", "[", 
  RowBox[{"TarskiEquidistanceClasses", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], "]"}]], "Input",Expression\
UUID->"1ea8ac48-57e4-4e46-902f-baf895e5a180"],

Cell["Check that every unordered pair lands in exactly one class.", "CodeText",ExpressionUUID->"03ff99b2-7cac-4051-a5f1-2cfe867ee9e5"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"classes", "=", 
     RowBox[{"TarskiEquidistanceClasses", "[", 
      RowBox[{"PathGraph", "[", 
       RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"Sort", "[", 
     RowBox[{"Flatten", "[", 
      RowBox[{"classes", ",", "1"}], "]"}], "]"}], "===", 
    RowBox[{"Sort", "[", 
     RowBox[{"Subsets", "[", 
      RowBox[{
       RowBox[{"Range", "[", "5", "]"}], ",", 
       RowBox[{"{", "2", "}"}]}], "]"}], "]"}]}]}], "]"}]], "Input",Expression\
UUID->"e81b8cb8-66ee-48f0-8665-1ca428b0fd71"],

Cell["See also", "Section",ExpressionUUID->"5c1099d9-36da-45ff-b514-53dd043b65cd"],

Cell["BetweennessQ", "Item",ExpressionUUID->"b205547f-e0f1-4b0b-ac76-8d988d7593e9"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"016ec4a2-16f1-428d-8d3a-075f3f11f25a"],

Cell["TarskiStructure", "Item",ExpressionUUID->"54e94adc-f826-4424-8ddc-6a83719450a2"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"682be29f-03fe-4d35-93a1-afa56c54b712"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"7a694fd7-eb43-448e-9622-b65d3446541b"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"9485f68c-de8f-4e41-92e4-1826b88a5fd9"],

Cell["MetricInterval", "Item",ExpressionUUID->"589fba43-21a5-4042-aae9-b1fa52833ce2"]
},
