Notebook[{
Cell["TarskiEquidistanceClasses", "Title",ExpressionUUID->"9bd6a9e7-f8b6-4e97-b6f4-641252de4d85"],

Cell["\<\
TarskiEquidistanceClasses[graph] returns the partition of unordered vertex \
pairs by distance value -- each class is a list of {a, b} pairs with a common \
d(a, b).\
\>", "Text",ExpressionUUID->"26a43889-8e1f-47cc-b0b0-851313a6c33f"],

Cell["Setup", "Section",ExpressionUUID->"a5da4799-a954-414e-a0a3-63a4d3fcd284"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"6cfa904d-3b9a-497f-921f-c5dc77af9556"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"d750bb6f-f2e6-4927-ae07-662c8df61dd2"],

Cell["Usage", "Section",ExpressionUUID->"030bd31f-ae67-46e5-a713-05588442ee4f"],

Cell["Return the partition of unordered pairs by distance value.", "CodeText",ExpressionUUID->"f4c787c2-1c2f-42b7-b795-0d8df0e9268d"],

Cell[BoxData[
 RowBox[{"TarskiEquidistanceClasses", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"0c707517-ab74-4bf4-9e85-3525883782a8"],

Cell["Count the distance classes on a cycle.", "CodeText",ExpressionUUID->"c643cea5-b62b-4b96-969f-fc46915a323d"],

Cell[BoxData[
 RowBox[{"Length", "[", 
  RowBox[{"TarskiEquidistanceClasses", "[", 
   RowBox[{"CycleGraph", "[", "6", "]"}], "]"}], "]"}]], "Input",ExpressionUUI\
D->"b3212c6e-2cbf-461a-8579-ca94c5046599"],

Cell["Examples", "Section",ExpressionUUID->"dcb63eb0-20ec-4817-a699-79b4f9547ef5"],

Cell["Inspect one class of equal-distance pairs.", "CodeText",ExpressionUUID->"4d46b259-914b-4532-bf0e-25326f0ddb1a"],

Cell[BoxData[
 RowBox[{"First", "[", 
  RowBox[{"TarskiEquidistanceClasses", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], "]"}]], "Input",Expression\
UUID->"3c78d2be-e871-48fc-b080-cae661f0484e"],

Cell["Check that every unordered pair lands in exactly one class.", "CodeText",ExpressionUUID->"8309746e-180b-4b3b-bb31-67cd1c27f1d1"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"classes", "=", 
     RowBox[{"TarskiEquidistanceClasses", "[", 
      RowBox[{"PathGraph", "[", 
       RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"Sort", "[", 
     RowBox[{"Flatten", "[", 
      RowBox[{"classes", ",", "1"}], "]"}], "]"}], "===", 
    RowBox[{"Sort", "[", 
     RowBox[{"Subsets", "[", 
      RowBox[{
       RowBox[{"Range", "[", "5", "]"}], ",", 
       RowBox[{"{", "2", "}"}]}], "]"}], "]"}]}]}], "]"}]], "Input",Expression\
UUID->"56f48f6b-d647-4d76-99ed-4fb7f4e3847f"],

Cell["See also", "Section",ExpressionUUID->"dc4ef42a-84e4-4346-9db3-64e5f6b3e706"],

Cell["BetweennessQ", "Item",ExpressionUUID->"dad245ae-ce2f-4a60-a347-95026f89b7e9"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"b2b87ec5-f99e-4732-9756-5ebfc1fd1835"],

Cell["TarskiStructure", "Item",ExpressionUUID->"775c0fe9-c95e-45c1-b486-230f2286b1a3"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"4fa0ce54-260d-4c05-b384-c18faaf40f28"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"90b853b1-a810-41ed-931e-3a817ccecbd8"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"e84a8da2-e92a-4029-b755-101d76ba8089"],

Cell["MetricInterval", "Item",ExpressionUUID->"b5cf2d4e-542e-43eb-8658-6417383b5a81"]
},
