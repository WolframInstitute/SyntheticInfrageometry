Notebook[{
Cell["FindTarskiMidpoint", "Title",ExpressionUUID->"65c416f6-8c7d-4aef-bb11-cb5dfff14356"],

Cell["\<\
FindTarskiMidpoint[graph, a, b] returns one vertex m with B(a, m, b) and am \
== mb -- the synthetic midpoint defined only from B and E. \
FindTarskiMidpoint[graph, a, b, n] returns exactly n or $Failed; UpTo[n] \
returns up to n; All returns all. Returns { } when no synthetic midpoint \
exists (e.g. odd-distance pairs); contrast FindMidpoint, which always returns \
a central interval element.\
\>", "Text",ExpressionUUID->"8e9d69a0-4294-49f4-a5e3-6ecdecc6f899"],

Cell["Setup", "Section",ExpressionUUID->"0399faf1-6809-4b3c-a0fd-c4938bef3e60"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"60b4f18a-fd82-4e69-92b7-cefa6bf64800"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"eca107a6-3e47-4e44-bc45-e7e17ab1e6a6"],

Cell["Usage", "Section",ExpressionUUID->"b5f08899-2309-49e6-98b9-d650fb511084"],

Cell["Find a synthetic midpoint on an even-length path.", "CodeText",ExpressionUUID->"7320ccf6-415f-4fe3-b376-b6b4c7d092dc"],

Cell[BoxData[
 RowBox[{"FindTarskiMidpoint", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "5", ",", "All"}],
   "]"}]], "Input",ExpressionUUID->"2847d12e-9dcc-42ec-bcda-8492223ebb45"],

Cell["Observe the odd-distance failure mode.", "CodeText",ExpressionUUID->"18fff1c6-5154-4e74-932c-ee318659ab6c"],

Cell[BoxData[
 RowBox[{"FindTarskiMidpoint", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "4", ",", "All"}],
   "]"}]], "Input",ExpressionUUID->"2c3dbb9c-c242-4e2b-bd3e-fb11fd899d7c"],

Cell["Examples", "Section",ExpressionUUID->"f5412cdd-8d1e-467e-8a24-7f1b6b0c59e7"],

Cell["Compare with the metric midpoint construction.", "CodeText",ExpressionUUID->"328d8fbb-740b-4da9-8dd7-4de6e8b6a1bc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"FindTarskiMidpoint", "[", 
    RowBox[{
     RowBox[{"PathGraph", "[", 
      RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "4", ",", 
     "All"}], "]"}], ",", 
   RowBox[{"FindMidpoint", "[", 
    RowBox[{
     RowBox[{"PathGraph", "[", 
      RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "4", ",", 
     "All"}], "]"}]}], "}"}]], "Input",ExpressionUUID->"ca9245b6-1e81-492f-\
b235-a5bc29c3dbde"],

Cell["Antipodes on a 4-cycle have two synthetic midpoints.", "CodeText",ExpressionUUID->"d84523df-9211-407f-ab04-ab577d9c3a03"],

Cell[BoxData[
 RowBox[{"FindTarskiMidpoint", "[", 
  RowBox[{
   RowBox[{"CycleGraph", "[", "4", "]"}], ",", "1", ",", "3", ",", "All"}], 
  "]"}]], "Input",ExpressionUUID->"558e683b-a0fa-423d-8978-86bf849d308d"],

Cell["See also", "Section",ExpressionUUID->"e30b8c4c-df6a-4a3b-bed9-588baf89eb38"],

Cell["BetweennessQ", "Item",ExpressionUUID->"53ea5863-2cdd-4930-889d-d77c4a369ad4"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"84f03314-0988-4b96-ac20-18501829a9d4"],

Cell["TarskiStructure", "Item",ExpressionUUID->"6142894e-5994-43a8-8e25-7534e45d63ae"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"cf194e1d-0160-4741-b651-cd3be1be6a87"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"441a9df5-b54b-4f24-88bb-777d18e32c57"],

Cell["MetricInterval", "Item",ExpressionUUID->"f6bce5b0-556a-47ce-9e3e-be028b6fce83"]
},
