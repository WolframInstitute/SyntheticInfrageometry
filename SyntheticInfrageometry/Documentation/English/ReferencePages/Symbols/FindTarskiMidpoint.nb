Notebook[{
Cell["FindTarskiMidpoint", "Title",ExpressionUUID->"6893459b-ba1d-4a9a-8767-4d693e606773"],

Cell["\<\
FindTarskiMidpoint[graph, a, b] returns one vertex m with B(a, m, b) and am \
== mb -- the synthetic midpoint defined only from B and E. \
FindTarskiMidpoint[graph, a, b, n] returns exactly n or $Failed; UpTo[n] \
returns up to n; All returns all. Returns { } when no synthetic midpoint \
exists (e.g. odd-distance pairs); contrast FindMidpoint, which always returns \
a central interval element.\
\>", "Text",ExpressionUUID->"b3f50151-27be-4694-9c1a-bec839350a41"],

Cell["Setup", "Section",ExpressionUUID->"cc0461cb-227a-40af-8d46-bce63e499ad7"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"06f33092-ae50-4ab4-8938-036c9a6b6555"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"53cdcc22-5b17-4e17-8ba1-4994699d6c5c"],

Cell["Usage", "Section",ExpressionUUID->"dec1adc1-8e41-448a-8d65-c03c492a4d7c"],

Cell["Find a synthetic midpoint on an even-length path.", "CodeText",ExpressionUUID->"2bacc945-0030-4116-9c7d-a83eafb19728"],

Cell[BoxData[
 RowBox[{"FindTarskiMidpoint", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "5", ",", "All"}],
   "]"}]], "Input",ExpressionUUID->"6664f5d5-b4ed-437d-9fbf-c8df8a468489"],

Cell["Observe the odd-distance failure mode.", "CodeText",ExpressionUUID->"f9f8f3d8-c940-4a0a-bd15-ac61f9a1c391"],

Cell[BoxData[
 RowBox[{"FindTarskiMidpoint", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "4", ",", "All"}],
   "]"}]], "Input",ExpressionUUID->"d6dec486-e91b-4f8e-829a-270e8680caa9"],

Cell["Examples", "Section",ExpressionUUID->"86e9f122-1ef1-4766-9f44-61e125b7471e"],

Cell["Compare with the metric midpoint construction.", "CodeText",ExpressionUUID->"c9989970-e269-466c-b90b-54cf4215059d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"FindTarskiMidpoint", "[", 
    RowBox[{
     RowBox[{"PathGraph", "[", 
      RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "4", ",", 
     "All"}], "]"}], ",", 
   RowBox[{"FindMidpoint", "[", 
    RowBox[{
     RowBox[{"PathGraph", "[", 
      RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "4", ",", 
     "All"}], "]"}]}], "}"}]], "Input",ExpressionUUID->"1bab148f-2e8c-4c4b-\
bb4d-ed5cfeec3b69"],

Cell["Antipodes on a 4-cycle have two synthetic midpoints.", "CodeText",ExpressionUUID->"d591209c-d988-4524-85be-782feeb67edf"],

Cell[BoxData[
 RowBox[{"FindTarskiMidpoint", "[", 
  RowBox[{
   RowBox[{"CycleGraph", "[", "4", "]"}], ",", "1", ",", "3", ",", "All"}], 
  "]"}]], "Input",ExpressionUUID->"26bee16e-a28f-48e7-838e-61139f694f69"],

Cell["See also", "Section",ExpressionUUID->"84388cf7-c86f-4ce4-96a0-08d70563b8e5"],

Cell["BetweennessQ", "Item",ExpressionUUID->"dfb8029e-0247-4401-8263-85c6339d8ed1"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"2b130936-6986-40c2-bd4d-aedd666e683c"],

Cell["TarskiStructure", "Item",ExpressionUUID->"7d11bc57-a3b7-459f-9756-db3a6bb49d9f"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"8cf56a43-729b-406a-afda-36a33b1aa1ee"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"7fdf8363-c77b-4607-bdae-467f57d45377"],

Cell["MetricInterval", "Item",ExpressionUUID->"443f3bd8-142e-4894-a8f6-133f86f7abbc"]
},
