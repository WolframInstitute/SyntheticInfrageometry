Notebook[{
Cell["GeodesicMultiplicity", "Title",ExpressionUUID->"70fcec0a-187f-438f-8ae2-c610c7c81e59"],

Cell["\<\
GeodesicMultiplicity[graph, u, v] returns the number of distinct geodesics \
from u to v, computed in polynomial time as (A^d)[u, v] where d = \
GraphDistance[graph, u, v] and A is the adjacency matrix. Walks of length d \
from u to v are automatically simple geodesics.\
\>", "Text",ExpressionUUID->"b7facc02-7a27-48d8-af0a-bed96f4933fc"],

Cell["Setup", "Section",ExpressionUUID->"af07a3bb-9d76-4f66-97b4-e2789dae2c96"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"29f7d3d4-41b9-434f-ba99-313c4045915c"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"140ab7d7-7ec7-422b-9736-1e5a57b295dd"],

Cell["Usage", "Section",ExpressionUUID->"554c9846-ebe8-4b88-abd1-0171f99f9172"],

Cell["\<\
Number of geodesics between opposite corners of a 4x4 grid (the central \
binomial coefficient C(6, 3)).\
\>", "CodeText",ExpressionUUID->"20e7d570-0cdf-409d-a0b0-00c254737484"],

Cell["GeodesicMultiplicity[GridGraph[{4, 4}], 1, 16]", "Input",ExpressionUUID->"6d2cfb96-698c-4eec-8a65-03c7947f1cc8"],

Cell["On a path the geodesic is unique.", "CodeText",ExpressionUUID->"203e8a1a-688d-4af1-a4df-c8d6389ec780"],

Cell["GeodesicMultiplicity[PathGraph[Range[7]], 1, 7]", "Input",ExpressionUUID->"7c4c24ee-a333-4287-a3a8-f24a22b5f524"],

Cell["Examples", "Section",ExpressionUUID->"7cee9933-5cef-48fa-8167-b8df01579244"],

Cell["\<\
On a cycle of even length the antipodal pair admits two geodesics.\
\>", "CodeText",ExpressionUUID->"8ec6e73e-684f-427b-8893-6bc8fdda8437"],

Cell["GeodesicMultiplicity[CycleGraph[8], 1, 5]", "Input",ExpressionUUID->"03d46815-1a1b-4baf-9d2b-ebd1ec74d32a"],

Cell["Compare across small grids.", "CodeText",ExpressionUUID->"ff28575f-1349-4e47-9631-d83ecc85fa51"],

Cell["\<\
Table[GeodesicMultiplicity[GridGraph[{n, n}], 1, n^2], {n, 2, 6}]\
\>", "Input",ExpressionUUID->"deeda1fc-7892-4580-91c2-49ad9ae4570a"],

Cell["See also", "Section",ExpressionUUID->"938bf96f-2bff-44f2-acad-0c9662605808"],

Cell["GeodesicMultiplicityMatrix", "Item",ExpressionUUID->"c5a7342f-4532-4cc5-8dff-12668087f656"],

Cell["MetricInterval", "Item",ExpressionUUID->"083c7f65-8402-4b8f-85b0-1a11d53b9b00"],

Cell["FindSegment", "Item",ExpressionUUID->"487e0f6c-b4eb-46bf-93ac-ee0a9fc619cd"],

Cell["MedianVertices", "Item",ExpressionUUID->"26257865-9efc-4b40-8c03-95ee3223697b"]
},
