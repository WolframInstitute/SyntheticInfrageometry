Cell[BoxData[
 RowBox[{"FindTarskiCounterexample", "[", 
  RowBox[{
   RowBox[{"PetersenGraph", "[", "]"}], ",", "TarskiInnerPaschQ", ",", 
   RowBox[{"UpTo", "[", "1", "]"}]}], "]"}]], "Input",ExpressionUUID->\
"c340393c-061b-49be-a2a8-9928dc9dd2cc"],

Cell["Read the dashboard entry on a grid.", "CodeText",ExpressionUUID->"3bc9c598-72ec-4a59-8eda-dc01a798e5ea"],

