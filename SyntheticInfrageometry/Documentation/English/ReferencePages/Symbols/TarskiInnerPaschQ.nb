Notebook[{
Cell["TarskiInnerPaschQ", "Title",ExpressionUUID->"d76213aa-d361-4d08-9707-13e31d275d3f"],

Cell["\<\
TarskiInnerPaschQ[graph] tests Tarski axiom A7 (Inner Pasch): if B(a, p, c) \
and B(b, q, c), there is x in I(p, b) intersect I(q, a). Holds on median \
graphs (trees, hypercubes); fails on cycles >= 5 and on Petersen.\
\>", "Text",ExpressionUUID->"6f4cfdf3-e99f-4ce7-be7a-ac0a75196a0f"],

Cell["Setup", "Section",ExpressionUUID->"616dd874-2a85-4e45-8b49-3a4bc7424d98"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"688f671f-a307-4ed8-972f-2b0d48a2c299"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"8d0acfcc-48a4-4af1-8394-815d13b6f9ba"],

Cell["Usage", "Section",ExpressionUUID->"280929b1-575b-4ad0-b941-1aa3e4c3f3c7"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"b20754e0-7dad-44c6-924a-537061c3a7af"],

Cell[BoxData[
 RowBox[{"TarskiInnerPaschQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"bc4991fd-4b8e-4848-b628-02f6ab93b743"],

