Notebook[{
Cell["CircleQ", "Title",ExpressionUUID->"788cca7a-71f4-4657-b88d-8b7665945671"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"72d8462f-2e61-4413-b9b0-debcd5ac7fd4"],

Cell["\<\
CircleQ[g, cycle] tests whether the vertex sequence cycle is a metric circle: \
a cyclic edge chain whose vertex set is a metric shell. Accepts both open and \
closed input.\
\>", "Text",ExpressionUUID->"8b39e59b-7466-412d-9314-cac33f37b33f"],

Cell["Setup", "Section",ExpressionUUID->"150576c1-423f-4e2a-bd23-89e43888c078"],

