Notebook[{
Cell["RadarCoordinates", "Title",ExpressionUUID->"480cc2aa-46f3-46dd-8415-4cb3efc4f5e2"],

Cell["\<\
RadarCoordinates[graph, basis, v] returns the spatial radar coordinates of v: \
the vector of graph distances (d(v, b1), d(v, b2), ..., d(v, bk)) from v to \
each basis point. RadarCoordinates[graph, basis] returns the Association of \
all vertices' radar coordinates, so RadarCoordinates[graph, basis][v] is the \
natural operator form.\
\>", "Text",ExpressionUUID->"c3c9c6e7-6edc-4c54-b0f8-1d34f60bf807"],

Cell["Setup", "Section",ExpressionUUID->"35bcf9aa-1257-4a66-ba6f-78200fffb96f"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"ccf60094-ac51-4f47-acba-8764287476e4"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"d7c4e57a-05e8-45b9-9c80-b710d4a8ccd5"],

Cell["Usage", "Section",ExpressionUUID->"dbf0d33f-3bd2-469a-bf81-bfd4d7cb962f"],

Cell["Distance vector of vertex 3 of P_5 to the basis {1}.", "CodeText",ExpressionUUID->"e3aace93-f366-40a9-b97e-d79edae9115d"],

Cell["RadarCoordinates[PathGraph[Range[5]], {1}, 3]", "Input",ExpressionUUID->"780ada83-10f6-456c-94a1-e9cd3c20a013"],

Cell["\<\
Bulk form: every vertex's coordinates with respect to the path endpoints.\
\>", "CodeText",ExpressionUUID->"a4f2b2d7-ff97-4c2b-94e2-7038f41f0953"],

Cell["RadarCoordinates[PathGraph[Range[5]], {1, 5}]", "Input",ExpressionUUID->"3e963948-20f9-404c-886a-d883d40eb9fa"],

Cell["Examples", "Section",ExpressionUUID->"8ca9659d-b804-4dec-be16-f6c83afb26eb"],

Cell["Radar coordinates with a two-vertex basis on the 6-cycle.", "CodeText",ExpressionUUID->"bc92d531-e678-4229-bdab-5b8027806162"],

Cell["RadarCoordinates[CycleGraph[6], {5, 6}]", "Input",ExpressionUUID->"5dcb2ebe-f5f9-4b97-886b-9db4ba92d1bb"],

Cell["\<\
Sanity check that the basis truly resolves the graph: every vertex gets a \
distinct coordinate vector.\
\>", "CodeText",ExpressionUUID->"acdd3a94-1644-40c5-93d2-e4e4fba57447"],

Cell["\<\
DuplicateFreeQ @ Values @ RadarCoordinates[GridGraph[{4, 4}], First @ \
FindRadarBasis[GridGraph[{4, 4}]]]\
\>", "Input",ExpressionUUID->"a6785a84-a329-4108-8168-534c8189ac9f"],

Cell["See also", "Section",ExpressionUUID->"1403671f-0447-40ef-86c7-6a20cc3cb77f"],

Cell["FindRadarBasis", "Item",ExpressionUUID->"f8a2cacc-1371-4e67-832e-71c9c115944d"],

Cell["RadarBasisQ", "Item",ExpressionUUID->"ca97aff2-9a7b-4227-86ad-bb2339bee89d"],

Cell["OrthogonalCoordinates", "Item",ExpressionUUID->"0741be0c-14b0-4f68-8ab2-0f26994b76ab"],

Cell["CoordinatizationGuide", "Item",ExpressionUUID->"97d2439e-303d-45d0-8ef6-f826a60cdbb4"]
},
