Notebook[{
Cell["TarskiAxiomQ", "Title",ExpressionUUID->"c96fd000-b89e-4f3c-973d-9d0d9216548f"],

Cell["\<\
TarskiAxiomQ[graph] returns an Association keyed by descriptive axiom names \
with the per-axiom result, composing all eleven Tarski*Q predicates into a \
dashboard.\
\>", "Text",ExpressionUUID->"c6250c5e-a0f7-43c3-ba2e-48556210ffd3"],

Cell["Setup", "Section",ExpressionUUID->"45c78ead-095f-42ba-8643-608aa609dc88"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"baa8d60b-911d-4b26-aeb1-800f6ca968c1"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"f5225b2d-4a1d-4431-8d1e-622ebfbc52b6"],

Cell["Usage", "Section",ExpressionUUID->"708eaba4-d1b3-42a2-bf61-0b804336ba9f"],

Cell["Return the full axiom dashboard on a grid.", "CodeText",ExpressionUUID->"05c6dbe6-5dc5-420a-9f5b-7d45b3749469"],

Cell[BoxData[
 RowBox[{"Quiet", "[", 
  RowBox[{"TarskiAxiomQ", "[", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}], "]"}]], "Input",ExpressionU\
UID->"d8ce4647-cf16-41e9-a448-81302db4417f"],

Cell["Return the dashboard on the Petersen graph.", "CodeText",ExpressionUUID->"b36a21ac-22c0-44dd-b0d1-48b7ad95564c"],

Cell[BoxData[
 RowBox[{"Quiet", "[", 
  RowBox[{"TarskiAxiomQ", "[", 
   RowBox[{"PetersenGraph", "[", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"61770e52-7d62-4c12-b18b-7849ab910a62"],

Cell["Examples", "Section",ExpressionUUID->"6b2647f1-1eb7-4f51-a7e9-b1b5481aee8f"],

Cell["Extract one named entry from the dashboard.", "CodeText",ExpressionUUID->"9a816cde-e6b5-4b5e-b719-78c30f20db19"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TarskiAxiomQ", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], 
  "[", "\"\<SegmentConstruction\>\"", "]"}]], "Input",ExpressionUUID->\
"a6b2eb2f-4887-4eb1-8e0f-8805317a551d"],

Cell["Compare two dashboards side by side.", "CodeText",ExpressionUUID->"c87ddf03-3dac-4f7d-9dc9-414162719e24"],

Cell[BoxData[
 RowBox[{"AssociationMap", "[", 
  RowBox[{
   RowBox[{"Quiet", "@*", "TarskiAxiomQ"}], ",", 
   RowBox[{"Association", "[", 
    RowBox[{
     RowBox[{"\"\<Path\>\"", "\[Rule]", 
      RowBox[{"PathGraph", "[", 
       RowBox[{"Range", "[", "5", "]"}], "]"}]}], ",", 
     RowBox[{"\"\<Petersen\>\"", "\[Rule]", 
      RowBox[{"PetersenGraph", "[", "]"}]}]}], "]"}]}], "]"}]], "Input",Expres\
sionUUID->"aba050a8-53ac-46ba-91d9-75d769747327"],

Cell["See also", "Section",ExpressionUUID->"3806dd5f-8842-448a-837a-cb251de686d2"],

Cell["BetweennessQ", "Item",ExpressionUUID->"973438ba-1412-4408-b374-152e28b017fa"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"e04242c9-8d7b-425e-91d1-e725fa6bb08f"],

Cell["TarskiStructure", "Item",ExpressionUUID->"37031f3f-9481-41e7-933f-c46d5a4fe5c0"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"9ad5f934-9ea8-4fff-b8fa-1318862d3ee2"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"3fa8b937-b55f-47f1-b074-03306285364b"],

Cell["MetricInterval", "Item",ExpressionUUID->"8fbb0cb9-d93f-40bc-a880-36cac771f6bb"]
},
