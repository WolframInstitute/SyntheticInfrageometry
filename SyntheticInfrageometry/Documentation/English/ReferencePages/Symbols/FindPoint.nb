Notebook[{
Cell["FindPoint", "Title",ExpressionUUID->"e6c9510e-8cbf-4879-97f1-dcb09da6bc27"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"2f8230cc-c320-4f40-a896-b97796f15582"],

Cell["\<\
FindPoint enumerates vertices, optionally filtered by a source / pool / \
distance constraint. Returns a List of unary InfraPoint[{v}] wrappers. \
Follows the strict / soft / exhaustive triple n_Integer | UpTo[n] | All. \
Options: \"From\" (All (default), \"Center\", \"Periphery\", origin -> dist), \
\"Distance\" (exactly d, or {dMin, dMax} with Infinity allowed), \"MaxCliques\
\".\
\>", "Text",ExpressionUUID->"70b890d9-a826-4356-addb-118570c8d8ed"],

Cell["Setup", "Section",ExpressionUUID->"f0fc97c3-56f6-489d-93cd-8080105d4860"],

