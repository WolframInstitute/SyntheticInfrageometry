Notebook[{

Cell[CellGroupData[{
Cell["FindPoint", "Title",ExpressionUUID->"c30a2cdc-1c6b-40ea-ad3e-878f31403078"],

Cell["\<\
FindPoint[graph, n] returns n vertices of graph wrapped as InfraPoint -- the \
existence postulate for points. Options \"From\" (\"Random\" | \"Center\" | \
\"Periphery\", a vertex, a vertex list, InfraPoint[...] for a multi-anchor \
pool, or origin -> dist for an anchor + distance restriction) and \
\"Distance\" (a number, {min, max} range, or \"Max\") restrict the candidate \
pool and impose mutual-separation constraints.\
\>", "Text",ExpressionUUID->"81f7fbae-fe01-4d55-8ee6-4957829a0a73"],

Cell[CellGroupData[{

Cell["Setup", "Section",ExpressionUUID->"9fbaf53d-36a7-4ab0-ae8d-7febc04c745e"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"3f8fb129-9ffa-4881-b807-8c0b978a048f"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",
 CellLabel->"In[67]:=",ExpressionUUID->"4a4b53bd-b576-4c17-8bcb-81a5180821ae"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Usage", "Section",ExpressionUUID->"b303d3e0-8c9d-429e-8a3b-f7810a7da3f7"],

Cell["Pick three vertices on a 5x5 grid.", "CodeText",ExpressionUUID->"dbd5e14d-0e77-4112-9253-854ff3eeae65"],

Cell[CellGroupData[{

Cell["FindPoint[GridGraph[{5, 5}], 3]", "Input",
 CellLabel->"In[68]:=",ExpressionUUID->"e0e268f9-e591-450f-844b-1eb52e686e03"],

Cell[BoxData[
 RowBox[{"InfraPoint", "[", 
  RowBox[{"{", 
   RowBox[{"23", ",", "20", ",", "12"}], "}"}], "]"}]], "Output",
 CellChangeTimes->{3.9869207172014837`*^9},
 CellLabel->"Out[68]=",ExpressionUUID->"5020a929-9f08-4e51-b208-5a22fec19b8c"]
}, Open  ]],

Cell["\<\
Render them as red dots on top of the graph drawing via InfraSceneHighlight.\
\>", "CodeText",ExpressionUUID->"071f390f-a2ea-4e10-9e8b-4131b73e9787"],

Cell[CellGroupData[{

Cell["\<\
With[{g = GridGraph[{5, 5}]}, InfraSceneHighlight[g, {FindPoint[g, 3] -> \
Red}]]\
\>", "Input",
 CellLabel->"In[69]:=",ExpressionUUID->"8b75dddb-e8b7-4069-8db6-4555b85ec24a"],

