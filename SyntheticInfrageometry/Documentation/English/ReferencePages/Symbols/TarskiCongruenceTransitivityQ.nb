Notebook[{
Cell["TarskiCongruenceTransitivityQ", "Title",ExpressionUUID->"3bab4915-e359-4986-bca7-eb25dea2e319"],

Cell["\<\
TarskiCongruenceTransitivityQ[graph] tests Tarski axiom A2: ab == pq and ab \
== rs implies pq == rs. A tautology of equality on distance values.\
\>", "Text",ExpressionUUID->"99bd779e-8ae8-454c-ac71-feae1623a1d2"],

Cell["Setup", "Section",ExpressionUUID->"a3950a29-e32f-4b19-939b-14038f0e1d7e"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"381ea2f3-c6fe-452a-916c-077ea9100ef4"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"b6f08305-802c-4f16-b8c2-0023a87184ea"],

Cell["Usage", "Section",ExpressionUUID->"795ec646-094e-40c2-b602-fbda96566556"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"3965f849-126b-40e6-8e42-66a0ce4d7a24"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceTransitivityQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"5c039835-8c40-4c61-b47e-eb43892fc150"],

