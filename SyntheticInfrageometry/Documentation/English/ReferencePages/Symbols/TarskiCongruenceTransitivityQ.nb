Notebook[{
Cell["TarskiCongruenceTransitivityQ", "Title",ExpressionUUID->"2a32b42c-a3d5-4734-8d69-c6fb64ce5443"],

Cell["\<\
TarskiCongruenceTransitivityQ[graph] tests Tarski axiom A2: ab == pq and ab \
== rs implies pq == rs. A tautology of equality on distance values.\
\>", "Text",ExpressionUUID->"2cec47d3-75d6-4515-bf01-eac0f4c5fc95"],

Cell["Setup", "Section",ExpressionUUID->"535861c1-454a-4588-b4b8-a29e2a5ccddd"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"39a8d18b-8f89-4422-a58d-a1d29baf1c63"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"aa5fcbeb-c1b0-490d-bca7-09b56d2b37ad"],

Cell["Usage", "Section",ExpressionUUID->"02a21044-4c6d-4ad2-8b63-a66f1c856331"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"245e5edc-3abd-4232-9809-117bbda95d79"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceTransitivityQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"90925fb9-6a58-469e-a233-0a6f21be01b0"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"e10e025a-f2b8-439c-9264-70083b388aaf"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceTransitivityQ", "[", 
  RowBox[{
  "tarskiSecondExample", "[", "\"\<TarskiCongruenceTransitivityQ\>\"", "]"}], 
  "]"}]], "Input",ExpressionUUID->"c77deb78-1ea7-4e83-adf9-14509cb500ac"],

Cell["Examples", "Section",ExpressionUUID->"ee810389-a50d-41fe-b8c5-ceb3723b0961"],

Cell["Compare with the dashboard entry.", "CodeText",ExpressionUUID->"5e0c6c09-dc0f-404b-941a-09d2ae66f810"],

Cell[BoxData[
 RowBox[{"TarskiAxiomQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"d61990b4-7582-4f7b-944e-6aad49f44663"],

Cell["Evaluate the predicate on a grid as a second check.", "CodeText",ExpressionUUID->"8d7cec01-4ad0-48f1-aff3-17b4b5a60edb"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceTransitivityQ", "[", 
  RowBox[{"GridGraph", "[", 
   RowBox[{"{", 
    RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"3d2cf163-3b01-48bc-b68c-0d79a90a6552"],

Cell["See also", "Section",ExpressionUUID->"b426e587-1168-4108-8a73-c9196051679e"],

Cell["BetweennessQ", "Item",ExpressionUUID->"f5196518-ecf8-403c-aed1-f389d7c55e83"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"7ba64f17-b0e1-4bbc-8258-7fd70ec17d88"],

Cell["TarskiStructure", "Item",ExpressionUUID->"9299c352-9ec6-41d4-aed1-e8c377d560f7"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"0f369328-4347-426d-8e95-fcf0286ac67d"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"21cf9ca6-07eb-4115-b80a-15f41ec32f24"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"06636be6-549f-4a86-8579-49ec3474e363"],

Cell["MetricInterval", "Item",ExpressionUUID->"cbd41179-f2b3-4290-b929-7b6a221e0844"]
},
