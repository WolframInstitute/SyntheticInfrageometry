Notebook[{
Cell["GeodesicMultiplicityMatrix", "Title",ExpressionUUID->"5415a296-e877-4e8b-940b-06b9280b8ebf"],

Cell["\<\
GeodesicMultiplicityMatrix[graph] returns the pair {D, M} where D is the \
distance matrix of graph and M[i, j] is the number of geodesics from vertex i \
to vertex j. The multiplicity counterpart of the metric.\
\>", "Text",ExpressionUUID->"d8180f42-a57d-45fb-846e-06e155962aef"],

Cell["Setup", "Section",ExpressionUUID->"d31e95c0-3d03-4aa9-afac-f5b5285835e3"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"d8a3f3fe-a851-4c79-b558-e75d17b331b6"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"62a72883-a216-4ea8-9f83-eb58518f9d6b"],

Cell["Usage", "Section",ExpressionUUID->"e53f8233-ef66-400f-9ca3-51479c54d549"],

Cell["Distance and multiplicity matrices of the cycle C_5.", "CodeText",ExpressionUUID->"960b3b7f-6298-4617-a4d1-b5a2a97e7296"],

Cell["GeodesicMultiplicityMatrix[CycleGraph[5]]", "Input",ExpressionUUID->"0c0f570a-8c93-46ae-8453-49cafd5af434"],

Cell["Same on a 3x3 grid.", "CodeText",ExpressionUUID->"c0bab6c8-257c-4ec1-928b-9fa1ddd10e4f"],

Cell["GeodesicMultiplicityMatrix[GridGraph[{3, 3}]]", "Input",ExpressionUUID->"0cd1966f-5dfd-47f8-a912-73d0a9191a00"],

Cell["Examples", "Section",ExpressionUUID->"22111d8e-5bf8-4f50-bc96-6152c7602bb6"],

Cell["Read off the global geodesic counts.", "CodeText",ExpressionUUID->"55ec8a00-7437-42ea-a8c1-5dafb3bd53cb"],

Cell["Last @ GeodesicMultiplicityMatrix[GridGraph[{4, 4}]]", "Input",ExpressionUUID->"f4bb41e9-5b33-444a-801a-a1b80fdb8ed9"],

Cell["See also", "Section",ExpressionUUID->"38b6cc99-ae19-4c77-b7c8-9723cc9599f9"],

Cell["GeodesicMultiplicity", "Item",ExpressionUUID->"833187a2-e44e-4541-85ba-2c2b3416da12"],

Cell["MetricInterval", "Item",ExpressionUUID->"030c984f-43b6-4f7e-8d18-5316d3f1af9a"],

Cell["MedianVertices", "Item",ExpressionUUID->"3f598016-b5a7-4031-81ca-468bc8f1b54f"]
},
