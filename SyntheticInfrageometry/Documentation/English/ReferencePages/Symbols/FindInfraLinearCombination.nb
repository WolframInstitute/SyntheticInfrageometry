Notebook[{
Cell["FindInfraLinearCombination", "Title",ExpressionUUID->"00ee8f72-8830-4f7f-8e15-e957a7e782f1"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"2d007646-918b-4cf6-a5a2-3baf5c24d6d4"],

Cell["\<\
FindInfraLinearCombination[g, o, {{lambda1, u1}, {lambda2, u2}, \[Ellipsis]}] \
returns the multi-valued vertex realisation of sum_i lambda_i u_i with base \
point o, computed as scaled-then-pairwise-summed left-to-right. Returns a \
List of unary InfraPoint[{v}] wrappers; n / UpTo[n] / All control \
multiplicity. Options: \"ScaleMethod\" (Automatic (default), \"Metric\", \
\"Line\", \"Midpoint\"); \"SumMethod\" (\"Metric\" (default), \"Parallel\").\
\>", "Text",ExpressionUUID->"12ef209f-195f-4eb7-a476-66c1667e2423"],

Cell["Setup", "Section",ExpressionUUID->"d83ecffc-2755-4011-b540-13dd9e398eb2"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"1dce1989-35d2-4c4e-ae40-45a579d579f5"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"9a11649d-f7e1-4354-82e6-60ce0a5b36dd"],

Cell["Examples", "Section",ExpressionUUID->"a8bb4d55-ff53-4382-aa7f-04732312ca58"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"7332fb9a-6297-4ff4-b8c2-8ed3a9bc5a30"],

Cell[BoxData[
 $CellContext`buildCell["Linear combination 2*u with base point o."]], "Input",\
ExpressionUUID->"f133ea09-68ca-4d74-9d38-b6a3496612f3"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"a86eacf3-ed1e-4adb-82e5-a1c1047bce4b"],

Cell[BoxData[
