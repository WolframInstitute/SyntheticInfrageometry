Notebook[{
Cell["FindInfraLinearCombination", "Title",ExpressionUUID->"9ce8914d-f900-4f40-b8a8-da2b1c00a1db"],

Cell["\<\
FindInfraLinearCombination[graph, o, {{lambda1, u1}, {lambda2, u2}, ...}] \
returns the multi-valued vertex realisation of sum_i lambda_i u_i with base \
point o, computed left-to-right by scaling each term and then pairwise \
summing. The fourth argument n / UpTo[n] / All controls multiplicity. \
Options: \"ScaleMethod\" (Automatic, \"Metric\", \"Line\", \"Midpoint\"); \
\"SumMethod\" (\"Metric\", \"Parallel\").\
\>", "Text",ExpressionUUID->"f165b527-23ae-498d-98c3-970ba406a658"],

Cell["Setup", "Section",ExpressionUUID->"0dafb298-7aca-409e-b076-e614dfe8ff6d"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"cc103fe3-8f94-4662-90bf-65522dbf1910"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"4b93339b-7604-4265-b307-2f99969714cc"],

Cell["Usage", "Section",ExpressionUUID->"9f1c1467-3c24-4b1b-a803-cb955d041c09"],

Cell["Realize 2 * u relative to base point o on a path graph.", "CodeText",ExpressionUUID->"93ff6433-c66e-457b-aae0-6311a71acb43"],

Cell["\<\
With[{g = PathGraph[Range[10]]}, FindInfraLinearCombination[g, 1, {{2, 3}}, \
All]]\
\>", "Input",ExpressionUUID->"66d98682-acd0-4abe-acfc-7031092d35d4"],

Cell["Sum two unit vectors u + v on a 5x5 grid.", "CodeText",ExpressionUUID->"7a829e73-fd3d-410d-9e36-1685e539a55c"],

Cell["\<\
With[{g = GridGraph[{5, 5}]}, FindInfraLinearCombination[g, 1, {{1, 2}, {1, \
6}}, All]]\
\>", "Input",ExpressionUUID->"980cb558-669b-45bb-a079-0e12e610c272"],

Cell["Examples", "Section",ExpressionUUID->"5f938752-9707-4018-87c8-f47a5d1e1061"],

Cell["Combine scaling and summation: u + (-1) v.", "CodeText",ExpressionUUID->"6dc10deb-ba54-454c-859b-da0cfa6ae02c"],

Cell["\<\
With[{g = GridGraph[{5, 5}]}, FindInfraLinearCombination[g, 13, {{1, 5}, {-1, \
21}}, All]]\
\>", "Input",ExpressionUUID->"6607af4c-f630-4407-8dfc-cc7be76de7a6"],

Cell["\<\
Switch to the line-based scaling rule for half-integer scalars.\
\>", "CodeText",ExpressionUUID->"016320e3-eea0-4ff3-9d83-1205dc85347f"],

Cell["\<\
With[{g = PathGraph[Range[10]]}, FindInfraLinearCombination[g, 1, {{1/2, 5}}, \
All, \"ScaleMethod\" -> \"Line\"]]\
\>", "Input",ExpressionUUID->"6b3faf62-8092-42c7-989f-4aaf18010111"],

Cell["See also", "Section",ExpressionUUID->"5f8de931-83b5-464a-a24f-b9027226b3b7"],

Cell["InfraScalarProduct", "Item",ExpressionUUID->"a0f7a1f9-f98a-48e4-864f-6b077a81d755"],

Cell["FindMidpoint", "Item",ExpressionUUID->"f9fe4f06-6923-4833-90f9-a0719bd2cdc8"],

Cell["ExtendSegment", "Item",ExpressionUUID->"e06eb67a-b30e-421c-8ffd-6168a6bda1ca"],

Cell["FindSegment", "Item",ExpressionUUID->"f358cff1-e42d-4ed9-aeb2-dc53afb2fc1c"],

Cell["FindParallel", "Item",ExpressionUUID->"7316b85d-f271-40b4-9ad9-bb33cd56a421"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
