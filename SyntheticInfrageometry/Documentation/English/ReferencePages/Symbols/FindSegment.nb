Cell["\<\
Switch the curvature engine to Wolfram-Ricci scalar with Pool -> \"AllPaths\" \
(full adjacency, paths simple but possibly detouring).\
\>", "CodeText",ExpressionUUID->"7c5bec5f-c1fc-4751-914d-a7e6b532dfb2"],

Cell[CellGroupData[{

Cell["\<\
With[{g = GridGraph[{4, 4}]}, InfraSceneHighlight[g, {FindSegment[g, 1, 16, \
All, Method -> {\"CurvatureMinimizing\", \"Curvature\" -> \"Wolfram\", \"Pool\
\" -> \"AllPaths\"}] -> Blue}]]\
\>", "Input",
 CellLabel->
  "In[101]:=",ExpressionUUID->"024ddfa1-b059-47da-93fa-47b089c6e1a7"],

