Notebook[{
Cell["FindSegment", "Title",ExpressionUUID->"d4a0dd4d-67b1-47b1-a7ab-16f568f962c5"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"9fb1fdc3-30de-4867-8ed1-33b02c1aaa87"],

Cell["\<\
FindSegment enumerates geodesic segments (and, with non-default Method, \
near-geodesic paths) between two vertices, returning a List of unary \
InfraSegment[{path}] wrappers. It follows the strict / soft / exhaustive \
triple n_Integer | UpTo[n] | All. Method (\"Shortest\" (default), \
\"ShortestPathExtension\", \"CurvatureMinimizing\", \"Embedding\") is shared \
with FindLine and ExtendSegment, with sub-options threaded through the method \
spec.\
\>", "Text",ExpressionUUID->"059d57dd-1826-41cd-ab44-a1938b326453"],

Cell["Setup", "Section",ExpressionUUID->"f1363183-cccb-4c12-8c7d-b516f31e4925"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"2dc92ad3-6a62-4d2e-a036-218cfa806d91"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"14203314-6b7d-4b81-83e9-25ed3b195faa"],

Cell["Examples", "Section",ExpressionUUID->"bbaff85c-bed1-4a5f-bd03-e834ac041ca1"],

