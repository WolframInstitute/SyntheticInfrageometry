Notebook[{

Cell[CellGroupData[{
Cell["FindSegment", "Title",ExpressionUUID->"882fb0e7-4c70-4207-8cd1-d0a8ed718c4b"],

Cell["\<\
FindSegment[graph, p1, p2] returns InfraSegment[{path}] containing the \
shortest path from p1 to p2. With an explicit count it returns multiple \
paths; the Method option enumerates non-geodesic alternatives -- \
\"ShortestPathExtension\" (recency-lex simple paths), \"CurvatureMinimizing\" \
(Forman / Wolfram Ricci-curvature pulled), and \"Embedding\" (graph-drawing \
aligned). Endpoints may be bare vertices or InfraPoint[...] wrappers; \
multi-realisation endpoints spread over the Cartesian product.\
\>", "Text",ExpressionUUID->"f97aeefe-8d03-4246-a553-993aab597a24"],

Cell[CellGroupData[{

Cell["Setup", "Section",ExpressionUUID->"5d33a440-092d-41e4-a3d1-208d578363ae"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"48ad7934-48e1-4b0e-9bc0-df420503af8f"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",
 CellLabel->"In[78]:=",ExpressionUUID->"c47d2aaa-1d92-437b-86bb-c5377fcfb075"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Usage", "Section",ExpressionUUID->"49c2bddc-a0d6-419c-8626-8bb7f8cc5c41"],

Cell["Find the shortest path between two corners of a grid.", "CodeText",ExpressionUUID->"12eb37a0-e1e7-4056-a054-8f56f3863090"],

