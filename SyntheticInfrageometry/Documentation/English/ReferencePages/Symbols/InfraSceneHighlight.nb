Notebook[{
Cell["InfraSceneHighlight", "Title",ExpressionUUID->"4b266bde-dd58-45c3-b664-941d096ca88a"],

Cell["\<\
InfraSceneHighlight[g, multiObjects] renders a list of multi-objects \
diffusely on a graph. Each multi-object is a list of representations (a \
vertex, vertex sequence, or vertex set); within one multi-object, vertex/edge \
intensity scales with how many representations pass through it. Across \
multi-objects, colors blend on shared vertices/edges. Entries may be plain \
(default cycling palette) or wrapped as `multiObj -> color`. Option \
\"Cyclic\" -> True | False | {bools} closes each path into a cycle \
(per-object when a list); \"OpacityRange\", \"ThicknessRange\", \
\"PointSizeRange\" tune the diffusion envelope.\
\>", "Text",ExpressionUUID->"fffc8868-7430-436e-8368-e8f0b2fae0d9"],

Cell["Setup", "Section",ExpressionUUID->"491d1f3c-9f0e-40ca-8642-5bd473891cc8"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"31a84b92-70b2-4aa9-a8f6-1d0aaa8544c4"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"a32089ae-0596-45e7-a56b-8cc1c48e83db"],

Cell["Usage", "Section",ExpressionUUID->"9aca08e3-9173-4000-a2cc-23ea7838e941"],

Cell["Render a geodesic bundle as one diffuse multi-object.", "CodeText",ExpressionUUID->"cd485499-21d3-4e7c-a4e3-3dc1e9d90ad7"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FindSegment", "[", 
        RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
       "Blue"}], "}"}]}], "]"}]}], "]"}]], "Input",ExpressionUUID->"845dc2bb-\
1813-441f-a2de-1f11c4a1f6c9"],

Cell["\<\
Render a segment cloud and a sphere cloud together, with per-object cyclic \
flags.\
\>", "CodeText",ExpressionUUID->"ee518621-d738-4720-b88a-313033f4b2fe"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"FindSegment", "[", 
         RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
        "Blue"}], ",", 
       RowBox[{
        RowBox[{"FindSphere", "[", 
         RowBox[{"g", ",", "6", ",", "2", ",", "All"}], "]"}], "\[Rule]", 
        "Green"}]}], "}"}], ",", 
     RowBox[{"\"\<Cyclic\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"False", ",", "True"}], "}"}]}]}], "]"}]}], "]"}]], "Input",Exp\
ressionUUID->"f65bb021-1d6f-4c5b-bb33-d9c2b9a0503d"],

Cell["Examples", "Section",ExpressionUUID->"b9974d6e-298f-4931-b908-4dd611e3cffa"],

Cell["Overlay a point pair on top of a segment cloud.", "CodeText",ExpressionUUID->"32ababc3-5c0a-46b8-8e19-23e558ec0590"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"FindSegment", "[", 
         RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
        "Blue"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "16"}], "}"}], "\[Rule]", "Red"}]}], "}"}]}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"e346d064-e79a-4904-a871-\
06722e41c407"],

Cell["Use the default palette by passing bare multi-objects.", "CodeText",ExpressionUUID->"2fdbb60f-c7e3-4260-a0fd-00a7c352f9e0"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FindSegment", "[", 
        RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], ",", 
       RowBox[{"FindSphere", "[", 
        RowBox[{"g", ",", "6", ",", "2", ",", "All"}], "]"}]}], "}"}], ",", 
     RowBox[{"\"\<Cyclic\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"False", ",", "True"}], "}"}]}]}], "]"}]}], "]"}]], "Input",Exp\
ressionUUID->"1b24f3cf-0c5b-454d-b362-6da2f514d8f6"],

Cell["See also", "Section",ExpressionUUID->"1d447ad4-cb80-40ad-b21b-864adc766baa"],

Cell["FindSegment", "Item",ExpressionUUID->"4e11806b-8cc7-4b69-81df-a3003c493997"],

Cell["FindSphere", "Item",ExpressionUUID->"6fe25f41-12c2-4867-881e-b743daa04349"],

Cell["CentralPaths", "Item",ExpressionUUID->"e70f5a6b-5e49-4370-b78d-de860041f6e0"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"c4ec1b1e-7082-478e-9c77-69f242a3d056"]
},
