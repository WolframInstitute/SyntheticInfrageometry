Cell["\<\
Render a segment cloud and a sphere cloud together, with per-object cyclic \
flags.\
\>", "CodeText",ExpressionUUID->"ee518621-d738-4720-b88a-313033f4b2fe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"FindSegment", "[", 
         RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
        "Blue"}], ",", 
       RowBox[{
        RowBox[{"FindSphere", "[", 
         RowBox[{"g", ",", "6", ",", "2", ",", "All"}], "]"}], "\[Rule]", 
        "Green"}]}], "}"}], ",", 
     RowBox[{"\"\<Cyclic\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"False", ",", "True"}], "}"}]}]}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[121]:=",ExpressionUUID->"f65bb021-1d6f-4c5b-bb33-d9c2b9a0503d"],

