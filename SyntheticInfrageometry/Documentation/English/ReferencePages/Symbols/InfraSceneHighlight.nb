Notebook[{
Cell["InfraSceneHighlight", "Title",ExpressionUUID->"bcc7938c-ff6a-466d-bcc4-77d9bdf95500"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"3f362e82-e911-407f-abfb-56b97c9d05ce"],

Cell["\<\
InfraSceneHighlight[g, multiObjects] renders a list of multi-objects \
diffusely on g, with intensity scaling by overlap within each object and \
colour-blending across objects. Each entry is auto-classified by \
representation; explicit Infra* wrappers force the intended semantics, and \
`entry -> color` overrides the default per-head colour. Options: \
\"OpacityRange\", \"ThicknessRange\", \"PointSizeRange\".\
\>", "Text",ExpressionUUID->"57d93b3b-387a-463c-a180-c08e7d795b42"],

Cell["Setup", "Section",ExpressionUUID->"31523e72-57b9-44d3-9f18-585ed3d39c30"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"b8a2602f-4b3c-40de-9527-170412239f88"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"e71e35b2-bcbb-4f79-8e47-6b358640ab53"],

Cell["Examples", "Section",ExpressionUUID->"ed730fc1-213f-4aaf-b7b0-5e18b56fe5b5"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"be42e5bc-5135-498a-86b5-1bd2b5b6ce97"],

Cell[BoxData[
 $CellContext`buildCell[
 "Render every geodesic between two grid corners."]], "Input",ExpressionUUID->\
"824e8e32-4379-494e-900c-0ee56b8a3a11"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"7ecf653d-c1b8-4d57-afd6-4d00a0aebeb5"],

Cell[BoxData[
 $CellContext`buildCell[
 "With[{g = GridGraph[{4, 4}]}, InfraSceneHighlight[g, {FindInfraSegment[g, 1, 16, \
All]}]]"]], "Input",ExpressionUUID->"57c27875-abb1-44b8-ab27-15137d721029"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"3592850b-10c2-4f49-81ff-c2502676c667"],

Cell[BoxData[
 $CellContext`buildCell[
 "Combine segment, shell, and circle layers."]], "Input",ExpressionUUID->\
"c35e793c-17ca-4315-a64b-d2364a358950"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"0fd1136d-28e8-40ca-b87b-516c7afd1236"],

Cell[BoxData[
 $CellContext`buildCell[
 "With[{g = GridGraph[{4, 4}]}, InfraSceneHighlight[g, {FindInfraSegment[g, 1, 16, \
All] -> Blue, FindInfraShell[g, 6, 2] -> LightBlue, FindInfraCircle[g, 6, 2, All] -> \
Green}]]"]], "Input",ExpressionUUID->"7e8bcb08-a81c-4839-a413-2a63b9ded6c2"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"c337e37d-2abf-4121-bf25-de8ba2802f3c"],

Cell[BoxData[
 $CellContext`buildCell["Custom opacity range."]], "Input",ExpressionUUID->"fbd36dd3-d2f9-4474-9dc9-2ce114a6f4dc"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"6a2d619c-8467-4857-a7a1-7bbd09994fab"],

Cell[BoxData[
 $CellContext`buildCell[
 "With[{g = GridGraph[{4, 4}]}, InfraSceneHighlight[g, {FindInfraSegment[g, 1, 16, \
All]}, \"OpacityRange\" -> {0.2, 0.9}]]"]], "Input",ExpressionUUID->"79050300-\
cd30-457b-b37c-2f22ddbf8e2b"],

