Notebook[{
Cell["InfraSceneHighlight", "Title",ExpressionUUID->"2580e310-6f59-4e21-8d29-18d663bfbd48"],

Cell["\<\
InfraSceneHighlight[g, multiObjects] renders a list of multi-objects \
diffusely on a graph. Each multi-object is a list of representations (a \
vertex, vertex sequence, or vertex set); within one multi-object, vertex/edge \
intensity scales with how many representations pass through it. Across \
multi-objects, colors blend on shared vertices/edges. Entries may be plain \
(default cycling palette) or wrapped as `multiObj -> color`. Option \
\"Cyclic\" -> True | False | {bools} closes each path into a cycle \
(per-object when a list); \"OpacityRange\", \"ThicknessRange\", \
\"PointSizeRange\" tune the diffusion envelope.\
\>", "Text",ExpressionUUID->"e6a0f88f-75bc-4b12-abfe-c8938c27b43e"],

Cell["Setup", "Section",ExpressionUUID->"c9ce06e1-82cc-4d20-ba4e-c71d3b33f1f4"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"ff5110a5-0909-4438-b09b-c8f815e443f8"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"6e5d9542-64ee-4f16-865d-edcf23301c16"],

Cell["Usage", "Section",ExpressionUUID->"0817888e-7bf7-40c4-a937-feb92e8cf407"],

Cell["Render a geodesic bundle as one diffuse multi-object.", "CodeText",ExpressionUUID->"abb9c52f-c13f-4226-8ad6-b6c80777416b"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FindSegment", "[", 
        RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
       "Blue"}], "}"}]}], "]"}]}], "]"}]], "Input",ExpressionUUID->"b412db43-\
68d4-43ec-aa3f-76fc47b3d21d"],

Cell["\<\
Render a segment cloud and a sphere cloud together, with per-object cyclic \
flags.\
\>", "CodeText",ExpressionUUID->"abe58e81-a6b9-4044-af94-353899ac743f"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"FindSegment", "[", 
         RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
        "Blue"}], ",", 
       RowBox[{
        RowBox[{"FindSphere", "[", 
         RowBox[{"g", ",", "6", ",", "2", ",", "All"}], "]"}], "\[Rule]", 
        "Green"}]}], "}"}], ",", 
     RowBox[{"\"\<Cyclic\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"False", ",", "True"}], "}"}]}]}], "]"}]}], "]"}]], "Input",Exp\
ressionUUID->"be2f9a46-5949-4be5-97d7-716df8eef441"],

Cell["Examples", "Section",ExpressionUUID->"4065ae10-18df-4e22-883b-5eb694dd554c"],

Cell["Overlay a point pair on top of a segment cloud.", "CodeText",ExpressionUUID->"be62ffc6-f3b2-4a3c-98b5-93623a7d9bea"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"FindSegment", "[", 
         RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
        "Blue"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "16"}], "}"}], "\[Rule]", "Red"}]}], "}"}]}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"a1442746-0d43-40c1-b15d-\
7a3f76cf652f"],

Cell["Use the default palette by passing bare multi-objects.", "CodeText",ExpressionUUID->"edd222b0-3ae1-4b63-86fc-633ae70ed7f1"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FindSegment", "[", 
        RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], ",", 
       RowBox[{"FindSphere", "[", 
        RowBox[{"g", ",", "6", ",", "2", ",", "All"}], "]"}]}], "}"}], ",", 
     RowBox[{"\"\<Cyclic\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"False", ",", "True"}], "}"}]}]}], "]"}]}], "]"}]], "Input",Exp\
ressionUUID->"017dd0a5-9fc1-46f5-908f-3df2b09d58f7"],

Cell["See also", "Section",ExpressionUUID->"139eb2f4-43e5-4135-9460-c7737362e7a6"],

Cell["FindSegment", "Item",ExpressionUUID->"00383a85-9f83-4de2-afd1-649b004c5a57"],

Cell["FindSphere", "Item",ExpressionUUID->"f5d617e7-8234-43d2-bc98-93de7b3d0b30"],

Cell["CentralPaths", "Item",ExpressionUUID->"32532dcd-8d3e-434d-87af-7dca05db2070"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"72103703-3710-4a27-9084-8c0419db9710"]
},
