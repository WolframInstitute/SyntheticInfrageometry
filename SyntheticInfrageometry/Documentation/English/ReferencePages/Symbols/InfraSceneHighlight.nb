Cell["Overlay a point pair on top of a segment cloud.", "CodeText",ExpressionUUID->"32ababc3-5c0a-46b8-8e19-23e558ec0590"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"FindSegment", "[", 
         RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "\[Rule]", 
        "Blue"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "16"}], "}"}], "\[Rule]", "Red"}]}], "}"}]}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"e346d064-e79a-4904-a871-\
06722e41c407"],

