Notebook[{
Cell["InfraRay", "Title",ExpressionUUID->"6786b0b4-2b05-4593-859f-4c94b11d0779"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"5557d82b-242f-40ed-9265-53be3b90c2c0"],

Cell["\<\
InfraRay is the wrapper head for pointed half-line realisations. \
InfraRay[{ray}] is the unary form; InfraRay[{ray1, \[Ellipsis], rayk}] is the \
multi-realisation form. Each ray is a vertex sequence {O, \[Ellipsis], w} \
with w an inextensible endpoint. FindInfraRay emits a List of unary \
InfraRay[{ray}] wrappers; the multi form is consumed by InfraSceneHighlight \
with sequential-edge semantics.\
\>", "Text",ExpressionUUID->"1bd8fa68-ac66-4cbe-b485-8e9990f6591a"],

Cell["Setup", "Section",ExpressionUUID->"752658f2-305c-4b56-a11d-dd2c9b2f51f6"],

