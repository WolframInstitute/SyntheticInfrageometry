Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"50f6f927-24a3-4a90-87d2-0e8535c52a05"],

