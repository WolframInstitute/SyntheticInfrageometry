Notebook[{
Cell["TarskiBetweennessTensor", "Title",ExpressionUUID->"c5cc4e40-b783-46c9-ac9d-a32629f8760a"],

Cell["\<\
TarskiBetweennessTensor[graph] returns the sparse rank-3 tensor whose nonzero \
positions are exactly the (i, j, k) with B(v_i, v_j, v_k).\
\>", "Text",ExpressionUUID->"b6897027-f478-4560-8f3b-8a78b0ea91b6"],

Cell["Setup", "Section",ExpressionUUID->"dac4a5db-47b5-4e6e-94dd-3df45fb8b7ad"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"264cf3e0-eda1-4a0c-a7e5-e81e2cb5712d"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"0d97582e-7d9e-4e4d-9993-20000bf80d65"],

Cell["Usage", "Section",ExpressionUUID->"91ac9f61-74fc-4bc9-bcb4-e04d1f554ca3"],

Cell["Inspect the tensor dimensions.", "CodeText",ExpressionUUID->"796c2465-a2e5-4cc6-b0bd-109c89a592a7"],

Cell[BoxData[
 RowBox[{"Dimensions", "[", 
  RowBox[{"TarskiBetweennessTensor", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], "]"}]], "Input",Expression\
UUID->"eabf4ea5-7811-4780-8aac-136a48866dd3"],

Cell["Probe one specific tensor entry.", "CodeText",ExpressionUUID->"cf29b9cb-1cf8-4fbe-9c4c-1133767c5b6b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TarskiBetweennessTensor", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], "\[LeftDoubleBracket]", 
  RowBox[{"1", ",", "3", ",", "5"}], "\[RightDoubleBracket]"}]], "Input",Expre\
ssionUUID->"a60c9b1c-7aec-46c3-ac35-3cded3f9245b"],

Cell["Examples", "Section",ExpressionUUID->"59fbf853-c2b8-4c87-ab30-de72ab4181cd"],

Cell["Count the nonzero positions in the sparse tensor.", "CodeText",ExpressionUUID->"ebe12182-be92-4660-a0f1-3d7e89d281a1"],

Cell[BoxData[
 RowBox[{"Length", "[", 
  RowBox[{
   RowBox[{"TarskiBetweennessTensor", "[", 
    RowBox[{"HypercubeGraph", "[", "3", "]"}], "]"}], 
   "[", "\"\<NonzeroPositions\>\"", "]"}], "]"}]], "Input",ExpressionUUID->\
"026bb387-defb-4feb-9566-a987c02f883c"],

Cell["\<\
Compare one tensor entry with BetweennessQ on the same triple.\
\>", "CodeText",ExpressionUUID->"d14337a4-4675-48be-9207-65fd4f5bea87"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"PathGraph", "[", 
      RowBox[{"Range", "[", "5", "]"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"TarskiBetweennessTensor", "[", "g", "]"}], "\[LeftDoubleBracket]", 
      RowBox[{"1", ",", "3", ",", "5"}], "\[RightDoubleBracket]"}], ",", 
     RowBox[{"BetweennessQ", "[", 
      RowBox[{"g", ",", "1", ",", "3", ",", "5"}], "]"}]}], "}"}]}], 
  "]"}]], "Input",ExpressionUUID->"5b7377b9-ae6d-4cc4-a837-bc360c0b5056"],

Cell["See also", "Section",ExpressionUUID->"1e44e6ac-80ac-429e-968a-9ed97d12332c"],

Cell["BetweennessQ", "Item",ExpressionUUID->"66d6b765-94cd-48a1-9263-ceedeb81a217"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"0cf2d3f1-bd91-464c-bbf2-7b62f02ec4ec"],

Cell["TarskiStructure", "Item",ExpressionUUID->"4d23fece-f1d5-41ba-ba6c-68623f0c17a5"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"ad2b4788-9fa1-4230-be50-7dcc4bdeab3f"],

Cell["FindMidpoint", "Item",ExpressionUUID->"90cb4340-e6dc-41e9-897e-699e23295c28"],

Cell["FindReflection", "Item",ExpressionUUID->"9ce4d54f-bdc7-4a6e-a384-cbb80f23a448"],

Cell["MetricInterval", "Item",ExpressionUUID->"25271152-8250-47d8-bfb1-895e34e26e67"]
},
