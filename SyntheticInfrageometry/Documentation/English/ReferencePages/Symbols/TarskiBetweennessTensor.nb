Notebook[{
Cell["TarskiBetweennessTensor", "Title",ExpressionUUID->"206bad52-c596-40d4-8ce7-edf94688a2e1"],

Cell["\<\
TarskiBetweennessTensor[graph] returns the sparse rank-3 tensor whose nonzero \
positions are exactly the (i, j, k) with B(v_i, v_j, v_k).\
\>", "Text",ExpressionUUID->"7e0bde9b-6f86-49f0-a79c-faa31ab447b3"],

Cell["Setup", "Section",ExpressionUUID->"f2fce21f-f176-4238-84a6-c3fd9e009403"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"1b155df0-91da-4481-a54a-5fee9131e826"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"a59cf1e6-ff3c-412f-8ad6-8fd31f928390"],

Cell["Usage", "Section",ExpressionUUID->"834dbc35-e711-4211-8aec-aa86b7603b6a"],

Cell["Inspect the tensor dimensions.", "CodeText",ExpressionUUID->"e8a35f16-645f-4994-b659-45ed4c5ad08e"],

Cell[BoxData[
 RowBox[{"Dimensions", "[", 
  RowBox[{"TarskiBetweennessTensor", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], "]"}]], "Input",Expression\
UUID->"3b8d8fbe-56ff-4f64-9a01-1339c1738947"],

Cell["Probe one specific tensor entry.", "CodeText",ExpressionUUID->"fc611d95-8cb9-4dfb-9be6-0dc675ec2f68"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TarskiBetweennessTensor", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], "\[LeftDoubleBracket]", 
  RowBox[{"1", ",", "3", ",", "5"}], "\[RightDoubleBracket]"}]], "Input",Expre\
ssionUUID->"5582d4ea-2efd-4374-a128-890674878059"],

Cell["Examples", "Section",ExpressionUUID->"53946b84-40fc-4efa-b48a-84d99b8cbc36"],

Cell["Count the nonzero positions in the sparse tensor.", "CodeText",ExpressionUUID->"7ccf3800-00d6-4503-b9af-5849650486a6"],

Cell[BoxData[
 RowBox[{"Length", "[", 
  RowBox[{
   RowBox[{"TarskiBetweennessTensor", "[", 
    RowBox[{"HypercubeGraph", "[", "3", "]"}], "]"}], 
   "[", "\"\<NonzeroPositions\>\"", "]"}], "]"}]], "Input",ExpressionUUID->\
"01c84e7e-396c-41ff-a75f-e81a65010430"],

Cell["\<\
Compare one tensor entry with BetweennessQ on the same triple.\
\>", "CodeText",ExpressionUUID->"6987f2ed-1aeb-4dd7-864e-726f9f5a3af8"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"PathGraph", "[", 
      RowBox[{"Range", "[", "5", "]"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"TarskiBetweennessTensor", "[", "g", "]"}], "\[LeftDoubleBracket]", 
      RowBox[{"1", ",", "3", ",", "5"}], "\[RightDoubleBracket]"}], ",", 
     RowBox[{"BetweennessQ", "[", 
      RowBox[{"g", ",", "1", ",", "3", ",", "5"}], "]"}]}], "}"}]}], 
  "]"}]], "Input",ExpressionUUID->"d68bc318-3003-4288-ac7c-545d7b1d2158"],

Cell["See also", "Section",ExpressionUUID->"2368d312-79e5-4d9b-9b54-86aba522fccd"],

Cell["BetweennessQ", "Item",ExpressionUUID->"d59e5bdc-4a3d-4289-b9de-ba46c10d358e"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"be508e35-f0b1-403e-9e5f-f8a1f12d18ec"],

Cell["TarskiStructure", "Item",ExpressionUUID->"861b71ff-adb2-4475-9cb8-a003739ca170"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"6d1d6137-d7ef-4d54-88e0-a21f264c0c09"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"93bab418-bda8-43d6-bb50-e8ed225fa6fd"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"f8225e69-b692-428f-9cd2-fbb4acada753"],

Cell["MetricInterval", "Item",ExpressionUUID->"9ab60d61-5e6c-469a-9a32-ee3706b68fd5"]
},
