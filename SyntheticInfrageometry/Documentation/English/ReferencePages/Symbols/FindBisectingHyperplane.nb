Cell[CellGroupData[{

Cell["Usage", "Section",ExpressionUUID->"9fc1717c-ffb6-435b-bc13-5990b645ab43"],

Cell["\<\
Find and visualize the bisecting hyperplane on the 4x4 grid between opposite \
corners (returns the antidiagonal cut).\
\>", "CodeText",ExpressionUUID->"3274904d-1fc5-4b79-91c4-c062c7a5194b"],

Cell[CellGroupData[{

Cell["\<\
With[{g = GridGraph[{4, 4}]}, InfraSceneHighlight[g, \
{InfraPoint[FindBisectingHyperplane[g, 1, 16][\"First\"]] -> Red, \
InfraPoint[{1, 16}] -> Blue}]]\
\>", "Input",
 CellLabel->
  "In[150]:=",ExpressionUUID->"647c681a-1019-4d36-8d4c-03dcd5abb851"],

