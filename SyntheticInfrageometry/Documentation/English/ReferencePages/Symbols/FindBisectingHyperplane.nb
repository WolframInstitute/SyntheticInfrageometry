Notebook[{
Cell["FindInfraBisectingHyperplane", "Title",ExpressionUUID->"632fb520-c324-4fe5-a130-e700653647d8"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"cea21dbe-08fa-4c40-88ba-699f6e6a181c"],

Cell["\<\
FindInfraBisectingHyperplane[g, p1, p2] returns the inclusion-minimal vertex \
subsets of the bisector { v : d(p1, v) == d(p2, v) } whose removal \
disconnects p1 from p2. Returns a List of unary InfraPlane[{set}] wrappers; n \
/ UpTo[n] / All control multiplicity. A positional {lo, hi} widens the \
bisector to lo \[LessEqual] d(p1, v) - d(p2, v) \[LessEqual] hi.\
\>", "Text",ExpressionUUID->"83c7647b-b463-496c-8ce3-869fb4ba256d"],

Cell["Setup", "Section",ExpressionUUID->"9cf55f01-3244-4d62-a19f-187c827986e0"],

