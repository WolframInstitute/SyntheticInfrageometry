Cell["\<\
Check that every returned hyperplane really separates the endpoints.\
\>", "CodeText",ExpressionUUID->"bce564aa-8736-41e8-99b7-3d03bf92604f"],

Cell[CellGroupData[{

Cell["\<\
With[{g = PathGraph[Range[5]], hs = \
FindBisectingHyperplane[PathGraph[Range[5]], 1, 5, All][\"Realisations\"]}, \
AllTrue[hs, h |-> SeparatesQ[g, h, 1, 5]]]\
\>", "Input",
 CellLabel->
  "In[157]:=",ExpressionUUID->"13430363-cfc2-4f8c-a37b-34bedb96d00a"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.986921614118058*^9},
 CellLabel->
