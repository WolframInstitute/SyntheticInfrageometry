Notebook[{
Cell["FindBisectingHyperplane", "Title",ExpressionUUID->"0b52b159-e92d-4668-b68b-74f229440a3c"],

Cell["\<\
FindBisectingHyperplane[graph, p1, p2] returns one inclusion-minimal subset \
of the bisector { v : d(p1, v) == d(p2, v) } whose removal disconnects p1 \
from p2 -- the graph analog of a perpendicular bisecting hyperplane. \
FindBisectingHyperplane[graph, p1, p2, n] returns exactly n or $Failed; \
UpTo[n] returns up to n; All returns every minimal hyperplane. \
FindBisectingHyperplane[graph, p1, p2, {lo, hi}, ...] widens the underlying \
bisector to vertices with lo <= d(p1, v) - d(p2, v) <= hi (use {-1, 1} to \
recover the parity-stranded middle pair when d(p1, p2) is odd). Accepts \
FindBisectingHyperplane[graph, {p1, p2}, ...] equivalently.\
\>", "Text",ExpressionUUID->"43d10b86-8f9f-4621-bbcc-b2b418542f82"],

Cell["Setup", "Section",ExpressionUUID->"5c6fbe98-0269-4683-b161-7d7dd7d11d27"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"5a066ae2-ed86-4b33-b988-74e1ad70c4ef"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"8ef2fe8d-6f93-45ce-9bc5-958ca64127d1"],

Cell["Usage", "Section",ExpressionUUID->"fabeefc0-9293-44c1-aa96-0d1d978d7479"],

Cell["Find the unique minimal separator on an odd-length path.", "CodeText",ExpressionUUID->"10c07f55-050c-4e98-ba17-008eeccd67d7"],

Cell[BoxData[
 RowBox[{"FindBisectingHyperplane", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "5"}], 
  "]"}]], "Input",ExpressionUUID->"1c95e7bf-01e3-4ed1-9feb-f8a86d0f3b5e"],

Cell["\<\
Widen the bisector window on an even path to recover parity-stranded cuts.\
\>", "CodeText",ExpressionUUID->"c7f625bb-874e-4970-9fa9-f528e79bdc92"],

Cell[BoxData[
 RowBox[{"FindBisectingHyperplane", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "6", "]"}], "]"}], ",", "1", ",", "6", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "All"}], "]"}]], "Input",Expr\
essionUUID->"83227116-62ef-4963-b886-74d0b6e3232a"],

Cell["Examples", "Section",ExpressionUUID->"7aaf51b8-ceba-45b8-a5eb-43b18230f9de"],

Cell["\<\
Inspect the grid antidiagonal separator between opposite corners.\
\>", "CodeText",ExpressionUUID->"68825476-3623-47f2-9d77-e16857a0c360"],

Cell[BoxData[
 RowBox[{"FindBisectingHyperplane", "[", 
  RowBox[{
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"3", ",", "3"}], "}"}], "]"}], ",", "1", ",", "9", ",", "All"}], 
  "]"}]], "Input",ExpressionUUID->"2b1e6d5f-87f5-4847-9def-a3cdf2a9083d"],

Cell["\<\
Check that every returned hyperplane really separates the endpoints.\
\>", "CodeText",ExpressionUUID->"204f13ec-9793-42d4-b382-83bc01d936ec"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"g", "=", 
      RowBox[{"PathGraph", "[", 
       RowBox[{"Range", "[", "5", "]"}], "]"}]}], ",", 
     RowBox[{"hs", "=", 
      RowBox[{"FindBisectingHyperplane", "[", 
       RowBox[{
        RowBox[{"PathGraph", "[", 
         RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "5", ",", 
        "All"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"AllTrue", "[", 
    RowBox[{"hs", ",", 
     RowBox[{"Function", "[", 
      RowBox[{"h", ",", 
       RowBox[{"SeparatesQ", "[", 
        RowBox[{"g", ",", "h", ",", "1", ",", "5"}], "]"}]}], "]"}]}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"ff0ea6f4-7630-4bf8-ab58-\
811d33154edb"],

Cell["See also", "Section",ExpressionUUID->"60015ae4-41bf-4d51-a86a-f0a9a500467c"],

Cell["FindMidpoint", "Item",ExpressionUUID->"db399e22-04cc-4266-90e5-e93be788bc3d"],

Cell["SeparatesQ", "Item",ExpressionUUID->"f6bb620b-b7c8-4a82-9113-7c3ee8e18a8f"],

Cell["FindSphere", "Item",ExpressionUUID->"b1f39c2a-e4bc-4cea-97e7-becf2733773a"],

Cell["MetricInterval", "Item",ExpressionUUID->"b7f3affc-2970-4de1-b1a5-6bb25da09a18"]
},
