Notebook[{
Cell["TarskiEuclidAxiomQ", "Title",ExpressionUUID->"8212892e-43de-4841-a3ae-1a1ad652ee0d"],

Cell["\<\
TarskiEuclidAxiomQ[graph] tests Tarski axiom A10 (Euclid's parallel-axiom \
variant). Iteration-1 stub: returns Indeterminate and emits \
TarskiEuclidAxiomQ::nyi.\
\>", "Text",ExpressionUUID->"93611534-3fde-4413-849b-1baf41326ae5"],

Cell["Setup", "Section",ExpressionUUID->"0a97edef-5e64-4a00-9e2f-c049a28ca2e3"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"5277d140-3994-4a82-9185-88ca4f452d80"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"6f990804-286e-4a1d-952b-886e47c6cfae"],

Cell["Usage", "Section",ExpressionUUID->"8895120f-acc0-4e09-b5d5-881c3f3d3aa9"],

Cell["Evaluate the current iteration-1 stub on a path graph.", "CodeText",ExpressionUUID->"015d3c39-867b-40f6-ae5d-279f572cfa22"],

Cell[BoxData[
 RowBox[{"Quiet", "[", 
  RowBox[{"TarskiEuclidAxiomQ", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], "]"}]], "Input",Expression\
UUID->"c33eed71-eb5b-4ea5-be03-b8ae1b606985"],

Cell["Evaluate the same stub on a grid.", "CodeText",ExpressionUUID->"814820d8-b689-4883-b92d-47d295ba873b"],

Cell[BoxData[
 RowBox[{"Quiet", "[", 
  RowBox[{"TarskiEuclidAxiomQ", "[", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}], "]"}]], "Input",ExpressionU\
UID->"a130a124-c0a0-4d84-b0fe-9af7e978f49b"],

Cell["Examples", "Section",ExpressionUUID->"bfe8a7e5-1aef-48bb-a6e6-36bc7ee6be9a"],

Cell["The dashboard also reports Indeterminate for Euclid.", "CodeText",ExpressionUUID->"126d9508-378e-489c-8a08-565b055fc9c7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TarskiAxiomQ", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], "[", "\"\<Euclid\>\"", 
  "]"}]], "Input",ExpressionUUID->"1ac41e89-4f14-4061-8275-51d5d8de851a"],

Cell["Suppress the informational message while exploring.", "CodeText",ExpressionUUID->"319b341c-fd59-4953-bcc6-446f5a960f80"],

Cell[BoxData[
 RowBox[{"Quiet", "[", 
  RowBox[{"TarskiEuclidAxiomQ", "[", 
   RowBox[{"CycleGraph", "[", "6", "]"}], "]"}], "]"}]], "Input",ExpressionUUI\
D->"8f5ce01f-bb36-4d4f-a8b0-a0dfc818fbad"],

Cell["See also", "Section",ExpressionUUID->"1e14ec1c-41b8-4655-bd13-ab449c6e4bbe"],

Cell["BetweennessQ", "Item",ExpressionUUID->"03d3e86b-2ff9-4ae8-af41-243cbd576a24"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"51b94e80-3efb-4b0b-ba32-0ffde35a06eb"],

Cell["TarskiStructure", "Item",ExpressionUUID->"49b0b978-c0ea-4f42-b81e-5bf187f27e6e"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"390a46a2-d048-4ad8-88ec-d8a1ff50e17f"],

