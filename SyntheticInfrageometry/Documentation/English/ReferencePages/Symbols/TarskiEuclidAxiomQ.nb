Notebook[{
Cell["TarskiEuclidAxiomQ", "Title",ExpressionUUID->"da3b59c4-6702-4b0b-b313-98073fc72395"],

Cell["\<\
TarskiEuclidAxiomQ[graph] tests Tarski axiom A10 (Euclid's parallel-axiom \
variant). Iteration-1 stub: returns Indeterminate and emits \
TarskiEuclidAxiomQ::nyi.\
\>", "Text",ExpressionUUID->"dd0cf572-c0ad-44c4-a237-abe32e188143"],

Cell["Setup", "Section",ExpressionUUID->"042c6e25-ecc2-443d-9da8-7057c3aab0d8"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"b67fbfb3-c98b-43e0-ad69-8a5a36413ee5"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"7bde82b2-526b-4cf6-a9da-7d8f8ee405d6"],

Cell["Usage", "Section",ExpressionUUID->"9f41eed1-c3a0-401c-a5a7-f6415a1c3e2d"],

Cell["Evaluate the current iteration-1 stub on a path graph.", "CodeText",ExpressionUUID->"e406090a-6e8a-429f-ae8b-fa3913909842"],

Cell[BoxData[
 RowBox[{"Quiet", "[", 
  RowBox[{"TarskiEuclidAxiomQ", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], "]"}]], "Input",Expression\
UUID->"cf4eac7f-f269-4a70-9f84-901294fc6b0d"],

Cell["Evaluate the same stub on a grid.", "CodeText",ExpressionUUID->"20fa4a27-d09a-43bd-97d4-de874a5dd958"],

Cell[BoxData[
 RowBox[{"Quiet", "[", 
  RowBox[{"TarskiEuclidAxiomQ", "[", 
   RowBox[{"GridGraph", "[", 
    RowBox[{"{", 
     RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}], "]"}]], "Input",ExpressionU\
UID->"51d0fa83-fbb6-4727-a371-b1a281f333c8"],

Cell["Examples", "Section",ExpressionUUID->"88f27ed3-7049-41d9-b4c4-657c08f2ee0c"],

Cell["The dashboard also reports Indeterminate for Euclid.", "CodeText",ExpressionUUID->"c12f35f6-7685-41d1-9caa-fff374d51ab5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TarskiAxiomQ", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], "[", "\"\<Euclid\>\"", 
  "]"}]], "Input",ExpressionUUID->"8d4a541d-3239-4e39-a045-f5371d1771c5"],

Cell["Suppress the informational message while exploring.", "CodeText",ExpressionUUID->"9646df53-b47a-4672-9667-b0ad3e9f9d21"],

Cell[BoxData[
 RowBox[{"Quiet", "[", 
  RowBox[{"TarskiEuclidAxiomQ", "[", 
   RowBox[{"CycleGraph", "[", "6", "]"}], "]"}], "]"}]], "Input",ExpressionUUI\
D->"5dc8f8c0-aab4-4575-a27e-d627fa8eff88"],

Cell["See also", "Section",ExpressionUUID->"b3b46b38-83d9-446c-8e27-9aa2a4f3ca51"],

Cell["BetweennessQ", "Item",ExpressionUUID->"e2657f82-b6c1-4fac-8d42-c75d193d5e75"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"de35dda8-bb54-4e64-ac4c-5d6759d9e80c"],

