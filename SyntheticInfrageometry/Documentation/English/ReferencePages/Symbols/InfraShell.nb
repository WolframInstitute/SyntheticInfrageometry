Notebook[{
Cell["InfraShell", "Title",ExpressionUUID->"e058990d-332d-44c6-a6b7-8ff137982bc0"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"ef667ca6-c9d5-421d-94cb-7cb25359741e"],

Cell["\<\
InfraShell is the wrapper head for metric-shell vertex sets. \
InfraShell[{set}] is the unary form; InfraShell[{set1, \[Ellipsis], setk}] is \
the multi-realisation form. FindInfraShell emits a List of unary InfraShell[{set}] \
wrappers. Wrapping that List with InfraShell @ \[Ellipsis] collapses it to \
the multi form via auto-flatten; InfraSceneHighlight consumes the multi form \
with induced-subgraph semantics.\
\>", "Text",ExpressionUUID->"f70bd8b0-516d-43d2-a733-a88c4c7fc0d1"],

Cell["Setup", "Section",ExpressionUUID->"08bc2def-dd1c-4c0d-a0ae-ba04477a6e07"],

