Notebook[{
Cell["EmbeddingClosestCycles", "Title",ExpressionUUID->"0cda7b01-552d-44a0-bdb6-48f09171a201"],

Cell["\<\
EmbeddingClosestCycles[graph, cycles, {center, radius}] keeps the cycles \
whose drawing under GraphEmbedding is closest (in plane Hausdorff distance) \
to the Euclidean circle of given centre and radius. Operator form \
EmbeddingClosestCycles[graph, {center, radius}][cycles].\
\>", "Text",ExpressionUUID->"037b1c01-28b9-43b7-9b34-fc8218a4e999"],

Cell["Setup", "Section",ExpressionUUID->"01e21813-d44e-49db-8307-4ac3f6ba2f7f"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"7e9eec18-34c0-4c2f-baf8-4603ddc62051"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"20d447db-8cad-485a-b950-d6ea931531cd"],

Cell["Usage", "Section",ExpressionUUID->"4f7afd92-7871-43dc-838f-9c06d0dc06f8"],

Cell["\<\
Keep the cycles closest to a Euclidean circle in the embedding.\
\>", "CodeText",ExpressionUUID->"7097ef85-5bb9-4e13-81ef-6b6fed0b7199"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"EmbeddingClosestCycles", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSphere", "[", 
      RowBox[{"g", ",", "6", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
       RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"6", ",", "1.5`"}], "}"}]}], "]"}]}], "]"}]], "Input",Expression\
UUID->"59e2157d-05cd-4390-9cbe-faacff7ec066"],

Cell["Use the operator form for piping.", "CodeText",ExpressionUUID->"3b8acdc3-66af-4025-83c4-e459d6a81c95"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"EmbeddingClosestCycles", "[", 
     RowBox[{"g", ",", 
      RowBox[{"{", 
       RowBox[{"6", ",", "1.5`"}], "}"}]}], "]"}], "[", 
    RowBox[{"FindSphere", "[", 
     RowBox[{"g", ",", "6", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
      RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"c5b20e4c-43a7-45c6-a2f3-\
9cca54cf25fd"],

Cell["Examples", "Section",ExpressionUUID->"d1782fcf-16d4-48b5-8421-a03565975d49"],

Cell["Compose circumference filtering with embedding closeness.", "CodeText",ExpressionUUID->"cf0d0025-00ed-4504-8b79-fdc43344c0d3"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"EmbeddingClosestCycles", "[", 
     RowBox[{"g", ",", 
      RowBox[{"{", 
       RowBox[{"6", ",", "1.5`"}], "}"}]}], "]"}], "[", 
    RowBox[{"ShortestCircumferenceCycles", "[", 
     RowBox[{"FindSphere", "[", 
      RowBox[{"g", ",", "6", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
       RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], 
     "]"}], "]"}]}], "]"}]], "Input",ExpressionUUID->"5f5ed8b9-3ffc-4f4d-b0a3-\
3a3b1383715b"],

Cell["Render the most circle-like separating cycles.", "CodeText",ExpressionUUID->"6ec10e68-9e34-43bd-a104-9d8dc643a68e"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"EmbeddingClosestCycles", "[", 
        RowBox[{"g", ",", 
         RowBox[{"FindSphere", "[", 
          RowBox[{"g", ",", "6", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
           RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"6", ",", "1.5`"}], "}"}]}], "]"}], "\[Rule]", "Green"}], 
      "}"}], ",", 
     RowBox[{"\"\<Cyclic\>\"", "\[Rule]", "True"}]}], "]"}]}], "]"}]], "Input",\
ExpressionUUID->"389b12ef-4fee-4652-b7ba-6d2b7de5ddb8"],

Cell["See also", "Section",ExpressionUUID->"5f5f5688-b638-4097-8c2e-adebdb6d0e14"],

Cell["FindSegment", "Item",ExpressionUUID->"55e35a14-f31f-4ec7-a1e2-6e72f8a0a390"],

Cell["FindLine", "Item",ExpressionUUID->"17e6f94c-cc60-4ec9-8d3f-0a2d0d59c034"],

Cell["FindSphere", "Item",ExpressionUUID->"a4b84a57-ca8b-4df3-991f-351b8b0b1d31"],

Cell["CentralPaths", "Item",ExpressionUUID->"cdd734ee-ce2b-4398-80cb-9e45e3027a87"],

Cell["CentralCycles", "Item",ExpressionUUID->"e8121f01-0f4d-4089-84cf-af2a1d2a4e82"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"cf9d05a4-1e40-4f3f-ac39-f6a9ce5276fb"]
},
