Notebook[{
Cell["EmbeddingClosest", "Title",ExpressionUUID->"c24d2fc4-3e45-41f1-8e90-c8be953a874d"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"f000bdb1-2927-43cb-b24c-e0c86210285e"],

Cell["\<\
EmbeddingClosest[g, cycles, {center, radius}] keeps the cycles whose \
drawing under GraphEmbedding is Hausdorff-closest to the Euclidean circle of \
given centre and radius. Operator form EmbeddingClosest[g, {center, \
radius}][cycles].\
\>", "Text",ExpressionUUID->"506a4a14-6594-4f81-a824-ddbb96f1b427"],

