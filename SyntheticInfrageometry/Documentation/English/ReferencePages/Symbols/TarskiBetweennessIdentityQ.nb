Notebook[{
Cell["TarskiBetweennessIdentityQ", "Title",ExpressionUUID->"ff7cd3a8-c98e-4c5f-a3b1-7147765292fb"],

Cell["\<\
TarskiBetweennessIdentityQ[graph] tests Tarski axiom A6: B(a, b, a) implies a \
== b. Always True on connected simple graphs.\
\>", "Text",ExpressionUUID->"d6584143-576f-47b3-86eb-2316ff6f8105"],

Cell["Setup", "Section",ExpressionUUID->"f3d52d9d-223b-402b-8dd2-31eff8c3030b"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"cdb2874a-5e94-4052-a4f6-637521f5f069"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"437c9920-633b-4d3b-8b67-0114b706c088"],

Cell["Usage", "Section",ExpressionUUID->"e1a7d65b-c360-4c62-8799-ffca76bb344d"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"01eb8c70-ea03-4877-a2ac-8b1f713a0186"],

Cell[BoxData[
 RowBox[{"TarskiBetweennessIdentityQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"5406c2d2-46af-43e9-91af-bdd347b82ebe"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"0fc5f50e-1278-4e7e-a5fc-8add93c470f1"],

Cell[BoxData[
 RowBox[{"TarskiBetweennessIdentityQ", "[", 
  RowBox[{"Graph", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"Null", ",", 
      RowBox[{"SparseArray", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{"6", ",", "6"}], "}"}], ",", "0", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "0", ",", "2", ",", "4", ",", "6", ",", "8", ",", "10", ",", 
              "12"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "5", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "5", "}"}]}], "}"}]}], "}"}], ",", "Pattern"}], 
         "}"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"GraphLayout", "\[Rule]", "\"\<CircularEmbedding\>\""}], "}"}]}],
    "]"}], "]"}]], "Input",ExpressionUUID->"1a79bbb0-841e-473c-817a-\
714b35e7bd97"],

Cell["Examples", "Section",ExpressionUUID->"98748728-2d14-4d76-9b25-82930a548044"],

Cell["Compare with the dashboard entry.", "CodeText",ExpressionUUID->"1dd0d534-dd51-4e28-9168-1031de8c804e"],

Cell[BoxData[
 RowBox[{"TarskiAxiomQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"b7983f46-4907-4aad-81b1-49cad88e26bb"],

Cell["Evaluate the predicate on a grid as a second check.", "CodeText",ExpressionUUID->"59679e76-2c5c-4fd3-ba48-ba363b38e2cf"],

Cell[BoxData[
 RowBox[{"TarskiBetweennessIdentityQ", "[", 
  RowBox[{"GridGraph", "[", 
   RowBox[{"{", 
    RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"cdb7a75e-41ce-4521-9349-7756d3833c0a"],

Cell["See also", "Section",ExpressionUUID->"54729029-bdf2-4ad9-8364-bf702115ddb7"],

