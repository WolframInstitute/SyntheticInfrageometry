Notebook[{
Cell["FindTarskiReflection", "Title",ExpressionUUID->"e9334ef6-9244-4fc1-87e4-f7764207549d"],

Cell["\<\
FindTarskiReflection[graph, x, a] returns one vertex x' with B(x, a, x') and \
ax == ax' -- the reflection of x through a in Tarski's primitives. \
FindTarskiReflection[graph, x, a, n] returns exactly n or $Failed; UpTo[n] \
returns up to n; All returns all candidates.\
\>", "Text",ExpressionUUID->"95de6c85-5e10-4fad-ac48-ed21cae874f0"],

Cell["Setup", "Section",ExpressionUUID->"881b5da8-0759-45d5-b738-94718d685a06"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"004bfa19-a8c0-4d51-b546-a8612a271b36"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"c0ceb5e8-7708-47e8-9c26-d0387e19c143"],

Cell["Usage", "Section",ExpressionUUID->"fa885abd-11bc-4146-9eef-fda87df0504f"],

Cell["Reflect a point through another point on a path.", "CodeText",ExpressionUUID->"324ceaae-2b90-40a8-9adc-d20c40acf95f"],

Cell[BoxData[
 RowBox[{"FindTarskiReflection", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "3", ",", "All"}],
   "]"}]], "Input",ExpressionUUID->"0b2f6558-eaab-4dda-8494-f3744f9e2794"],

Cell["See a multi-valued reflection on the cube.", "CodeText",ExpressionUUID->"e3ff0ca9-c16c-45ea-8dcd-c22d4b082f88"],

Cell[BoxData[
 RowBox[{"FindTarskiReflection", "[", 
  RowBox[{
   RowBox[{"HypercubeGraph", "[", "3", "]"}], ",", "1", ",", "2", ",", 
   "All"}], "]"}]], "Input",ExpressionUUID->"98256576-9769-4490-9356-\
ddc42ef04cdc"],

Cell["Examples", "Section",ExpressionUUID->"b8972d37-0d82-4b84-abf4-040ff40cbf55"],

Cell["Ask for only one reflected point when several exist.", "CodeText",ExpressionUUID->"ae1fee22-444f-4480-8e0f-60b290544167"],

Cell[BoxData[
 RowBox[{"FindTarskiReflection", "[", 
  RowBox[{
   RowBox[{"HypercubeGraph", "[", "3", "]"}], ",", "1", ",", "2", ",", 
   RowBox[{"UpTo", "[", "1", "]"}]}], "]"}]], "Input",ExpressionUUID->\
"5b10510d-5d8c-45d7-bfa7-696feaaa2f5a"],

Cell["Watch the strict form fail when the graph has no room.", "CodeText",ExpressionUUID->"47d9a463-43fd-4a4e-bfc1-ae51b5231a59"],

Cell[BoxData[
 RowBox[{"FindTarskiReflection", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "4"}], 
  "]"}]], "Input",ExpressionUUID->"c52a04c6-fa8d-4428-a795-eabe2a0c03c0"],

Cell["See also", "Section",ExpressionUUID->"f2152c40-a1a6-4c8a-8518-d911739bd70d"],

Cell["BetweennessQ", "Item",ExpressionUUID->"533d8f0b-c799-4815-a380-7de9d9d1c744"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"f9ff436e-0205-440f-b144-5c6b58a35fc6"],

Cell["TarskiStructure", "Item",ExpressionUUID->"3279ae20-9658-4b3f-be43-5071030a365e"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"64b73be7-bae4-4881-aa5d-33c5a8920b67"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"38ce1ae7-0a5f-43b4-9278-8df7ca5a954c"],

Cell["MetricInterval", "Item",ExpressionUUID->"93db130e-4069-4615-ba4c-74a4678d2422"]
},
