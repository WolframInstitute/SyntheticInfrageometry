Notebook[{
Cell["FindTarskiReflection", "Title",ExpressionUUID->"d6b5afcf-dffe-4d42-bb02-d17a4993044e"],

Cell["\<\
FindTarskiReflection[graph, x, a] returns one vertex x' with B(x, a, x') and \
ax == ax' -- the reflection of x through a in Tarski's primitives. \
FindTarskiReflection[graph, x, a, n] returns exactly n or $Failed; UpTo[n] \
returns up to n; All returns all candidates.\
\>", "Text",ExpressionUUID->"f4362843-f1f2-473b-b260-b441ad420e28"],

Cell["Setup", "Section",ExpressionUUID->"be8c2ead-3421-4e02-9b9a-6fbe171c642a"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"1ef5e416-75b5-4a30-86f7-e1c99f91ac2d"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"e85b05a7-37ac-462b-a747-fba73f48d1b7"],

Cell["Usage", "Section",ExpressionUUID->"64accb99-6bd8-43f7-a456-1ebd4a25b0b6"],

Cell["Reflect a point through another point on a path.", "CodeText",ExpressionUUID->"91ef50c2-b3b5-4fcc-8d3f-14af62bee293"],

Cell[BoxData[
 RowBox[{"FindTarskiReflection", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "3", ",", "All"}],
   "]"}]], "Input",ExpressionUUID->"d1ad8ae5-21ff-4d8a-a1cb-547791babad5"],

Cell["See a multi-valued reflection on the cube.", "CodeText",ExpressionUUID->"dd3b69de-1d50-47ed-96d3-104db85b2c22"],

Cell[BoxData[
 RowBox[{"FindTarskiReflection", "[", 
  RowBox[{
   RowBox[{"HypercubeGraph", "[", "3", "]"}], ",", "1", ",", "2", ",", 
   "All"}], "]"}]], "Input",ExpressionUUID->"4672fce9-77db-4b2b-bcbb-\
d1f70f0d809b"],

Cell["Examples", "Section",ExpressionUUID->"3a95695a-da24-474c-8b5a-6b1332731429"],

Cell["Ask for only one reflected point when several exist.", "CodeText",ExpressionUUID->"5908bf5a-b281-4192-9603-9d6c9e73c818"],

Cell[BoxData[
 RowBox[{"FindTarskiReflection", "[", 
  RowBox[{
   RowBox[{"HypercubeGraph", "[", "3", "]"}], ",", "1", ",", "2", ",", 
   RowBox[{"UpTo", "[", "1", "]"}]}], "]"}]], "Input",ExpressionUUID->\
"7f02f3fc-f02d-4a33-bc04-5159935c90c7"],

Cell["Watch the strict form fail when the graph has no room.", "CodeText",ExpressionUUID->"65e5aace-be04-4215-9d6c-5add46b245fb"],

Cell[BoxData[
 RowBox[{"FindTarskiReflection", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "4"}], 
  "]"}]], "Input",ExpressionUUID->"04e109ea-7d52-4079-85f8-724ec86f92d6"],

Cell["See also", "Section",ExpressionUUID->"12b04f4f-9cd3-401d-924c-baf9deb65751"],

Cell["BetweennessQ", "Item",ExpressionUUID->"a4f82c66-7d4b-44ee-8949-f06f9c45bc12"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"b4746a79-cf42-4805-be2e-a1a701a12b42"],

Cell["TarskiStructure", "Item",ExpressionUUID->"0be13f27-ae95-44d1-85ea-a4b492d5f5ae"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"d5b7d215-53d6-4cb9-b2d0-cae331d14134"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"b76f7246-9b5c-4ad8-890c-3ee6dfd4593d"],

Cell["MetricInterval", "Item",ExpressionUUID->"0ba2c37b-5448-499c-96fe-b9a54c326511"]
},
