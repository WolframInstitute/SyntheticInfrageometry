Notebook[{
Cell["TarskiLowerDimensionQ", "Title",ExpressionUUID->"7ff798f9-a6d8-479a-a6ad-12697e10bb7d"],

Cell["\<\
TarskiLowerDimensionQ[graph] tests Tarski axiom A8: there exist three \
non-collinear points. Uses the projective CollinearQ (maximal-geodesic \
version).\
\>", "Text",ExpressionUUID->"49ddaad5-87f5-45ce-8d2c-32974c31f937"],

Cell["Setup", "Section",ExpressionUUID->"d799ae70-986d-478c-b02e-8cb317e38712"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"f1f00319-32ab-432c-8364-1b3b15f0f5bf"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"23a95eed-d632-42d5-a80e-ec248ebe5534"],

Cell["Usage", "Section",ExpressionUUID->"bb1a8a9c-f2c0-4e19-93c6-fedcf2d4e15f"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"d7c5732d-9400-454b-864b-06934c903432"],

Cell[BoxData[
 RowBox[{"TarskiLowerDimensionQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"7113afe3-1cfb-4eda-a3d5-f2cb1596f9d2"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"c0826d4a-d747-4832-a21f-b91f1f55335b"],

Cell[BoxData[
 RowBox[{"TarskiLowerDimensionQ", "[", 
  RowBox[{"Graph", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"Null", ",", 
      RowBox[{"SparseArray", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{"6", ",", "6"}], "}"}], ",", "0", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "0", ",", "2", ",", "4", ",", "6", ",", "8", ",", "10", ",", 
              "12"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "5", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "6", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "5", "}"}]}], "}"}]}], "}"}], ",", "Pattern"}], 
         "}"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"GraphLayout", "\[Rule]", "\"\<CircularEmbedding\>\""}], "}"}]}],
    "]"}], "]"}]], "Input",ExpressionUUID->"3ae5f2da-c127-4ea0-bb79-\
aacf69200bb6"],

Cell["Examples", "Section",ExpressionUUID->"b20f0d8e-2458-4445-97b4-4a0ca3a5609c"],

Cell["Compare with the dashboard entry.", "CodeText",ExpressionUUID->"127b0c4c-c790-4aae-a6e2-e90a5570a208"],

Cell[BoxData[
 RowBox[{"TarskiAxiomQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"55de6dcc-1682-4a83-b4e6-cac8d667aafe"],

Cell["Evaluate the predicate on a grid as a second check.", "CodeText",ExpressionUUID->"24a6f14a-7c2a-40c3-ba87-b76b09fffa00"],

Cell[BoxData[
 RowBox[{"TarskiLowerDimensionQ", "[", 
  RowBox[{"GridGraph", "[", 
   RowBox[{"{", 
    RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"136999cf-0dd3-4bb3-9e8e-df44ae340d44"],

Cell["See also", "Section",ExpressionUUID->"39b75895-222f-4d5d-8fc5-d7a0f63ebca4"],

Cell["BetweennessQ", "Item",ExpressionUUID->"883f9c44-fd53-4234-acf3-27672a89d000"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"dfdb8ead-f8e6-4771-99f5-d3c7e34ba42d"],

Cell["TarskiStructure", "Item",ExpressionUUID->"9f43c29f-99aa-4e57-ab9b-2c6cd1a9f043"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"0a60edde-b700-412e-b237-73610727b159"],

Cell["FindMidpoint", "Item",ExpressionUUID->"d21f93a4-41e2-41fc-80f3-3adaa1c3c536"],

Cell["FindReflection", "Item",ExpressionUUID->"5442499d-cd04-438b-9daa-cf46fc2429f5"],

Cell["MetricInterval", "Item",ExpressionUUID->"dbe95001-ded3-4bd7-9b74-02577bbe3f3c"]
},
