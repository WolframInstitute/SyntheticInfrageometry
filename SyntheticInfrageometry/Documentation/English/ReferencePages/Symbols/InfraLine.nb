Notebook[{
Cell["InfraLine", "Title",ExpressionUUID->"8272fee4-e341-4ec1-922f-d13134d2f2a5"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"d470bf55-62c4-4ee0-aea5-c550ee174b74"],

Cell["\<\
InfraLine[p, q] represents maximal geodesic extensions through p and q in the \
scene language. InfraLine[path] extends a given path. Multi-realisations are \
returned as InfraSegment[{\[Ellipsis]}] (the only path-shaped wrapper).\
\>", "Text",ExpressionUUID->"3b56d5ea-6989-4431-b4dc-7689ab03a72f"],

