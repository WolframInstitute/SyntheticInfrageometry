Cell["PathSubgraph", "Title",ExpressionUUID->"2546f7d9-4ae3-4247-91ad-f4d8875f6c45"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"56654340-93b6-49b5-821a-45bd21082b6d"],

Cell["\<\
PathSubgraph[g, u, v] returns the union of all shortest u-v paths. \
PathSubgraph[g, u, v, k] (or UpTo[k]) caps path length; PathSubgraph[g, u, v, \
All] returns the full simple-path subgraph. Option \"Directed\".\
\>", "Text",ExpressionUUID->"1c8b766c-ab9a-4dd3-a11b-9730d7816477"],

