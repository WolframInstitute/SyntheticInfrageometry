Notebook[{
Cell["FindInfraParallel", "Title",ExpressionUUID->"0d7544e4-a379-4cd4-9995-820377a03cab"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"77311dc3-6884-4907-a2e4-7c69917035f8"],

Cell["\<\
FindInfraParallel[g, line, p] returns the maximal geodesics through p whose \
distance to line is constant (graph-intrinsic parallels). Returns a List of \
unary InfraSegment[{line}] wrappers or $Failed; n / UpTo[n] / All control \
multiplicity. Option Method (\"Metric\" (default) | \"Embedding\").\
\>", "Text",ExpressionUUID->"914d1756-afdd-46bb-80d5-a4cfb18a6b6d"],

Cell["Setup", "Section",ExpressionUUID->"d9b7e6cf-268f-44ae-9040-40a8d9753617"],

