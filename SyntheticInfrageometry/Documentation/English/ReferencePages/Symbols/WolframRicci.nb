Cell["\<\
Color vertices by curvature value -- boundary vertices have the most extreme \
values, the bulk is roughly flat.\
\>", "CodeText",ExpressionUUID->"8cbe8188-a8bf-4a7b-a67a-ca29af01c5cb"],

Cell[CellGroupData[{

Cell["\<\
With[{g = GridGraph[{6, 6}], ric = WolframRicci[GridGraph[{6, 6}], \
\"Dimension\" -> 2]}, Graph[g, VertexStyle -> KeyValueMap[#1 -> \
ColorData[\"TemperatureMap\"][Rescale[#2, MinMax @ Values @ ric]] &, ric], \
VertexSize -> Medium]]\
\>", "Input",
 CellLabel->
  "In[107]:=",ExpressionUUID->"9dbd00ea-ab39-4139-b249-86b7ee806308"],

