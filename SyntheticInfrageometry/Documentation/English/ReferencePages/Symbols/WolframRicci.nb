Cell["\<\
Wolfram-Ricci on the Petersen graph (3-regular, vertex-transitive: every \
vertex has the same scalar).\
\>", "CodeText",ExpressionUUID->"638d7397-9e5b-4bbd-9b09-6138e1fa964c"],

Cell[CellGroupData[{

Cell["\<\
