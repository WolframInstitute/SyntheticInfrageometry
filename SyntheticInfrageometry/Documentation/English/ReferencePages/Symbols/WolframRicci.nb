Notebook[{

Cell[CellGroupData[{
Cell["WolframRicci", "Title",ExpressionUUID->"a67b788f-3dc8-432e-85a0-397b81b60dc0"],

Cell["\<\
WolframRicci[graph] returns an Association of vertices to volume-comparison \
Ricci scalar values, averaged over a per-vertex eccentricity-capped radius \
window. WolframRicci[graph, {rmin, rmax}] uses an explicit radius range; \
WolframRicci[graph, r] uses a single radius. Option \"Dimension\" -> \
Automatic | d sets the comparison dimension. Used as a curvature engine for \
FindSegment / FindLine / ExtendSegment under Method -> \
\"CurvatureMinimizing\".\
\>", "Text",ExpressionUUID->"549ad15e-154a-428b-b04d-884876e7fd96"],

Cell[CellGroupData[{

Cell["Setup", "Section",ExpressionUUID->"a7bbc1b3-67ba-4142-afb0-6702bc645538"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"0c22c41e-3276-43c2-a03d-1c8c54afad5c"],

