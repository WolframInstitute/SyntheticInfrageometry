Notebook[{
Cell["TarskiSegmentConstructionQ", "Title",ExpressionUUID->"eaf364c1-09f6-4427-924b-68ee6c33cd58"],

Cell["\<\
TarskiSegmentConstructionQ[graph] tests Tarski axiom A4: for all a, b, c, d \
there is x with B(a, b, x) and bx == cd. Generally False on finite graphs.\
\>", "Text",ExpressionUUID->"ddd4e92e-cf2d-471d-8293-5d273ea34cbe"],

Cell["Setup", "Section",ExpressionUUID->"dfddb4c2-2017-4ad8-b59d-8d952ef2972c"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"4fc1e4f0-57f7-47bf-85ff-3965b3c3a1ca"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"2244dc51-989a-429e-88c9-af6c117c7f5c"],

Cell["Usage", "Section",ExpressionUUID->"caf611dd-7a9b-4db9-a0fc-70128e8eee46"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"2747aa51-f57a-47d3-94a8-ba9ef0325d00"],

Cell[BoxData[
 RowBox[{"TarskiSegmentConstructionQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"cf433f4b-13aa-4e48-938a-118b82ed10b3"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"52433246-b5fd-45c6-bdf3-b824d4b54488"],

Cell[BoxData[
 RowBox[{"TarskiSegmentConstructionQ", "[", 
  RowBox[{"Graph", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"Null", ",", 
      RowBox[{"SparseArray", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{"4", ",", "4"}], "}"}], ",", "0", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "3", ",", "6", ",", "9", ",", "12"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "3", "}"}]}], "}"}]}], "}"}], ",", "Pattern"}], 
         "}"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"GraphLayout", "\[Rule]", "\"\<StarEmbedding\>\""}], "}"}]}], 
   "]"}], "]"}]], "Input",ExpressionUUID->"ba303ec7-2950-414d-94dd-\
0e1a7d5f2912"],

Cell["Examples", "Section",ExpressionUUID->"9198f879-f343-410e-b66b-22610bea55ac"],

Cell["Pair the Boolean result with a concrete witness search.", "CodeText",ExpressionUUID->"3f27ec4a-4e03-42af-bee7-fb673826cfc4"],

Cell[BoxData[
 RowBox[{"FindTarskiCounterexample", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", 
   "TarskiSegmentConstructionQ", ",", 
   RowBox[{"UpTo", "[", "1", "]"}]}], "]"}]], "Input",ExpressionUUID->\
"40705f87-e08f-4edb-a07e-2ca57c86c313"],

Cell["Read the dashboard entry for A4.", "CodeText",ExpressionUUID->"2973cf81-289c-46eb-aeae-e999460c3386"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TarskiAxiomQ", "[", 
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}], 
  "[", "\"\<SegmentConstruction\>\"", "]"}]], "Input",ExpressionUUID->\
"e21e0e2c-3a0a-45ee-9838-05957d818024"],

Cell["See also", "Section",ExpressionUUID->"866b16a5-5e0c-46cf-9eac-37961a73f29d"],

Cell["BetweennessQ", "Item",ExpressionUUID->"a83207d5-ee37-48bf-86f5-64badbf8ba42"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"6f4f8439-39e0-4b4a-b92f-9808c574173b"],

