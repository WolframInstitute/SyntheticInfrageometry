Notebook[{
Cell["InfraCurvature", "Title",ExpressionUUID->"2f02f095-ab95-4fbd-948e-c34ca9b545f3"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"ae83c13d-e74c-4b8a-96b7-0735bbfc5f98"],

Cell["\<\
InfraCurvature[g, v] returns the local Alexandrov upper-curvature bound at v: \
L^2 times the supremum of per-triangle CAT bounds over all triangles whose \
three vertices sit inside B_L(v), with L = GraphDiameter[g] by default. \
Option \"Radius\" (Automatic | Integer L) selects the ball radius; reported \
curvature is rescaled by L^2 to match the (edge / L)^-2 unit convention. \
InfraCurvature[g] returns an Association v -> kappa_v over all vertices.\
\>", "Text",ExpressionUUID->"dcb4005a-7639-4aa9-9bed-eab31fa13fc9"],

Cell["Setup", "Section",ExpressionUUID->"b74e4f69-ccd9-4514-af89-47a6bec054d3"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"1ade6834-58b8-435a-9486-a33502ce49e7"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"94869ee2-7901-45c8-8dd3-7aeff56ea669"],

