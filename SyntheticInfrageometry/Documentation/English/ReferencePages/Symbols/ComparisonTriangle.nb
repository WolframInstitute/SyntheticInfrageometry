Notebook[{
Cell["ComparisonTriangle", "Title",ExpressionUUID->"b2940c1e-5a99-492e-8d7a-945684125048"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"ae89671e-dfe7-448b-ac69-d268b2d588e2"],

Cell["\<\
ComparisonTriangle[a, b, c] returns the Wolfram Triangle in R^2 with side \
lengths {a, b, c}. ComparisonTriangle[a, b, c, \"Curvature\" -> k] for k \
\[NotEqual] 0 returns InfraComparisonTriangle in M_k^2. ComparisonTriangle[g, \
p, q, r, \"Curvature\" -> k] reads the side lengths from g.\
\>", "Text",ExpressionUUID->"dab84e31-fc12-4231-8c5c-006581cc380f"],

Cell["Setup", "Section",ExpressionUUID->"dc7960c5-7c12-4d16-8823-ee3ae7f35965"],

