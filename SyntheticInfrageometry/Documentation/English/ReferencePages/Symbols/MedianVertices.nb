Notebook[{
Cell["MedianVertices", "Title",ExpressionUUID->"caec7edf-3b7c-4b8d-bdd0-b6ac8334ca45"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"4e76f37a-f57a-498b-8676-00a33613805e"],

Cell["\<\
MedianVertices[g, vs] returns the vertices minimising the sum of distances to \
vs. A graph is a median graph iff every triple has a unique median.\
\>", "Text",ExpressionUUID->"8c95a45d-460d-4f0e-8bba-2bc902420d95"],

