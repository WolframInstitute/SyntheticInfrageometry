Notebook[{
Cell["FindTarskiCounterexample", "Title",ExpressionUUID->"ee6bb69f-3d42-43a1-a13a-f3f962fe508a"],

Cell["\<\
FindTarskiCounterexample[graph, predQ] returns one vertex tuple witnessing \
the failure of the Tarski axiom predQ on graph, or $Failed. predQ is one of \
TarskiCongruenceIdentityQ, TarskiSegmentConstructionQ, TarskiFiveSegmentsQ, \
TarskiBetweennessIdentityQ, TarskiInnerPaschQ, TarskiLowerDimensionQ, \
TarskiUpperDimensionQ. The calling triple n / UpTo[n] / All caps the witness \
count. Returns $Failed for the always-True axioms and for TarskiContinuityQ \
(whose failure has no finite vertex-tuple witness).\
\>", "Text",ExpressionUUID->"3053bd48-9575-4232-aabe-6927de6aac0f"],

Cell["Setup", "Section",ExpressionUUID->"34e3460c-ff09-462d-b08a-eb5c77c83b87"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"7e48825d-c5ad-405c-96d8-cda4ad2ffcbe"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"c6508dea-419d-45c9-aa3a-f2faf1724207"],

Cell["Usage", "Section",ExpressionUUID->"009d3a25-9d1b-4447-8232-294cf7da3a37"],

Cell["Find a witness that A4 fails on a finite path.", "CodeText",ExpressionUUID->"136bb95c-2d4a-45c8-9852-10318da4ac83"],

Cell[BoxData[
 RowBox[{"FindTarskiCounterexample", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", 
   "TarskiSegmentConstructionQ", ",", 
   RowBox[{"UpTo", "[", "2", "]"}]}], "]"}]], "Input",ExpressionUUID->\
"ebd6a297-7732-439a-9915-a716962a84f9"],

Cell["Find an Inner Pasch counterexample on the Petersen graph.", "CodeText",ExpressionUUID->"c7fe1fcb-e8a3-44cd-816f-8bb704a688b2"],

Cell[BoxData[
 RowBox[{"FindTarskiCounterexample", "[", 
  RowBox[{
   RowBox[{"PetersenGraph", "[", "]"}], ",", "TarskiInnerPaschQ", ",", 
   RowBox[{"UpTo", "[", "1", "]"}]}], "]"}]], "Input",ExpressionUUID->\
"aa54b03a-4298-4ca7-a45e-e9cb6cd34316"],

Cell["Examples", "Section",ExpressionUUID->"41bc616f-cb2f-430a-8b28-d16113763cdf"],

Cell["Always-true axioms return no witness list.", "CodeText",ExpressionUUID->"ddf4789c-d66c-4097-af48-4e95ddab55a9"],

Cell[BoxData[
 RowBox[{"FindTarskiCounterexample", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", 
   "TarskiCongruenceReflexivityQ", ",", "All"}], "]"}]], "Input",ExpressionUUI\
D->"ead9a3d8-c82a-4594-a869-ae1f59890800"],

Cell["Continuity has no finite witness and returns $Failed.", "CodeText",ExpressionUUID->"ac23048c-694a-426d-889a-d75b2a68d934"],

Cell[BoxData[
 RowBox[{"Quiet", "[", 
  RowBox[{"FindTarskiCounterexample", "[", 
   RowBox[{
    RowBox[{"GridGraph", "[", 
     RowBox[{"{", 
      RowBox[{"3", ",", "3"}], "}"}], "]"}], ",", "TarskiContinuityQ", ",", 
    "All"}], "]"}], "]"}]], "Input",ExpressionUUID->"d9132dd6-79d5-4d03-ad5c-\
b556571806c7"],

Cell["See also", "Section",ExpressionUUID->"028499b0-ef01-449b-b7cf-5712c81fc184"],

Cell["BetweennessQ", "Item",ExpressionUUID->"13a93ad3-00c6-4b05-82c8-46cc94103584"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"9cebae3d-bfca-402b-909a-21162e251a12"],

Cell["TarskiStructure", "Item",ExpressionUUID->"565dd67f-4100-4d75-9cbc-98375be21428"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"83bebfb0-bfb7-4e0f-916e-61882ae95fe8"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"dfe8bb91-b306-478e-ac6f-fb41e53231b3"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"27a97e42-eed8-4473-b600-4d075133f978"],

Cell["MetricInterval", "Item",ExpressionUUID->"ed7704ce-4505-493c-b746-01a102d0eaa8"]
},
