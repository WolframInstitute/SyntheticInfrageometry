Notebook[{
Cell["FindTarskiCounterexample", "Title",ExpressionUUID->"f4bd17d2-0f95-461d-8252-bb905d323078"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"5b249d33-3a9a-4897-b1cb-17ce560325d5"],

Cell["\<\
FindTarskiCounterexample[g, predQ] returns one vertex tuple witnessing the \
failure of the Tarski axiom predicate predQ, or $Failed. With n / UpTo[n] / \
All caps the witness count. Returns $Failed for always-True axioms and for \
TarskiContinuityQ.\
\>", "Text",ExpressionUUID->"1b168051-0c54-4ec3-baab-55b10e8f1e69"],

