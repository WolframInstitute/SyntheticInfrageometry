Notebook[{
Cell["PunchHole", "Title",ExpressionUUID->"c3028cd3-48f3-49f8-afc7-271e82f64d45"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"62082ab5-f4c1-419c-853e-dfaff86d6193"],

Cell["\<\
PunchHole[g, r] removes the closed r-ball around a random vertex. \
PunchHole[g, c -> r] removes the closed r-ball around vertex c. For multiple \
holes, Fold[PunchHole, g, list].\
\>", "Text",ExpressionUUID->"9fb6b6f4-ece3-4554-8a10-6bb35e17273a"],

Cell["Setup", "Section",ExpressionUUID->"b3b06ece-edd6-4069-9737-16052fc086fd"],

