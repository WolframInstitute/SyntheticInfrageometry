Notebook[{
Cell["PeripheralCycles", "Title",ExpressionUUID->"d6ab5342-533d-4ea0-ae64-7708ad75e336"],

Cell["\<\
PeripheralCycles[graph, cycles] keeps the cycles whose maximum path-space \
distance to the rest of the bundle is maximal, with cyclic rotations factored \
out. Same Method options and operator form as PeripheralPaths.\
\>", "Text",ExpressionUUID->"d89eadd8-5b75-451b-a6cf-70340edbf059"],

Cell["Setup", "Section",ExpressionUUID->"91a83ac9-5c31-4e8c-948c-0093b869abf5"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"9927d089-de3a-4653-82f3-b72648083709"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"41a17200-9c3d-43dd-a3cd-c94786145e74"],

Cell["Usage", "Section",ExpressionUUID->"c60aeb1b-21ed-478a-becf-d57541ae28b8"],

Cell["Pick the eccentric cycles in a separating-cycle bundle.", "CodeText",ExpressionUUID->"44d8ccad-d6c2-48ec-99e4-74a150e6680a"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"PeripheralCycles", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSphere", "[", 
      RowBox[{"g", ",", "6", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
       RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}]}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"ef275941-a3bb-4959-b540-\
d2b8cf04f4e9"],

Cell["Use the operator form after FindSphere.", "CodeText",ExpressionUUID->"448a88f8-7d37-4660-b280-1e32e59973f5"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"PeripheralCycles", "[", "g", "]"}], "[", 
    RowBox[{"FindSphere", "[", 
     RowBox[{"g", ",", "6", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
      RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"154d1e49-0cfe-479f-84d4-\
b674533ef28b"],

Cell["Examples", "Section",ExpressionUUID->"8f438675-8e20-4b9a-b13b-355c672d3d00"],

Cell["Use the MeanFrechet metric on cycles.", "CodeText",ExpressionUUID->"9e75c7bc-d3a7-4651-980c-2256f4b44575"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"PeripheralCycles", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSphere", "[", 
      RowBox[{"g", ",", "6", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
       RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], ",", 
     RowBox[{"Method", "\[Rule]", "\"\<MeanFrechet\>\""}]}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"41a7c9b7-b06a-476f-a73e-cfef3ba40992"],

Cell["Compare the cycle bundle size before and after filtering.", "CodeText",ExpressionUUID->"fc1f1182-2d29-482b-8de1-6e6840666385"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"g", "=", 
      RowBox[{"GridGraph", "[", 
       RowBox[{"{", 
        RowBox[{"4", ",", "4"}], "}"}], "]"}]}], ",", 
     RowBox[{"cycles", "=", 
      RowBox[{"FindSphere", "[", 
       RowBox[{"g", ",", "6", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
        RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}]}]}],
     "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Length", "[", "cycles", "]"}], ",", 
     RowBox[{"Length", "[", 
      RowBox[{"PeripheralCycles", "[", 
       RowBox[{"g", ",", "cycles"}], "]"}], "]"}]}], "}"}]}], "]"}]], "Input",\
ExpressionUUID->"886de7dd-5d4a-4545-801e-efc8e6082f01"],

Cell["See also", "Section",ExpressionUUID->"73c04b1f-fcf4-499f-b827-1396c560943d"],

Cell["FindSegment", "Item",ExpressionUUID->"ecf017fe-e1f2-491f-a074-55c9f0bb41d6"],

Cell["FindLine", "Item",ExpressionUUID->"4e1b0259-3ead-4771-9774-ff441366896c"],

Cell["FindSphere", "Item",ExpressionUUID->"a08a4a53-0698-42e6-876d-5d4b409a81df"],

Cell["CentralPaths", "Item",ExpressionUUID->"34f2e45e-6799-417a-9d3f-fecbc97462ed"],

Cell["CentralCycles", "Item",ExpressionUUID->"59d2922d-434b-469d-8022-4a111ecf0ee4"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"cb6194a1-610f-4fc6-b151-5c271461a09b"],

Cell["EmbeddingClosestCycles", "Item",ExpressionUUID->"266dac57-2e8b-4236-871f-c13bd48ca96d"]
},
