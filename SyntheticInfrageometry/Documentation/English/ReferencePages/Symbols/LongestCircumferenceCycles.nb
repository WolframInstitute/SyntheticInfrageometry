Notebook[{
Cell["LongestCircumferenceCycles", "Title",ExpressionUUID->"fb38e2f9-59e0-4ad1-adb2-472f7d5cddd2"],

Cell["\<\
LongestCircumferenceCycles[cycles] keeps the cycles whose vertex count \
(circumference) is maximal in the bundle. \
LongestCircumferenceCycles[InfraCircle[cycles]] returns InfraCircle of the \
result. Used after FindCircle to keep only the largest separating cycles.\
\>", "Text",ExpressionUUID->"4af30a40-2306-4509-999f-5eacbac2c164"],

Cell["Setup", "Section",ExpressionUUID->"a6e058dc-6e79-4ada-aee7-94dabe2ad013"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"5d3968ee-fab7-48fb-a1af-1eb09986aa15"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"41aa1ad2-a100-4276-8b76-9f396ff53996"],

Cell["Usage", "Section",ExpressionUUID->"cf71d058-be24-48ac-a63d-eff7f0300359"],

Cell["Keep only the longest separating cycles.", "CodeText",ExpressionUUID->"a1a63db7-4346-49d7-9171-439f6b11ea99"],

Cell["\<\
With[{g = GridGraph[{4, 4}]}, LongestCircumferenceCycles @ FindCircle[g, 6, \
{1, 2}, All]]\
\>", "Input",ExpressionUUID->"58df83cc-d812-4323-8a60-108e3ee0a659"],

Cell["Render the longest-circumference cycles.", "CodeText",ExpressionUUID->"2ddf9eb5-fb54-43e8-9bd8-bcf5e8da8ee2"],

Cell["\<\
With[{g = GridGraph[{4, 4}]}, InfraSceneHighlight[g, \
{LongestCircumferenceCycles @ FindCircle[g, 6, {1, 2}, All] -> Blue, \
InfraPoint[{6}] -> Red}]]\
\>", "Input",ExpressionUUID->"8f6c5abf-ce5b-4db3-a7ae-132ee06ea23a"],

Cell["Examples", "Section",ExpressionUUID->"b14ec88c-b646-4bfe-bcd0-de3fa1db60ce"],

Cell["\<\
On the Petersen graph one center yields multiple 5-cycles -- \
LongestCircumferenceCycles keeps the longest of them.\
\>", "CodeText",ExpressionUUID->"a9344cbe-3914-4bbd-be36-5c2318ae30cc"],

Cell["\<\
With[{g = PetersenGraph[]}, InfraSceneHighlight[g, \
{LongestCircumferenceCycles @ FindCircle[g, 1, {1, 2}, All] -> Blue, \
InfraPoint[{1}] -> Red}]]\
\>", "Input",ExpressionUUID->"2d3d0d2b-14fa-4a06-ada6-1ed17c9fc346"],

Cell["See also", "Section",ExpressionUUID->"4a56b3df-8133-4070-b0fa-5ddab9760aff"],

Cell["ShortestCircumferenceCycles", "Item",ExpressionUUID->"60803aab-4c82-4bb9-8dcc-ae90f9f404c5"],

Cell["CentralCycles", "Item",ExpressionUUID->"cc8c10e0-aa8c-49b7-a103-27cc738a2ce4"],

Cell["FindCircle", "Item",ExpressionUUID->"81953468-93d7-4bf8-b367-06b5e9b99ab3"],

Cell["InfraSceneHighlight", "Item",ExpressionUUID->"b518e88a-4c00-4ec8-a039-ad253692ad1f"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
