Notebook[{
Cell["LongestCircumferenceCycles", "Title",ExpressionUUID->"d745cfc3-0cf9-4f14-962f-a0f9d893284c"],

Cell["\<\
LongestCircumferenceCycles[cycles] keeps the cycles of maximum length. Pure \
list operation, no graph required.\
\>", "Text",ExpressionUUID->"538875ec-753a-4566-9c96-f4f678d6a75c"],

Cell["Setup", "Section",ExpressionUUID->"e8de4030-130a-4eff-82a1-0ba2a34dddd2"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"a84394fd-30d7-4a77-aba7-2f0f4d3d3bba"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"5ae46029-8245-4c3f-bd3b-79838f987ea9"],

Cell["Usage", "Section",ExpressionUUID->"ec35fc7d-0be4-4dec-a4af-85687197b9cf"],

Cell["Keep the longest cycles in a list.", "CodeText",ExpressionUUID->"b9badfe2-88e8-49eb-8e71-15ce0fee11f3"],

Cell[BoxData[
 RowBox[{"LongestCircumferenceCycles", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"4", ",", "5", ",", "6"}], "}"}]}], "}"}], "]"}]], "Input",Expres\
sionUUID->"8fd61da2-82a7-4179-b2c2-6b4dedac8cfe"],

Cell["Apply the filter to a separating-cycle bundle.", "CodeText",ExpressionUUID->"ad7befa3-cec1-4652-872d-cbd2b898a4c7"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"LongestCircumferenceCycles", "[", 
    RowBox[{"FindSphere", "[", 
     RowBox[{"g", ",", "6", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
      RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"87629849-651c-491f-b2dd-\
2e9f049153f4"],

Cell["Examples", "Section",ExpressionUUID->"a346efd4-7ebc-4a16-9846-50eb8718b06b"],

Cell["Compose the filter with embedding closeness.", "CodeText",ExpressionUUID->"f445aeb0-1bb7-41ad-87aa-9276656eda2c"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"EmbeddingClosestCycles", "[", 
     RowBox[{"g", ",", 
      RowBox[{"{", 
       RowBox[{"6", ",", "1.5`"}], "}"}]}], "]"}], "[", 
    RowBox[{"LongestCircumferenceCycles", "[", 
     RowBox[{"FindSphere", "[", 
      RowBox[{"g", ",", "6", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
       RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], 
     "]"}], "]"}]}], "]"}]], "Input",ExpressionUUID->"b36021e2-fe8c-4a6c-bfa8-\
9332509858d0"],

Cell["Count how many maximum-length cycles survive a tie.", "CodeText",ExpressionUUID->"9e79678e-ea31-429d-9066-fc50067b7188"],

Cell[BoxData[
 RowBox[{"Length", "[", 
  RowBox[{"LongestCircumferenceCycles", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"6", ",", "7", ",", "8", ",", "9", ",", "10"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "}"}], "]"}], 
  "]"}]], "Input",ExpressionUUID->"aabcf070-1b20-439f-9e5b-66f3541bf45d"],

Cell["See also", "Section",ExpressionUUID->"a2140200-7762-4aff-8992-ba49c8ff044f"],

Cell["FindSegment", "Item",ExpressionUUID->"3b509764-f302-44e2-982c-3ef661fb7302"],

Cell["FindLine", "Item",ExpressionUUID->"c71cb1d7-1001-45d4-9348-a8ed7f6e56e2"],

Cell["FindSphere", "Item",ExpressionUUID->"e757d940-f0e6-4a5c-8d5e-6a7af6eb77ef"],

Cell["CentralPaths", "Item",ExpressionUUID->"7459a4d4-c8d4-4955-813c-4db725b2b502"],

Cell["CentralCycles", "Item",ExpressionUUID->"1f409474-a3ff-4f24-a1a7-5075da4be5f7"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"3a17390c-4168-44bc-a0f4-ede4e43056d5"],

Cell["EmbeddingClosestCycles", "Item",ExpressionUUID->"68f2a894-5903-44bd-9f41-a2e8afe27618"]
},
