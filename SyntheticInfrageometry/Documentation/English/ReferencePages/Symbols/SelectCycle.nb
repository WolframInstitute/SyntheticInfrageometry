Notebook[{
Cell["SelectInfraCycle", "Title",ExpressionUUID->"c88ae3cc-f137-4e50-9e3c-bc25334cf99c"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"0834b65d-a16b-4f9e-a69a-61c9717005e5"],

Cell["\<\
SelectInfraCycle[g, cycles] returns one cycle from the bundle in path-space. \
SelectInfraCycle[g, cycles, n] returns exactly n or $Failed; UpTo[n] returns up to \
n; All returns the whole pool. Options mirror SelectInfraPath plus two extra \
\"From\" values: \"ShortestCircumference\", \"LongestCircumference\". \
Path-space metric distances factor cyclic rotation, so they are \
rotation-invariant. Accepts InfraCircle[cycles_List]; preserves the wrapper. \
Operator form SelectInfraCycle[g, n, opts][cycles].\
\>", "Text",ExpressionUUID->"e7c452db-9360-4b56-b225-cd907021078a"],

Cell["Setup", "Section",ExpressionUUID->"b0c4d8df-89b3-4403-b3b3-e5ba5daf461c"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"188a87c1-cb15-4638-8676-baccfdbb5eff"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"eefed380-9e23-4b03-b23c-4f9541200073"],

Cell["Examples", "Section",ExpressionUUID->"b2a2e4c5-0660-4430-9a28-db09c8f4c982"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"21c811f3-c05b-4e50-85c1-c54e94be40ce"],

Cell[BoxData[
 $CellContext`buildCell["One separating cycle from a bundle."]], "Input",Expre\
ssionUUID->"c231cda0-be8f-4a03-ac47-28fa7838add8"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"8a199062-720f-40d1-ab6e-381ed069adbf"],

Cell[BoxData[
 $CellContext`buildCell[
 "SelectInfraCycle[GridGraph[{5, 5}], FindInfraCircle[GridGraph[{5, 5}], 13, 2, \
All]]"]], "Input",ExpressionUUID->"57bcffef-e052-4c12-92ad-d0b656e2eb55"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"69296b67-c3bf-4f77-83a5-2825956dd3e9"],

Cell[BoxData[
 $CellContext`buildCell["Shortest-circumference cycle."]], "Input",ExpressionU\
