Notebook[{
Cell["TarskiFiveSegmentsQ", "Title",ExpressionUUID->"d8eac779-cf5e-47b4-b849-1f16da9c6ea4"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"b4406054-200b-416b-b476-54b5018b05e3"],

Cell["\<\
TarskiFiveSegmentsQ[g] tests Tarski axiom A5 (five segments). Holds on median \
graphs. Brute O(n^8); option \"MaxTuples\" caps the search (returns \
Indeterminate if the cap is hit).\
\>", "Text",ExpressionUUID->"0c354dbe-8145-4ade-b1fc-9cf5f2c2b58a"],

