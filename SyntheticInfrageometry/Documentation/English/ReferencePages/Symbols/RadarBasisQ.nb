Notebook[{
Cell["RadarBasisQ", "Title",ExpressionUUID->"349ab34c-1eaf-4efd-8fc2-56d401c7094e"],

Cell["\<\
RadarBasisQ[graph, basis] tests whether a vertex list resolves the graph: the \
distance map v |-> (d(v, b))_{b in basis} is injective. Returns True or \
False. The predicate companion of FindRadarBasis.\
\>", "Text",ExpressionUUID->"ad5066af-b87b-4d47-814d-71a4d7616aed"],

Cell["Setup", "Section",ExpressionUUID->"42e08561-11a3-43df-ba62-c954399a13f1"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"1d57b54a-e180-4fa4-a08a-e14108a154f2"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"9c9ca8e0-a592-488d-a969-11d02450ed37"],

Cell["Usage", "Section",ExpressionUUID->"d7628dad-e90e-49db-96ab-1841722cf65a"],

Cell["\<\
Two non-antipodal vertices of the 6-cycle resolve every position.\
\>", "CodeText",ExpressionUUID->"0f426372-ee8e-42ae-8aaa-2b372c504f42"],

Cell["RadarBasisQ[CycleGraph[6], {1, 2}]", "Input",ExpressionUUID->"268efca1-9a80-4a3c-9585-03ac5450ab2a"],

Cell["\<\
Two antipodal vertices of an even cycle do NOT resolve every vertex.\
\>", "CodeText",ExpressionUUID->"6d8efa88-f8e9-4b61-ac69-b9f82b5239b0"],

Cell["RadarBasisQ[CycleGraph[6], {1, 4}]", "Input",ExpressionUUID->"e273d388-c80b-47aa-ae8f-cc61eeefc408"],

Cell["Examples", "Section",ExpressionUUID->"c6970586-46a5-4e19-90df-1856b9f0187e"],

Cell["An endpoint of a path resolves the entire path.", "CodeText",ExpressionUUID->"913df161-33f8-43ba-bab4-3dba3e21a154"],

Cell["RadarBasisQ[PathGraph[Range[5]], {1}]", "Input",ExpressionUUID->"e194b1c9-47e5-45f1-8ed7-2c28a482f085"],

Cell["A single vertex of a cycle is not a resolving set.", "CodeText",ExpressionUUID->"9a83b306-1926-4f0e-ba9b-17b3af94a3cd"],

Cell["RadarBasisQ[CycleGraph[6], {1}]", "Input",ExpressionUUID->"0878f7ef-6069-45da-bdca-27fb534d44fb"],

Cell["On a 4 x 4 grid, the four corners resolve every vertex.", "CodeText",ExpressionUUID->"806ae6ce-26a8-46cd-94cf-d5805b1f0c20"],

Cell["RadarBasisQ[GridGraph[{4, 4}], {1, 4, 13, 16}]", "Input",ExpressionUUID->"a03a01ed-2395-4130-a758-094d1e46d8bb"],

Cell["See also", "Section",ExpressionUUID->"742ef034-8917-4933-b8e3-c7df4bdff2e6"],

Cell["FindRadarBasis", "Item",ExpressionUUID->"ef2a7a19-cc72-4170-81ba-d5e8e16ceda0"],

Cell["RadarCoordinates", "Item",ExpressionUUID->"4d3426ef-074b-4ab4-a4c9-a64e3e7bf35b"],

Cell["CoordinatizationGuide", "Item",ExpressionUUID->"6a779b21-253f-40f6-874f-533b194920fa"]
},
