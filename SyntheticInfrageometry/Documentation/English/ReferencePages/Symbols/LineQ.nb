Notebook[{
Cell["LineQ", "Title",ExpressionUUID->"c96f687d-a580-4b16-a96e-3ec4026b59d4"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"3e0e3967-744b-4bb8-b98b-abbb58d8f8fa"],

Cell["\<\
LineQ[g, segment] tests whether segment is a maximal geodesic: a geodesic \
vertex sequence that cannot be extended at either endpoint while remaining a \
geodesic. LineQ is the predicate companion of FindLine and ExtendSegment.\
\>", "Text",ExpressionUUID->"1b5d7864-f6a2-41ef-88ef-16c7c3765625"],

