Notebook[{
Cell["PeripheralPaths", "Title",ExpressionUUID->"65f3e232-3d30-44d6-8b1a-9e92264baeda"],

Cell["\<\
PeripheralPaths[graph, paths] keeps the paths whose maximum path-space \
distance to the rest of the bundle is maximal -- the eccentric paths. Same \
Method options as CentralPaths and the same operator form.\
\>", "Text",ExpressionUUID->"320f29b1-e29c-4a27-8a05-f45f4fcf089a"],

Cell["Setup", "Section",ExpressionUUID->"09d18436-032a-489c-b70a-fde5224fba1a"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"843bf01d-3e67-4ac6-a0d1-8cd4b2dd6515"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"49add8e7-783f-4fbb-95ff-47f390ed60ed"],

Cell["Usage", "Section",ExpressionUUID->"d727274c-f4ec-44a8-a07c-c7ff73633a4b"],

Cell["Pick the eccentric paths in a geodesic bundle.", "CodeText",ExpressionUUID->"b1e9b916-a7d0-4c71-841a-8d075eaca1fb"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"PeripheralPaths", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSegment", "[", 
      RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}]}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"1725cd1c-b640-4766-84a0-743fc42beaaf"],

Cell["Use the operator form after FindLine.", "CodeText",ExpressionUUID->"672f485a-a60e-419b-9e24-8983d255bc24"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"PeripheralPaths", "[", "g", "]"}], "[", 
    RowBox[{"FindLine", "[", 
     RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"9114a13a-8de8-43cd-bdb6-303a9d6f8a1d"],

Cell["Examples", "Section",ExpressionUUID->"f602105c-ef11-4678-8391-4472c1e73a65"],

Cell["Use the MeanFrechet metric.", "CodeText",ExpressionUUID->"fb5add6f-5c03-4c4e-ac50-06643905aa13"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"PeripheralPaths", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSegment", "[", 
      RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], ",", 
     RowBox[{"Method", "\[Rule]", "\"\<MeanFrechet\>\""}]}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"759de085-38fe-416d-b688-0128c9bc60ea"],

Cell["Compare the bundle size before and after filtering.", "CodeText",ExpressionUUID->"80c06c1f-9d00-48f5-b0a5-f3637a5a81b4"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"g", "=", 
      RowBox[{"GridGraph", "[", 
       RowBox[{"{", 
        RowBox[{"4", ",", "4"}], "}"}], "]"}]}], ",", 
     RowBox[{"paths", "=", 
      RowBox[{"FindSegment", "[", 
       RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}]}]}], "}"}], ",", 
   
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Length", "[", "paths", "]"}], ",", 
     RowBox[{"Length", "[", 
      RowBox[{"PeripheralPaths", "[", 
       RowBox[{"g", ",", "paths"}], "]"}], "]"}]}], "}"}]}], "]"}]], "Input",E\
xpressionUUID->"31d497ae-1348-430a-8482-18447134a335"],

Cell["See also", "Section",ExpressionUUID->"cef592ef-99ef-4b32-bf96-67bbead8bc00"],

Cell["FindSegment", "Item",ExpressionUUID->"8787748c-68a0-4c0f-a32c-4748d2784503"],

Cell["FindLine", "Item",ExpressionUUID->"f8d9ebc8-8fc2-4c7f-bced-319c5d678707"],

Cell["FindSphere", "Item",ExpressionUUID->"51e52563-3247-45ae-b93a-bbbccade26d7"],

Cell["CentralPaths", "Item",ExpressionUUID->"031597c5-8e2d-4b56-b588-9eb2e7afb756"],

Cell["CentralCycles", "Item",ExpressionUUID->"fe20efa7-688d-4319-b9ee-13901baf198b"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"d03b558f-61bc-4bca-9112-dda02505348e"],

Cell["EmbeddingClosestCycles", "Item",ExpressionUUID->"e76f69bc-ffa1-4e1b-9a14-2b379bdb6685"]
},
