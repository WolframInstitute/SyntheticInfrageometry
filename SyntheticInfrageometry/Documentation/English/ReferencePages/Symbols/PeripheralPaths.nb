(* Beginning of Notebook Content *)
Notebook[{
Cell["PeripheralPaths", "Title",ExpressionUUID->"f52c4b14-61e4-4ba3-bf85-b925c468d0bf"],

Cell["\<\
PeripheralPaths[graph, paths] keeps the paths whose maximum path-space \
distance to the rest of the bundle is maximal -- the metric peripherals of \
the bundle. Option Method -> \"Frechet\" (default) | \"Hausdorff\" | \
\"MeanFrechet\" picks the underlying base metric. Operator form \
PeripheralPaths[graph, opts][paths] is provided for piping after FindSegment \
/ FindLine.\
\>", "Text",ExpressionUUID->"1aabe6cd-bd01-471d-bba1-f3b341a2aeab"],

Cell["Setup", "Section",ExpressionUUID->"10624574-183f-4564-a233-7247c3a3755e"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"280572d9-196f-4678-8f1d-4bb014ec4f1e"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"a7be26cd-809f-46dd-b33f-77b605bbc1d1"],

Cell["Usage", "Section",ExpressionUUID->"b148d10b-d497-49f7-a536-ff7c43a2975f"],

Cell["Pick the path-space peripherals of a geodesic bundle.", "CodeText",ExpressionUUID->"462dff40-c195-46b0-9bf3-6e71232eb687"],

Cell["\<\
With[{g = GridGraph[{4, 4}]}, PeripheralPaths[g, FindSegment[g, 1, 16, All]]]\
\
\>", "Input",ExpressionUUID->"3811fe88-4019-4521-82f6-93c62d1ec71e"],

Cell["Render only the peripheral subbundle on top of the graph.", "CodeText",ExpressionUUID->"555f0f62-8120-4d17-8f20-61df7566a830"],

Cell["\<\
With[{g = GridGraph[{4, 4}]}, InfraSceneHighlight[g, {PeripheralPaths[g, \
FindSegment[g, 1, 16, All]] -> Red}]]\
\>", "Input",ExpressionUUID->"602bfec5-7848-45d0-960a-0ce51e5e087d"],

Cell["Examples", "Section",ExpressionUUID->"44791647-a8ea-4d1a-99aa-8725c2ba78f7"],

Cell["Switch to the Hausdorff path-space metric.", "CodeText",ExpressionUUID->"385684be-d13b-45bf-8734-13b9249f729f"],

Cell["\<\
With[{g = GridGraph[{4, 4}]}, PeripheralPaths[g, FindSegment[g, 1, 16, All], \
Method -> \"Hausdorff\"]]\
\>", "Input",ExpressionUUID->"adb7cc7e-3bed-442f-9af7-8daab2254b24"],

Cell["Compare central vs peripheral subbundles side by side.", "CodeText",ExpressionUUID->"05608d56-bc7f-4c37-b1c8-80f66a7d1d7b"],

Cell["\<\
With[{g = GridGraph[{4, 4}], paths = FindSegment[g, 1, 16, All]}, \
Row[{InfraSceneHighlight[g, {CentralPaths[g, paths] -> Red}, ImageSize -> \
200], InfraSceneHighlight[g, {PeripheralPaths[g, paths] -> Blue}, ImageSize \
-> 200]}]]\
\>", "Input",ExpressionUUID->"ebf03aa2-4915-459b-b2a8-a542043ff4fe"],

Cell["See also", "Section",ExpressionUUID->"0773b491-13f7-470e-9f75-256fa281dd6a"],

Cell["CentralPaths", "Item",ExpressionUUID->"5c308a47-b364-460f-8fb8-94c1b126b71b"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"24fba031-7c8d-49b6-98b7-ac81a414ae76"],

Cell["FindSegment", "Item",ExpressionUUID->"d081f284-cabb-463e-a211-2c8532b91a06"],

Cell["FindLine", "Item",ExpressionUUID->"0b5b5a81-8d96-45f0-a112-e2f8ed9c3dc3"],

Cell["InfraSceneHighlight", "Item",ExpressionUUID->"05e8f1d9-4b9c-4b42-a412-c9487d645b36"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"6dc4a242-813d-4352-ac44-d8bf3ee96084"
]
