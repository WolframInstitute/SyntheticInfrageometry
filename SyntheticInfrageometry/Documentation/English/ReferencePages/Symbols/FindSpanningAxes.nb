(* Beginning of Notebook Content *)
Notebook[{
Cell["FindSpanningAxes", "Title",ExpressionUUID->"a005a57e-ba18-4748-b475-ba7401e2d719"],

Cell["\<\
FindSpanningAxes[graph, n] returns n mutually well-separated longest \
geodesics across graph (greedy, no fixed centre) or $Failed; UpTo[n] returns \
up to n; All returns every axis above the separation threshold. Options: \
\"AxisDistance\" (\"MinEndpoint\" | \"Hausdorff\" | \"Separation\"), \
\"MinLength\", \"MinSeparation\", \"AxisThickness\", \"RandomPick\". For axes \
through a fixed centre vertex use FindOrthogonalFrame.\
\>", "Text",ExpressionUUID->"44e597e9-2e7b-47e9-8939-8bb95a0b71fe"],

Cell["Setup", "Section",ExpressionUUID->"f768f549-ea4d-484e-a080-0f149e52ec30"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"b2496e30-fc55-4f7b-9d34-a435020ceb45"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"d955f6c3-b228-42c0-898f-067e3f1072aa"],

Cell["Usage", "Section",ExpressionUUID->"baa6322e-aaae-4390-affa-2a1e8904b12f"],

Cell["Two well-separated longest geodesics on a 5x5 grid.", "CodeText",ExpressionUUID->"8a42e0c5-8d2f-4579-a611-6feb76a769be"],

Cell["FindSpanningAxes[GridGraph[{5, 5}], 2]", "Input",ExpressionUUID->"90ecc65c-3684-4d1b-b70f-d398b37e8d3a"],

Cell["Visualize the spanning axes.", "CodeText",ExpressionUUID->"5f2bc531-84d9-4431-bc3e-40b668d90df4"],

Cell["\<\
With[{g = GridGraph[{5, 5}]}, InfraSceneHighlight[g, FindSpanningAxes[g, 2]]]\
\
\>", "Input",ExpressionUUID->"bddce114-e074-4adb-81fa-e8e41758be9e"],

Cell["Examples", "Section",ExpressionUUID->"f059e63f-04cb-47ea-ac48-d8dc57603d41"],

Cell["All axes above the separation threshold.", "CodeText",ExpressionUUID->"56922098-6595-44f2-843e-c351c48c3a6d"],

Cell["FindSpanningAxes[GridGraph[{4, 4}], All]", "Input",ExpressionUUID->"58902469-1c34-4b6a-9ff1-c119d91a3134"],

Cell["Switch to Hausdorff separation.", "CodeText",ExpressionUUID->"d4cf907c-75c2-4baa-82e8-1e9a556a807c"],

Cell["\<\
FindSpanningAxes[GridGraph[{6, 6}], 3, \"AxisDistance\" -> \"Hausdorff\"]\
\>", "Input",ExpressionUUID->"5fe307de-6cb5-4307-9698-ab02a51896b7"],

Cell["See also", "Section",ExpressionUUID->"0c224e15-6b2f-4cdf-ade9-81f724e7cac5"],

Cell["FindOrthogonalFrame", "Item",ExpressionUUID->"1a96b535-e657-4a8d-a9c2-e727c5ae7737"],

Cell["OrthogonalCoordinates", "Item",ExpressionUUID->"5dd10bf0-17bc-451c-9c81-829f664817ce"],

Cell["FindRadarBasis", "Item",ExpressionUUID->"ea326176-7c08-43a1-b842-ad4fbc12a6e6"],

Cell["SelectPaths", "Item",ExpressionUUID->"49c4e9e0-a055-40e4-b655-e1756b2f2263"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
