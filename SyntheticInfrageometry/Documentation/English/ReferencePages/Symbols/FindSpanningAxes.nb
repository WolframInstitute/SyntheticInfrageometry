Notebook[{
Cell["FindSpanningAxes", "Title",ExpressionUUID->"4779bb55-30e9-4480-b331-fbe3ab550cbc"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"a524e579-6a04-458d-86d6-fe05b9cb10ff"],

Cell["\<\
FindSpanningAxes[g, n] returns n mutually well-separated longest geodesics \
across g (greedy, no fixed centre) or $Failed; UpTo[n] returns up to n; All \
returns every axis above the separation threshold. Options: \"AxisDistance\" \
(\"MinEndpoint\" | \"Hausdorff\" | \"Separation\"), \"MinLength\", \
\"MinSeparation\", \"AxisThickness\", \"RandomPick\". For axes through a \
fixed centre use FindOrthogonalFrame.\
\>", "Text",ExpressionUUID->"c3512613-2abb-41bb-8e61-2223fe4d1f58"],

Cell["Setup", "Section",ExpressionUUID->"0fc7b7ac-68f4-421d-a25a-04402a1aff94"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"afc1b444-25e0-48e3-a1f7-89b1a5dc2f2c"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"4e9668eb-cc0c-4822-8fbc-fa3805790e03"],

Cell["Examples", "Section",ExpressionUUID->"9434f70c-861f-4602-93b9-5167ff90b71c"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"622e4bff-13f3-4652-bcd5-efea3442422d"],

Cell[BoxData[
 $CellContext`buildCell["Three spanning axes on a 4x4 grid."]], "Input",Expres\
sionUUID->"50928f85-7e8c-414b-850c-0f577a6121eb"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"21ad2ee1-bbe3-427e-91f0-27eda107112b"],

Cell[BoxData[
 $CellContext`buildCell["FindSpanningAxes[GridGraph[{4, 4}], 3]"]], "Input",Ex\
