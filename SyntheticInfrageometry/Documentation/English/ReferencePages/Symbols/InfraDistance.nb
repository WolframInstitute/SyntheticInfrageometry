Notebook[{
Cell["InfraDistance", "Title",ExpressionUUID->"10dc1d31-028f-45e6-9849-c049ef5c8df1"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"b42ff0cc-5cbf-4e43-9524-8d2c4e76d0a4"],

Cell["\<\
InfraDistance[g, p, q] is the graph distance between p and q in g, where each \
is a bare vertex or any Infra* wrapper. The result is aggregated over the \
cross-product of underlying vertex sets via the \"Aggregation\" option (Min \
default, also Max / Mean / any List -> Number). InfraDistance[p, q] without a \
graph is also recognised inside InfraScene assertions.\
\>", "Text",ExpressionUUID->"37596c11-41be-48ac-acfa-1edaa8a3294d"],

Cell["Setup", "Section",ExpressionUUID->"52392055-8a2d-49f5-b416-46421c372a3d"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"8ae70f3d-a9c2-4fe8-be4d-3e588df3f079"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"ac6e40b1-493c-4c14-bbc6-809c6ea8f2b6"],

