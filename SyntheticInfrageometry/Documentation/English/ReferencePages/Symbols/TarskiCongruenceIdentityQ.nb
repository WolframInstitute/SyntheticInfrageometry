Notebook[{
Cell["TarskiCongruenceIdentityQ", "Title",ExpressionUUID->"a47692c4-35ef-4125-8796-75d601725841"],

Cell["\<\
TarskiCongruenceIdentityQ[graph] tests Tarski axiom A3: ab == cc implies a == \
b. Holds on connected simple graphs.\
\>", "Text",ExpressionUUID->"2edca623-12da-459f-a57e-301b72d80987"],

Cell["Setup", "Section",ExpressionUUID->"67a11a21-32c0-4258-a3d2-4430317d099d"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"f2a702cd-cf83-4650-978d-4c79dd8aec98"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"7bfabeef-ce62-48a3-8c00-8882a9efd93f"],

Cell["Usage", "Section",ExpressionUUID->"475d8d8c-f0b6-4824-85be-debaf35607fd"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"bc790190-2bba-4002-b8f3-b7b69523ac9e"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceIdentityQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"a6780682-2afd-41c3-af0d-bea13d569273"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"992dd805-1a91-45b4-8c0c-825d46d2e7c2"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceIdentityQ", "[", 
  RowBox[{"Graph", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"Null", ",", 
      RowBox[{"SparseArray", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{"4", ",", "4"}], "}"}], ",", "0", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "3", ",", "6", ",", "9", ",", "12"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "3", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "4", "}"}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "3", "}"}]}], "}"}]}], "}"}], ",", "Pattern"}], 
         "}"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"GraphLayout", "\[Rule]", "\"\<StarEmbedding\>\""}], "}"}]}], 
   "]"}], "]"}]], "Input",ExpressionUUID->"3c06f27c-cee4-4648-8fc8-\
0e721f7563dc"],

Cell["Examples", "Section",ExpressionUUID->"b49e3d0f-3394-42b9-93d7-34decc021d6b"],

Cell["Compare with the dashboard entry.", "CodeText",ExpressionUUID->"fa977bd7-2b5f-4ca7-8ee6-13cfa5e4f674"],

Cell[BoxData[
 RowBox[{"TarskiAxiomQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"7cd227e4-b723-4482-bec1-ab0cf7c7e68e"],

Cell["Evaluate the predicate on a grid as a second check.", "CodeText",ExpressionUUID->"7f1a7077-957f-4147-af82-b228450397a9"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceIdentityQ", "[", 
  RowBox[{"GridGraph", "[", 
   RowBox[{"{", 
    RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"876d9319-4e59-45e7-b21d-d96da54e1df9"],

Cell["See also", "Section",ExpressionUUID->"53b02275-5284-440d-8878-684494dddc1d"],

Cell["BetweennessQ", "Item",ExpressionUUID->"74ad0c2a-63be-4f16-a44d-70c460c0aa95"],

