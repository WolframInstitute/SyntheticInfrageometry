Notebook[{
Cell["TarskiCongruenceIdentityQ", "Title",ExpressionUUID->"462a42fa-bdac-4aab-8a3e-4d2c457b14b3"],

Cell["\<\
TarskiCongruenceIdentityQ[graph] tests Tarski axiom A3: ab == cc implies a == \
b. Holds on connected simple graphs.\
\>", "Text",ExpressionUUID->"e44ce04e-747a-4b9f-8930-3c771c3a9b1b"],

Cell["Setup", "Section",ExpressionUUID->"b5e9f2f7-21f1-46e4-89e5-fa7be809c51b"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"d61f87c8-dddb-437a-9439-6baf129a1ba6"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"de485aa3-8b8f-4707-a345-87c81f26fd05"],

Cell["Usage", "Section",ExpressionUUID->"309728e5-b93b-4788-87ae-2f4fdf9f702a"],

Cell["Evaluate the axiom predicate on a path graph.", "CodeText",ExpressionUUID->"5f5771e0-5cd6-4460-8623-a4475abf0429"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceIdentityQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"8622fbf6-e14a-4eb2-8d51-0073a13c7c07"],

Cell["Evaluate the same predicate on a second substrate.", "CodeText",ExpressionUUID->"f7df62d2-e22d-43ca-a541-6069b6bb4858"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceIdentityQ", "[", 
  RowBox[{
  "tarskiSecondExample", "[", "\"\<TarskiCongruenceIdentityQ\>\"", "]"}], 
  "]"}]], "Input",ExpressionUUID->"c62f41e9-7cff-46dd-9270-b0e5caf5db21"],

Cell["Examples", "Section",ExpressionUUID->"0f3d2109-928e-457b-9eb0-da79272dad73"],

Cell["Compare with the dashboard entry.", "CodeText",ExpressionUUID->"05cdf1a0-119d-4b17-ad14-606669da7c56"],

Cell[BoxData[
 RowBox[{"TarskiAxiomQ", "[", 
  RowBox[{"PathGraph", "[", 
   RowBox[{"Range", "[", "5", "]"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"d4ff4c46-c654-4690-abf7-01a7f876b2f8"],

Cell["Evaluate the predicate on a grid as a second check.", "CodeText",ExpressionUUID->"2e2a6804-ca6e-44ab-96f0-64dbb707fa50"],

Cell[BoxData[
 RowBox[{"TarskiCongruenceIdentityQ", "[", 
  RowBox[{"GridGraph", "[", 
   RowBox[{"{", 
    RowBox[{"3", ",", "3"}], "}"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"920ce258-c490-4a67-b3e3-98668549dda5"],

Cell["See also", "Section",ExpressionUUID->"dbc098eb-e3a1-43f0-a33c-0303d82c730f"],

Cell["BetweennessQ", "Item",ExpressionUUID->"97d11f7d-306e-46f4-aeaf-e42b79943209"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"1b44a1a1-932c-4b55-9a82-0c9ab12cccb3"],

Cell["TarskiStructure", "Item",ExpressionUUID->"7c5d6aaf-124c-40a3-bb58-ad0f8ffaba83"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"6149d93c-3ed0-491b-b210-3ad72f846e18"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"407fab30-80c0-4db0-acf2-a959092c6036"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"284a9579-1116-492f-9bcd-b12f7614d572"],

Cell["MetricInterval", "Item",ExpressionUUID->"476a767a-7cd4-4981-bbd3-b19cadf79550"]
