Notebook[{
Cell["ResistanceCoordinates", "Title",ExpressionUUID->"96705212-774c-4ee2-9073-c92814e389fe"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"5595caac-dacb-4d8b-9b50-28b4c8dd0308"],

Cell["\<\
ResistanceCoordinates[g] returns the Association v -> Phi(v) of \
resistance-matching spectral coordinates Phi(v) = (phi_i(v) / \
Sqrt[lambda_i])_{i: lambda_i > 0}, satisfying ||Phi(u) - Phi(v)||^2 == \
EffectiveResistance(u, v). ResistanceCoordinates[g, v] returns one coordinate \
vector; an InfraPoint query returns the per-realisation list. Options: \
\"Rescaling\" (\"ResistanceMatching\" (default), \"None\", \"Diffusion\" -> \
t), \"Dimension\" (Automatic, Integer, UpTo[k], All), \"Origin\" (None or \
vertex / InfraPoint).\
\>", "Text",ExpressionUUID->"f83ae978-734d-4e80-83ed-13fb93eec8b2"],

Cell["Setup", "Section",ExpressionUUID->"246eafb8-5cf4-4a52-8933-12c5c0b4669b"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"238aeaca-c929-4930-8642-0bad1ae9d21a"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"136b1e4f-1ead-4002-b633-750f7b9a34eb"],

Cell["Examples", "Section",ExpressionUUID->"4d661c42-9382-4563-8205-45f0702bc5fd"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"ac7725c5-477a-4b17-a6e4-cb05e8f3e464"],

Cell[BoxData[
 $CellContext`buildCell[
 "All resistance coordinates of a path graph."]], "Input",ExpressionUUID->\
"c3127481-1898-4738-a425-6f4d9eaaee22"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"ffa309b9-865f-4a48-a8c6-300d130b8728"],

Cell[BoxData[
