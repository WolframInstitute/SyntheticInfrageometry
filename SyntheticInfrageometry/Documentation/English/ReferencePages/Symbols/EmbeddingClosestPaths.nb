Notebook[{
Cell["EmbeddingClosestPaths", "Title",ExpressionUUID->"dbc8d871-6790-4541-a270-65adf09a7856"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"1f75ae19-73f6-48e9-9ebc-1bdf1c52c6f0"],

Cell["\<\
EmbeddingClosestPaths[g, paths, {p1, p2}] keeps the paths whose drawing under \
GraphEmbedding is Hausdorff-closest to the straight Euclidean segment p1-p2. \
Operator form EmbeddingClosestPaths[g, {p1, p2}][paths].\
\>", "Text",ExpressionUUID->"cb885878-cbdf-4bb6-a882-bb056f5da33a"],

Cell["Setup", "Section",ExpressionUUID->"6fa0855e-7f0d-489a-81df-9ff5bebc005e"],

