Notebook[{
Cell["EmbeddingClosestPaths", "Title",ExpressionUUID->"5c43b7f5-4aad-4e75-8a80-5820ef98cfb0"],

Cell["\<\
EmbeddingClosestPaths[graph, paths, {p1, p2}] keeps the paths whose drawing \
under GraphEmbedding is closest (in plane Hausdorff distance) to the straight \
Euclidean segment between p1 and p2. Operator form \
EmbeddingClosestPaths[graph, {p1, p2}][paths].\
\>", "Text",ExpressionUUID->"89b7258f-60e2-40bc-b7f7-50d7cea9c82f"],

Cell["Setup", "Section",ExpressionUUID->"bbba0125-7c85-4588-b72f-d388627b9c88"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"9ff5e149-9f63-49a6-8d76-737f291fda8e"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"b13c89de-3634-4207-8469-87fc9c02c210"],

Cell["Usage", "Section",ExpressionUUID->"c8037b78-e97e-4b1d-8270-69fc198f4aff"],

Cell["\<\
Keep the paths closest to the Euclidean chord in the embedding.\
\>", "CodeText",ExpressionUUID->"7b597f40-6271-4d2e-bf09-600f0a84a114"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"EmbeddingClosestPaths", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSegment", "[", 
      RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "16"}], "}"}]}], "]"}]}], "]"}]], "Input",ExpressionUU\
ID->"1169c3dd-df00-4811-b981-ff15dd77dda0"],

Cell["Use the operator form for chaining.", "CodeText",ExpressionUUID->"fc65ec4c-a89f-4f35-83af-d64b84287bea"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"EmbeddingClosestPaths", "[", 
     RowBox[{"g", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "16"}], "}"}]}], "]"}], "[", 
    RowBox[{"FindSegment", "[", 
     RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"5fea8623-4233-4d31-b584-b29de56bfbe7"],

Cell["Examples", "Section",ExpressionUUID->"a2c08f9e-392b-4b4d-9fb5-11b800379ec4"],

Cell["Compose centrality and embedding closeness.", "CodeText",ExpressionUUID->"7a81dfc9-d130-49ea-b077-b916617d016f"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"EmbeddingClosestPaths", "[", 
     RowBox[{"g", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "16"}], "}"}]}], "]"}], "[", 
    RowBox[{
     RowBox[{"CentralPaths", "[", "g", "]"}], "[", 
     RowBox[{"FindSegment", "[", 
      RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], "]"}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"82092cb2-b003-4eae-9d87-3fdcefae3e24"],

Cell["Render the embedding-closest subbundle.", "CodeText",ExpressionUUID->"b1973b5a-d222-490b-ba1c-c120e494a077"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"EmbeddingClosestPaths", "[", 
        RowBox[{"g", ",", 
         RowBox[{"FindSegment", "[", 
          RowBox[{"g", ",", "1", ",", "16", ",", "All"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "16"}], "}"}]}], "]"}], "\[Rule]", "Blue"}], 
      "}"}]}], "]"}]}], "]"}]], "Input",ExpressionUUID->"e7a72bbe-ee71-4869-\
88d8-ca0f52d44dd9"],

Cell["See also", "Section",ExpressionUUID->"c8f60fdd-a3ad-4409-855f-6002e7ce5f58"],

Cell["FindSegment", "Item",ExpressionUUID->"3d5863ba-8028-4ed4-92e7-25ed242cc35d"],

Cell["FindLine", "Item",ExpressionUUID->"34e2b66a-24af-401a-8e1f-fa085e76e783"],

Cell["FindSphere", "Item",ExpressionUUID->"6388d5ce-c93a-4860-9046-1614a2c68369"],

Cell["CentralPaths", "Item",ExpressionUUID->"7ab36332-660a-41c7-8f9d-d16a0e428157"],

Cell["CentralCycles", "Item",ExpressionUUID->"e6a2d65b-32cb-4246-b48c-3df90a9002eb"],

Cell["EmbeddingClosestCycles", "Item",ExpressionUUID->"c42f5bd4-a2d8-46d2-9334-d3a3d877a43f"]
},
