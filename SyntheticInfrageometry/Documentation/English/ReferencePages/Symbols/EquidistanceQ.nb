Notebook[{
Cell["EquidistanceQ", "Title",ExpressionUUID->"b00e32b9-9520-4cf9-99a9-13ff7a16aa2b"],

Cell["\<\
EquidistanceQ[graph, a, b, c, d] tests Tarski's equidistance ab == cd: d(a, \
b) == d(c, d).\
\>", "Text",ExpressionUUID->"a9f165ff-3b87-4c03-857d-7eaf24b5e968"],

Cell["Setup", "Section",ExpressionUUID->"7c211f73-d5b8-41d6-9e11-a2b76999995a"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"7ccc1b09-303b-4ee3-b2e6-dcf37efa0d64"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"375ce6ec-71da-4bb8-ba9b-f90197727c0f"],

Cell["Usage", "Section",ExpressionUUID->"d5597263-58dd-4c55-9671-06760750cbd3"],

Cell["\<\
Test whether two unordered pairs have the same graph distance.\
\>", "CodeText",ExpressionUUID->"753f845c-0f8e-4a7d-b2f4-43eafe6a6e5f"],

Cell[BoxData[
 RowBox[{"EquidistanceQ", "[", 
  RowBox[{
   RowBox[{"CycleGraph", "[", "6", "]"}], ",", "1", ",", "4", ",", "2", ",", 
   "5"}], "]"}]], "Input",ExpressionUUID->"bcf4dc20-e800-4ded-b1dc-\
ade0afc8697e"],

Cell["A negative example on a path.", "CodeText",ExpressionUUID->"679f4bc0-d872-446b-b902-a0f905a4ae34"],

Cell[BoxData[
 RowBox[{"EquidistanceQ", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "3", ",", "2", ",",
    "5"}], "]"}]], "Input",ExpressionUUID->"ec3dddbd-abbb-4816-a607-\
3ea9d9476dc5"],

Cell["Examples", "Section",ExpressionUUID->"24b94c5a-c7de-443c-bddc-b4dfa6829e34"],

Cell["Use equidistance inside a midpoint check.", "CodeText",ExpressionUUID->"42175a6f-2129-4df1-be6d-871df264144b"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"g", "=", 
      RowBox[{"PathGraph", "[", 
       RowBox[{"Range", "[", "5", "]"}], "]"}]}], ",", 
     RowBox[{"m", "=", "3"}]}], "}"}], ",", 
   RowBox[{"EquidistanceQ", "[", 
    RowBox[{"g", ",", "1", ",", "m", ",", "m", ",", "5"}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"6f937a46-2b9a-4755-bb45-abac60b479dd"],

Cell["Check that adjacent edges are congruent on a path.", "CodeText",ExpressionUUID->"d40e29bd-c55f-4e23-aa1b-fa9601e99d13"],

Cell[BoxData[
 RowBox[{"EquidistanceQ", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "2", ",", "3", ",",
    "4"}], "]"}]], "Input",ExpressionUUID->"b19e2ee1-d311-43e4-b56c-\
3649b53b8552"],

Cell["See also", "Section",ExpressionUUID->"55e7ad13-c466-4aff-8f86-a1e71744e442"],

Cell["BetweennessQ", "Item",ExpressionUUID->"671009ba-8170-4944-902d-8a9d29fd28bc"],

Cell["TarskiStructure", "Item",ExpressionUUID->"f9af90da-85d3-416f-8413-ee3d40fa49b1"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"88f4bbff-ae41-469b-8fd2-81f0659a1f35"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"869a986d-164b-41c3-aa8a-2e0d1a452dd6"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"5b3b9e78-2e1b-4b91-b95e-1dccb42583c3"],

Cell["MetricInterval", "Item",ExpressionUUID->"7c8bbc3a-f8a7-45d5-b229-739ab6691c9b"]
},
