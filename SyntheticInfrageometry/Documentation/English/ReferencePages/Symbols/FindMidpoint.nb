Notebook[{
Cell["FindMidpoint", "Title",ExpressionUUID->"6782be88-e460-4ae0-a84b-d29d9f76c3fb"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"76d2013a-351f-40e1-8364-75762e805450"],

Cell["\<\
FindMidpoint[g, p1, p2] returns a midpoint between p1 and p2 across all \
geodesics. Two-argument form FindMidpoint[g, segment] returns the midpoint of \
a specific segment. Returns a List of unary InfraPoint[{v}] wrappers; n / \
UpTo[n] / All control multiplicity. Option Method (\"Metric\" (default) | \
\"Tarski\" (synthetic from B and E) | \"Embedding\").\
\>", "Text",ExpressionUUID->"b52b9f82-0cc0-443e-bf94-a9c17c098f0e"],

Cell["Setup", "Section",ExpressionUUID->"1d844254-116f-469d-966e-37671c4d6bea"],

