Notebook[{
Cell["InfraScalarProduct", "Title",ExpressionUUID->"460c58d4-b625-4962-96e0-43f049cfe265"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"6c44d0df-a63b-4577-9d75-a6471966cfab"],

Cell["\<\
InfraScalarProduct[g, o, u, v] returns the base-point-relative scalar product \
of u and v with respect to o. Option Method (\"Schoenberg\" (default) \
\[LongDash] (d(o, u)^2 + d(o, v)^2 - d(u, v)^2)/2; \"Parallelogram\" \
\[LongDash] polarisation identity (||u+v||^2 - ||u-v||^2)/4 via \
FindInfraLinearCombination).\
\>", "Text",ExpressionUUID->"64a0d84d-c698-4f65-ba8c-62dcfda56e20"],

Cell["Setup", "Section",ExpressionUUID->"c7326717-dcc7-4b34-bdf5-96d84f794cce"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"de703050-3f88-4f24-b28b-4d2a8a15af2b"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"bccbb605-caac-4611-8892-d71586850d12"],

Cell["Examples", "Section",ExpressionUUID->"8cad0702-2c6d-4621-87a8-0b2a5c2af4c3"],

