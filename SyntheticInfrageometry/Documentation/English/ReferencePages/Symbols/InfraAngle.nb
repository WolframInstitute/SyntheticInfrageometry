Notebook[{
Cell["InfraAngle", "Title",ExpressionUUID->"04340073-2c6a-4e55-9044-48d0dba9db06"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"e1d1755b-9734-469f-950b-d7de72d5224f"],

Cell["\<\
InfraAngle[g, {q1, p, q2}] returns an angle at p. Option Method (\"PunchOut\" \
(default) \[LongDash] delete the open ball of radius Min[d(p, q1), d(p, q2)] \
around p and return the shortest q1-q2 path length outside, divided by the \
radius; \"Comparison\" \[LongDash] the Alexandrov comparison-triangle angle \
at p in the Euclidean k = 0 model; {\"Comparison\", \"Curvature\" -> k} \
\[LongDash] same angle in M_k^2 for arbitrary k).\
\>", "Text",ExpressionUUID->"76ad0fda-b94e-4307-ace4-24713268cf9f"],

Cell["Setup", "Section",ExpressionUUID->"169be77d-9d10-4792-874f-edc117febc92"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"be7b8f3f-bd63-4bcd-bbf9-a0e9fb0410fa"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"5d4a4403-2bc5-4882-9580-8c774f530a14"],

Cell["Examples", "Section",ExpressionUUID->"28ce2e6f-7d73-48f1-a78c-3503780804f7"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"f3dd6685-354f-4ad6-9667-456de9773260"],

Cell[BoxData[
 $CellContext`buildCell[
 "Punch-out angle at the centre of a 4x4 grid."]], "Input",ExpressionUUID->\
"972e7623-fdf6-4efe-8afe-f897e3429453"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"833eb113-5342-4c49-bce3-0e1f8587a989"],

Cell[BoxData[
 $CellContext`buildCell["InfraAngle[GridGraph[{4, 4}], {1, 6, 11}]"]], "Input",\
ExpressionUUID->"c5bf6ca4-7098-4a9d-bc8f-b3e99fa0ca12"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"14f86941-18f6-4cd9-a0d3-c34fd48bb039"],

Cell[BoxData[
 $CellContext`buildCell[
 "Comparison-triangle angle in the Euclidean model."]], "Input",ExpressionUUID\
->"9862daf3-998f-42c1-ab5c-3618657732d6"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"4d5aa497-c36a-476b-9880-eada44f9fd92"],

Cell[BoxData[
 $CellContext`buildCell[
 "InfraAngle[GridGraph[{4, 4}], {1, 6, 11}, Method -> \"Comparison\"]"]], \
"Input",ExpressionUUID->"214a7ad6-112b-4d02-be00-85d421e9d1b7"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"cd2052af-2558-4b3c-bd56-765218d080b9"],

Cell[BoxData[
 $CellContext`buildCell["Comparison angle in M_k^2 with k = -1."]], "Input",Ex\
pressionUUID->"1a6457ea-68d8-4912-a72d-1aa14ac6be08"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"5e36c42b-f8da-4533-820a-53029854bda4"],

Cell[BoxData[
 $CellContext`buildCell[
 "InfraAngle[GridGraph[{4, 4}], {1, 6, 11}, Method -> {\"Comparison\", \
\"Curvature\" -> -1}]"]], "Input",ExpressionUUID->"2928243d-fc26-40da-840e-\
9b852d2be30e"],

