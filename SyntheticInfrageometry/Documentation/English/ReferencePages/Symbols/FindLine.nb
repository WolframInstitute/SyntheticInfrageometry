Notebook[{

Cell[CellGroupData[{
Cell["FindLine", "Title",ExpressionUUID->"3a9c2f62-3098-4f80-9e40-6b551ba18087"],

Cell["\<\
FindLine[graph, p1, p2] returns InfraSegment[{line}] for one maximal geodesic \
extension through p1 and p2 -- a vertex sequence (a, ..., p1, ..., p2, ..., \
b) every contiguous sub-sequence of which is a geodesic and which cannot be \
extended at either end without breaking the geodesic property. Option \
\"Maximality\" -> \"Extension\" (default) or \"Diameter\"; Method axis \
matches FindSegment / ExtendSegment.\
\>", "Text",ExpressionUUID->"1ec69ac5-9543-4aea-9876-e4efbe7f2311"],

Cell[CellGroupData[{

Cell["Setup", "Section",ExpressionUUID->"a3b4d04b-903d-40f7-99b2-2c1f019c5292"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"add460b6-e572-45fe-a32c-386a74eff17a"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",
 CellLabel->
  "In[112]:=",ExpressionUUID->"fcb97c3a-1377-4e3d-a66b-74f912834c73"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Usage", "Section",ExpressionUUID->"dbf3dad0-60e1-4e32-9a13-76dcdc0afc4f"],

Cell["\<\
Find one maximal geodesic extension through two diagonal vertices.\
\>", "CodeText",ExpressionUUID->"ed51c9ad-4628-41de-928f-e6ee3f9e45b1"],

Cell[CellGroupData[{

Cell["\<\
With[{g = GridGraph[{4, 4}]}, InfraSceneHighlight[g, {FindLine[g, 1, 16] -> \
Blue}]]\
\>", "Input",
 CellLabel->
  "In[113]:=",ExpressionUUID->"e3b0c203-6416-46b8-8fa4-8e331ed0a404"],

