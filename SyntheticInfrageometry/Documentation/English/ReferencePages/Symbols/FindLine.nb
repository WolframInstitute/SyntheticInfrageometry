Notebook[{
Cell["FindLine", "Title",ExpressionUUID->"4f8b2970-94c7-41a1-8955-c404d4ea8c65"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"0c30b0be-f108-49be-978e-769d5e2bd84e"],

Cell["\<\
FindLine[g, p1, p2] returns the maximal geodesic extensions through p1 and p2 \
as a List of unary InfraSegment[{line}] wrappers. n / UpTo[n] / All control \
multiplicity. Options: \"Maximality\" (\"Extension\" (default) | \
\"Diameter\"), Method (shared with FindSegment).\
\>", "Text",ExpressionUUID->"8f211a47-eeb0-4fec-b3dd-6100cde0341d"],

