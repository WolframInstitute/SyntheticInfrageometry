Notebook[{
Cell["CATInequalityQ", "Title",ExpressionUUID->"1665e666-ec08-4dd7-ae79-d216ace845e3"],

Cell["\<\
CATInequalityQ[graph, {p, q, r}, k : 0] tests whether the geodesic triangle \
on {p, q, r} satisfies the CAT(k) thinness inequality d(apex, x) <= \
d_k_bar(x_bar) at every vertex x on every geodesic side, with x_bar the \
corresponding point on the comparison triangle in M_k^2. Returns \
Indeterminate when k > 0 and the triangle perimeter exceeds 2 Pi / Sqrt[k] \
(no spherical comparison fits).\
\>", "Text",ExpressionUUID->"470460df-08a5-4d60-a866-7fa087d62235"],

Cell["Setup", "Section",ExpressionUUID->"2b1b9c9c-7e30-4b5e-b0f6-f3c80fee7c82"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"17fbbe87-a697-45df-9dda-a8456f5aa481"],

Cell["Needs[\"WolframInstitute`SyntheticInfrageometry`\"]", "Code",ExpressionUUID->"80400fbd-da82-490a-b5f2-bec3e7a5c326"],

Cell["Usage", "Section",ExpressionUUID->"ed4e305e-3696-4962-92e0-c631a6225fc2"],

Cell["Triangle in a tree is CAT(0).", "CodeText",ExpressionUUID->"08d3dd7c-d9c1-421f-89de-76e60d7fb3ea"],

Cell["\<\
With[{g = CompleteGraph[{2, 3}]}, CATInequalityQ[g, {1, 4, 5}]]\
\>", "Input",ExpressionUUID->"b28c69a3-ea07-4928-915d-83d8b80e6053"],

Cell["Triangle in a 4x4 grid -- check CAT(0) thinness.", "CodeText",ExpressionUUID->"860f0ee1-85b3-409c-8483-eead574ecec7"],

Cell["With[{g = GridGraph[{4, 4}]}, CATInequalityQ[g, {1, 4, 13}]]", "Input",ExpressionUUID->"46e076b9-535d-4b4f-8cc4-90e7f85e5390"],

Cell["Examples", "Section",ExpressionUUID->"a3f4e6e3-e314-48ee-a042-784124a6bedf"],

Cell["Test the same triangle against curvature k = -1.", "CodeText",ExpressionUUID->"81a76197-96aa-489e-9db6-54b6da27cd1b"],

Cell["\<\
With[{g = GridGraph[{4, 4}]}, CATInequalityQ[g, {1, 4, 13}, -1]]\
\>", "Input",ExpressionUUID->"9fadef86-db07-4543-8eb2-f685c384fe31"],

Cell["\<\
On a cycle the triangle inequality fails for non-trivial curvature \
comparisons.\
\>", "CodeText",ExpressionUUID->"58c97f6b-3ed6-4e5e-b6b6-737d7ef80474"],

Cell["With[{g = CycleGraph[8]}, CATInequalityQ[g, {1, 4, 7}]]", "Input",ExpressionUUID->"6948a5ba-0bf2-4d59-b895-215214e6ad7d"],

Cell["See also", "Section",ExpressionUUID->"5f338195-5e3e-4295-a190-3baf1012c494"],

Cell["ComparisonTriangle", "Item",ExpressionUUID->"43716f32-9d8a-4ad2-aa07-e9d214e8de64"],

Cell["InfraCurvature", "Item",ExpressionUUID->"697def0c-fdfb-4445-bfd1-d7aee6d673ef"],

Cell["InfraAngle", "Item",ExpressionUUID->"093c0196-a9c1-4c36-b21b-25c9f81ce60e"],

Cell["MetricInterval", "Item",ExpressionUUID->"17935e51-4399-442e-bab9-6e899d01754d"]
},
