Notebook[{
Cell["CATInequalityQ", "Title",ExpressionUUID->"08278b45-e7e7-4c3b-9cce-fe8c9aaa56e8"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"9b72a85b-5bb0-4e11-bee6-15cbdda770d1"],

Cell["\<\
CATInequalityQ[g, {p, q, r}, k:0] tests whether the geodesic triangle on {p, \
q, r} satisfies the CAT(k) thinness inequality. Option Method (\"ApexSide\" \
(default) \[LongDash] d(apex, x) \[LessEqual] d_k_bar(apex', x') for every \
interior vertex x on the side opposite to each apex; \"TwoRays\" \[LongDash] \
d(x, y) \[LessEqual] d_k_bar(x', y') for every cross-ray pair (x, y)). \
Returns Indeterminate when k > 0 and the triangle perimeter exceeds 2 Pi / \
Sqrt[k].\
\>", "Text",ExpressionUUID->"05071313-3cb0-4fa5-9b3f-44eea0d86f5a"],

Cell["Setup", "Section",ExpressionUUID->"9953ea00-516b-4155-bafd-68f275295cf2"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"62d60f7c-e566-4735-926c-88ef42887983"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"c1156e49-efe5-439a-a5ca-b6c7b823b577"],

Cell["Examples", "Section",ExpressionUUID->"8218b7f2-9ac9-4db7-a87d-3ce1e24fa897"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"a7c782d3-97aa-4f9f-bc9e-b7d1481534ae"],

Cell[BoxData[
 $CellContext`buildCell["CAT(0) on a path graph (always true)."]], "Input",Exp\
ressionUUID->"08902dc6-cea8-47be-8a83-c5f104a0eba2"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"5248cd3e-1e4f-47fc-934d-c61fa88b8e41"],

Cell[BoxData[
 $CellContext`buildCell[
 "CATInequalityQ[PathGraph[Range[7]], {1, 4, 7}]"]], "Input",ExpressionUUID->\
"83932de9-759e-4775-92ee-1984e37088ce"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"2e31211b-0cb7-473d-b86e-b7b93caf6460"],

Cell[BoxData[
 $CellContext`buildCell["CAT(0) on a 4x4 grid triangle."]], "Input",Expression\
UUID->"00f2332a-c200-436e-bfec-51fa845a1d54"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"23e7a848-dc8b-477c-935a-10ad0d9bd408"],

Cell[BoxData[
