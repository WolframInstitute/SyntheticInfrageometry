Notebook[{
Cell["FindInfraCommonLine", "Title",ExpressionUUID->"fb5d8d28-2c90-4733-9b8f-a18c637a0935"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"cf001745-1942-458a-96ca-9c7b6a235fbd"],

Cell["\<\
FindInfraCommonLine[g, vertices] returns the canonical lines containing every \
listed vertex. Returns a List of unary InfraSegment[{line}] wrappers or \
$Failed; n / UpTo[n] / All control multiplicity. Entries may be bare vertices \
or InfraPoint / InfraSegment / InfraRay wrappers.\
\>", "Text",ExpressionUUID->"fb134ccc-7b2c-41ca-bc86-02ba8587ade9"],

