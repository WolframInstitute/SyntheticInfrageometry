Notebook[{
Cell["TorusTessellation", "Title",ExpressionUUID->"56473336-e084-4ebc-8c2c-3596e6f9ff5b"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"e5218fc1-42c5-4c0b-bd70-44a23616171e"],

Cell["\<\
TorusTessellation[shape, {m, n}] returns the vertex-transitive flat-torus \
Cayley graph carrying the regular {p, q}-tessellation, where shape is \
\"Rectangular\" ({4, 4}, 4-regular), \"Triangular\" ({3, 6}, 6-regular), or \
\"Hexagonal\" ({6, 3}, 3-regular).\
\>", "Text",ExpressionUUID->"38977c77-01ed-4c02-9af0-086812e57215"],

Cell["Setup", "Section",ExpressionUUID->"b82f1b0c-92c6-4933-be06-18ef91e6cec0"],

