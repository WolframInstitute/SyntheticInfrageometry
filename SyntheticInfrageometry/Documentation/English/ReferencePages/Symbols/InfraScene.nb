Notebook[{
Cell["InfraScene", "Title",ExpressionUUID->"5a0cfda2-8d0a-4ecb-a9d2-30029c2119cc"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"16b30ad0-9738-4965-ad7a-d53311935d33"],

Cell["\<\
InfraScene[objects, hypotheses] constructs a scene descriptor from symbolic \
objects and construction / assertion hypotheses. Properties: \
scene[\"Steps\"], scene[\"Constructions\"], scene[\"Assertions\"], \
scene[\"DependencyGraph\"].\
\>", "Text",ExpressionUUID->"c8c219a7-b06d-431f-b1c2-6313ecb91063"],

Cell["Setup", "Section",ExpressionUUID->"1e0b9267-f8dc-4154-808e-8f543b456f04"],

Cell["Load the paclet.", "CodeText",ExpressionUUID->"22c6b0a6-6696-45ef-a09f-4a805680707f"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"c3a3deea-ca8b-4e2c-98bf-a3506a2d59df"],

Cell["Examples", "Section",ExpressionUUID->"4f180d4f-bd9d-4e31-9839-04db523c36be"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"27dff6e0-1338-440b-a560-0f5dcc86295e"],

Cell[BoxData[
 $CellContext`buildCell["Equilateral-triangle scene (Euclid I.1)."]], "Input",\
ExpressionUUID->"5a1b5198-fe4d-4faa-9375-23a1e14aa901"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"30098565-6fd2-43fa-8ee5-a0db47e67dc1"],

Cell[BoxData[
 $CellContext`buildCell[
 "InfraScene[\n  {a, b, c},\n  {\n    InfraPointQ[a], InfraPointQ[b], \
InfraPointQ[c],\n    InfraCircleQ[InfraCircle[a, InfraDistance[a, b]]],\n    \
InfraCircleQ[InfraCircle[b, InfraDistance[a, b]]],\n    c == \
InfraIntersection[InfraCircle[a, InfraDistance[a, b]], InfraCircle[b, \
InfraDistance[a, b]]]\n  }\n]"]], "Input",ExpressionUUID->"b3ef1d0d-2f3d-422b-\
9c59-662a6c5cb918"],

Cell["See Also", "Section",ExpressionUUID->"699ee2a4-f39a-41c4-acbb-0eeb5159c5f4"],

