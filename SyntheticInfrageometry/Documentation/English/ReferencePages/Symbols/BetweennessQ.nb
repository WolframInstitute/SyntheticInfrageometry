Notebook[{
Cell["BetweennessQ", "Title",ExpressionUUID->"122af86d-69b3-47ed-bd06-4a2151927862"],

Cell["\<\
BetweennessQ[graph, u, w, v] tests Tarski's betweenness B(u, w, v): w lies on \
a geodesic from u to v. Equivalently, d(u, w) + d(w, v) == d(u, v).\
\>", "Text",ExpressionUUID->"fa157130-fa8f-493f-b5e4-1f3c01c19ee8"],

Cell["Setup", "Section",ExpressionUUID->"edb21710-3f2a-4933-8f85-86e998f16fd6"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"ba3b9b52-3079-4352-a4af-d7f748f5a43b"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"093fa76d-0108-4245-9350-04a1da0e8e42"],

Cell["Usage", "Section",ExpressionUUID->"40f70a39-6911-47df-acf4-3b0e3b802e82"],

Cell["Test whether a vertex lies on a geodesic between two others.", \
"CodeText",ExpressionUUID->"b7a6741f-9ea9-44fd-b35d-a2276585a399"],

Cell[BoxData[
 RowBox[{"BetweennessQ", "[", 
  RowBox[{
   RowBox[{"CycleGraph", "[", "6", "]"}], ",", "1", ",", "2", ",", "4"}], 
  "]"}]], "Input",ExpressionUUID->"12289327-4e73-4009-aa7f-77db6719f54f"],

Cell["A negative example on the same graph.", "CodeText",ExpressionUUID->"df5af55a-2c76-43b6-99a3-ebcf3d430e22"],

Cell[BoxData[
 RowBox[{"BetweennessQ", "[", 
  RowBox[{
   RowBox[{"CycleGraph", "[", "6", "]"}], ",", "1", ",", "3", ",", "6"}], 
  "]"}]], "Input",ExpressionUUID->"19610492-f8dc-420d-aef5-ceaeeb136b74"],

Cell["Examples", "Section",ExpressionUUID->"2744a6e9-fc50-4d2a-9863-7948f9ac3a28"],

Cell["Compare with the metric interval.", "CodeText",ExpressionUUID->"1c876e07-8359-4b02-964f-07fa30b386ca"],

Cell[BoxData[
 RowBox[{"MetricInterval", "[", 
  RowBox[{
   RowBox[{"CycleGraph", "[", "6", "]"}], ",", "1", ",", "4"}], 
  "]"}]], "Input",ExpressionUUID->"0ed26e9e-8586-4e3a-8376-f2d6d990cce3"],

Cell["Check a path-graph midpoint witness.", "CodeText",ExpressionUUID->"fbe230ee-00c6-4683-9768-94eefb3400e1"],

Cell[BoxData[
 RowBox[{"BetweennessQ", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "3", ",", "5"}], 
  "]"}]], "Input",ExpressionUUID->"56740b82-31c6-48d1-9cc2-e0b717774a2d"],

Cell["See also", "Section",ExpressionUUID->"70dbca78-c7b2-4517-a33d-c11681f2914f"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"5eb42301-e7e3-4f74-8b41-7fa0e646c60a"],

Cell["TarskiStructure", "Item",ExpressionUUID->"632efc15-ae2c-4cf8-a1f8-ec662464b002"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"605b7ef4-fd69-4491-9d06-be2ca66f6981"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"55c43073-f791-4562-a5b2-269a034161ad"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"19018f6f-b2d2-43a9-b00a-71a301a7fe0f"],

Cell["MetricInterval", "Item",ExpressionUUID->"71dbae5c-28ca-476f-b715-e86689d17cd3"]
},
