Notebook[{
Cell["BetweennessQ", "Title",ExpressionUUID->"d58b403d-9336-4a05-b331-b702afd03e59"],

Cell["\<\
BetweennessQ[graph, u, w, v] tests Tarski's betweenness B(u, w, v): w lies on \
a geodesic from u to v. Equivalently, d(u, w) + d(w, v) == d(u, v).\
\>", "Text",ExpressionUUID->"83f25dcd-3c83-4148-bd88-65ebd5977b68"],

Cell["Setup", "Section",ExpressionUUID->"0a01f26c-a3e5-414a-ae84-cc6aa01618dc"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"aeab6ca9-1eba-4932-98fe-699ecc7f6e38"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"70dee12d-c3e5-4a2d-a41a-71343b03b9a6"],

Cell["Usage", "Section",ExpressionUUID->"793adf3b-5217-414f-8e57-7e1e10c72da4"],

Cell["Test whether a vertex lies on a geodesic between two others.", \
"CodeText",ExpressionUUID->"866e614a-58af-4618-8029-3228b02205fb"],

Cell[BoxData[
 RowBox[{"BetweennessQ", "[", 
  RowBox[{
   RowBox[{"CycleGraph", "[", "6", "]"}], ",", "1", ",", "2", ",", "4"}], 
  "]"}]], "Input",ExpressionUUID->"fd7be376-ef3d-4267-9c54-91897e8176ba"],

Cell["A negative example on the same graph.", "CodeText",ExpressionUUID->"8e4284ae-c247-4a13-a47c-2fbab621b86e"],

Cell[BoxData[
 RowBox[{"BetweennessQ", "[", 
  RowBox[{
   RowBox[{"CycleGraph", "[", "6", "]"}], ",", "1", ",", "3", ",", "6"}], 
  "]"}]], "Input",ExpressionUUID->"ee12712c-954f-4799-b97c-7fdf5b31c659"],

Cell["Examples", "Section",ExpressionUUID->"3532c7fb-c90b-486e-902c-33c3273adc5f"],

Cell["Compare with the metric interval.", "CodeText",ExpressionUUID->"a486a2fc-57cc-4998-a36b-c587002b6f0e"],

Cell[BoxData[
 RowBox[{"MetricInterval", "[", 
  RowBox[{
   RowBox[{"CycleGraph", "[", "6", "]"}], ",", "1", ",", "4"}], 
  "]"}]], "Input",ExpressionUUID->"02f04d52-50a9-4d7f-b060-43d1f0bf2c30"],

Cell["Check a path-graph midpoint witness.", "CodeText",ExpressionUUID->"43b76621-352e-4f5c-943c-99be45eb13d1"],

Cell[BoxData[
 RowBox[{"BetweennessQ", "[", 
  RowBox[{
   RowBox[{"PathGraph", "[", 
    RowBox[{"Range", "[", "5", "]"}], "]"}], ",", "1", ",", "3", ",", "5"}], 
  "]"}]], "Input",ExpressionUUID->"6b06d477-4a2b-4684-b623-e6e46e33e3d9"],

Cell["See also", "Section",ExpressionUUID->"fa35236e-48c3-402e-a844-bce9e20d3669"],

Cell["EquidistanceQ", "Item",ExpressionUUID->"cdb275e3-c76d-4f9c-b969-a4e6b666b373"],

Cell["TarskiStructure", "Item",ExpressionUUID->"659b5adf-8f22-4723-bc59-a8a56aefbfab"],

Cell["TarskiAxiomQ", "Item",ExpressionUUID->"b039e7cb-7afa-4228-b7a1-8a7e58d43a90"],

Cell["FindTarskiMidpoint", "Item",ExpressionUUID->"775e85a6-13f0-4267-8eb0-6b7c9b648a79"],

Cell["FindTarskiReflection", "Item",ExpressionUUID->"c9d5b31d-3d56-4f90-ac33-7b482f29c336"],

Cell["MetricInterval", "Item",ExpressionUUID->"609b11a8-cb90-4298-95b7-109421320dc8"]
},
