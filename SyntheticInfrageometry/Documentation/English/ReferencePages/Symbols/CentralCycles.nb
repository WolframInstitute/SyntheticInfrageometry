Notebook[{
Cell["CentralCycles", "Title",ExpressionUUID->"0391ce0f-3ed3-4fae-b48a-ae5a3da15bef"],

Cell["\<\
CentralCycles[graph, cycles] keeps the cycles whose maximum path-space \
distance to the rest of the bundle is minimal, with cyclic rotations factored \
out. Same Method options and operator form as CentralPaths.\
\>", "Text",ExpressionUUID->"3c580371-b37e-42dd-a506-8133d539df2c"],

Cell["Setup", "Section",ExpressionUUID->"d839688c-57fa-4d20-bc2c-9d67ea84de9c"],

Cell["Load the paclet before running the examples on this page.", "CodeText",ExpressionUUID->"503eaeca-ab78-4e0e-b6eb-cdf843db6faa"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",ExpressionUUID->"fff06e86-3177-45ac-9de3-f3a32b81c899"],

Cell["Usage", "Section",ExpressionUUID->"99dc9b8a-d622-4119-ac69-cc35a00a5b6a"],

Cell["Pick the cycle-space centres of a separating-cycle bundle.", "CodeText",ExpressionUUID->"6f3dad3a-951e-42b4-8e19-97fd02cc40fa"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"CentralCycles", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSphere", "[", 
      RowBox[{"g", ",", "6", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
       RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}]}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"6838488d-a92e-4943-a89d-\
394510cada59"],

Cell["Use the operator form after FindSphere.", "CodeText",ExpressionUUID->"719da2be-9dbb-4e85-94c2-0dc8da6d9ffd"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"CentralCycles", "[", "g", "]"}], "[", 
    RowBox[{"FindSphere", "[", 
     RowBox[{"g", ",", "6", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
      RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], 
    "]"}]}], "]"}]], "Input",ExpressionUUID->"174418b6-a8ac-405d-b45b-\
a25330219903"],

Cell["Examples", "Section",ExpressionUUID->"f5dea1c1-9bba-4cb9-9b1a-07028d2ea6af"],

Cell["Switch the base metric to Hausdorff.", "CodeText",ExpressionUUID->"fd4e3d3f-534c-4f15-8f3c-dad8236d97f1"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"CentralCycles", "[", 
    RowBox[{"g", ",", 
     RowBox[{"FindSphere", "[", 
      RowBox[{"g", ",", "6", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
       RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], "]"}], ",", 
     RowBox[{"Method", "\[Rule]", "\"\<Hausdorff\>\""}]}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"18cc16f7-353c-47b3-ac06-30ff42f53257"],

Cell["Render the central separating cycles.", "CodeText",ExpressionUUID->"104b3001-587f-43ed-8827-d41661149aea"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"g", "=", 
     RowBox[{"GridGraph", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "4"}], "}"}], "]"}]}], "}"}], ",", 
   RowBox[{"InfraSceneHighlight", "[", 
    RowBox[{"g", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"CentralCycles", "[", 
        RowBox[{"g", ",", 
         RowBox[{"FindSphere", "[", 
          RowBox[{"g", ",", "6", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "2"}], "}"}], ",", "All", ",", 
           RowBox[{"Method", "\[Rule]", "\"\<SeparatingCycle\>\""}]}], 
          "]"}]}], "]"}], "\[Rule]", "Green"}], "}"}], ",", 
     RowBox[{"\"\<Cyclic\>\"", "\[Rule]", "True"}]}], "]"}]}], "]"}]], "Input",\
ExpressionUUID->"bfdc6b22-beae-45db-bc5c-ea0b5ccf4744"],

Cell["See also", "Section",ExpressionUUID->"570befbc-4728-4b8a-a3f4-675f0f3a16e3"],

Cell["FindSegment", "Item",ExpressionUUID->"6652a7f9-ce80-4038-9735-d17fe1cfa301"],

Cell["FindLine", "Item",ExpressionUUID->"bbb07e7e-0bf1-4f53-a250-a23547850db9"],

Cell["FindSphere", "Item",ExpressionUUID->"2eb91328-5313-4dca-a54a-d514d31e9024"],

Cell["CentralPaths", "Item",ExpressionUUID->"2eaf22e8-61c0-445e-aa8b-39910e98f61c"],

Cell["EmbeddingClosestPaths", "Item",ExpressionUUID->"d50e9637-e7a1-417f-bdc6-a45dee6b056d"],

Cell["EmbeddingClosestCycles", "Item",ExpressionUUID->"5b7a061b-51a7-4221-9d71-815a571b2ee1"]
},
