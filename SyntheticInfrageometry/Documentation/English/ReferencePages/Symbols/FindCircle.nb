Notebook[{
Cell["FindInfraCircle", "Title",ExpressionUUID->"e134d1b8-6f69-4d57-a989-0140f44a724d"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"f40a7aa0-e461-4811-914d-ad6a2b8f25ba"],

Cell["\<\
FindInfraCircle[g, c, r] returns one separating cycle in the level-surface \
subgraph at radius r around c, as an open vertex sequence. Returns a List of \
unary InfraCircle[{cycle}] wrappers; n / UpTo[n] / All control multiplicity. \
Option Method (\"Combinatorial\" (default) | \"Embedding\").\
\>", "Text",ExpressionUUID->"a05f1c17-7ebb-48ea-b10c-5d425f851bca"],

Cell["Setup", "Section",ExpressionUUID->"2c157c1d-d542-45fd-9408-056dcb816951"],

