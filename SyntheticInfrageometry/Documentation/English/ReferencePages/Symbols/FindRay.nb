Notebook[{
Cell["FindRay", "Title",ExpressionUUID->"9e7e40a7-304b-475d-b70e-9fe97f56e9fb"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"355f2304-0ff1-4d0a-aef0-97b93495b191"],

Cell["\<\
FindRay[g, O, v] returns one pointed half-line from O in v's direction: the \
half of a maximal geodesic line through O and v starting at O and ending at \
the far inextensible endpoint. Returns a List of unary InfraRay[{ray}] \
wrappers; n / UpTo[n] / All control multiplicity. O and v accept InfraPoint[{\
\[Ellipsis]}] for multi-anchor spread.\
\>", "Text",ExpressionUUID->"0dcbfc35-ea05-470a-b05e-2e64dc53bf10"],

Cell["Setup", "Section",ExpressionUUID->"200d1101-b0b6-4870-9584-8a3e97bc7973"],

