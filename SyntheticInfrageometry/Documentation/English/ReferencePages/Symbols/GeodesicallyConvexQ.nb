Notebook[{
Cell["GeodesicallyConvexQ", "Title",ExpressionUUID->"df02910f-6b16-4a65-befb-9d555b7abb62"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"e2af0fd4-f571-477a-b494-35982b1f36eb"],

Cell["\<\
GeodesicallyConvexQ[g, S] tests geodesic convexity of S. Option Method \
(\"Strong\" (default): every geodesic between any pair of S lies in S; \"Weak\
\": some geodesic between each pair lies in S).\
\>", "Text",ExpressionUUID->"764a3ea6-7dd3-4400-a445-a86664b1d5fc"],

Cell["Setup", "Section",ExpressionUUID->"7ed642b3-4117-43bf-9bea-9c0c891c6bbd"],

