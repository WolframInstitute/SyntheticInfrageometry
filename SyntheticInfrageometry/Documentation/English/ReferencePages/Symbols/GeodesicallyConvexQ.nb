Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"e625afac-5e20-4f23-8215-da1a87df5a0b"],

Cell["Examples", "Section",ExpressionUUID->"9cedb5ac-d627-4bff-8777-7603a032a88a"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"7c792a74-d822-48a6-a514-bf5a384f4865"],

Cell[BoxData[
 $CellContext`buildCell["A convex hull is geodesically convex."]], "Input",Exp\
ressionUUID->"90382a29-8f8b-414b-a301-7da7fff9b048"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"195f1fb5-ebb2-47db-bde9-d6f742e7b955"],

Cell[BoxData[
 $CellContext`buildCell[
 "With[{g = GridGraph[{4, 4}]}, GeodesicallyConvexQ[g, \
FindGeodesicConvexHull[g, {1, 4, 13}]]]"]], "Input",ExpressionUUID->"a4b03bf1-\
83d0-48b1-bdc9-4c78adf783e8"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"dda07535-b519-466c-a29b-6ad1ef268ab7"],

Cell[BoxData[
 $CellContext`buildCell[
 "A path on the grid is weakly convex but not strongly."]], "Input",Expression\
UUID->"f31fb6ba-6718-49d5-a000-e16a0a9bcdf4"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"77a17fd7-dd69-46c2-958a-ff6b06e64fc9"],

