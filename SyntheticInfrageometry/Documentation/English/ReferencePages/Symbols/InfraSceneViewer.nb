Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<WolframInstitute`SyntheticInfrageometry`\>\"", 
  "]"}]], "Code",
 InitializationCell->
  True,ExpressionUUID->"7a6d5c4c-2286-4dda-9f04-a46f8bb94c43"],

Cell["Examples", "Section",ExpressionUUID->"1556da18-b5b6-4a44-876d-df80e9791695"],

Cell[BoxData[
 $CellContext`buildCell["CodeText"]], "Input",ExpressionUUID->"59eafbb5-7217-4237-9814-326afc55e6ef"],

Cell[BoxData[
 $CellContext`buildCell[
 "Interactive equilateral-triangle scene viewer."]], "Input",ExpressionUUID->\
"77eb9315-3f39-4e1e-84c6-9ae0005029da"],

Cell[BoxData[
 $CellContext`buildCell["Input"]], "Input",ExpressionUUID->"c1178975-0d9d-45f2-a13e-22282bfc6cd2"],

Cell[BoxData[
 $CellContext`buildCell[
 "InfraSceneViewer[InfraScene[{a, b, c}, {InfraPointQ[a], InfraPointQ[b], c \
== InfraIntersection[InfraCircle[a, InfraDistance[a, b]], InfraCircle[b, \
InfraDistance[a, b]]]}], GridGraph[{4, 4}]]"]], "Input",ExpressionUUID->\
"4aa4a90b-6fbb-4846-9f73-6664b455a60b"],

Cell["See Also", "Section",ExpressionUUID->"25ba0309-7bf6-462a-bf49-848a913d46de"],

