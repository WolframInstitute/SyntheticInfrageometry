Notebook[{
Cell["InfraSceneViewer", "Title",ExpressionUUID->"fa2020b6-b809-4788-9800-911c955f52fd"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"863758eb-de0c-4b48-8054-d40c14b006b8"],

Cell["\<\
InfraSceneViewer[scene, g] is an interactive visualisation of an InfraScene \
on a graph; an optional third Association of pre-fixed bindings is supported. \
Controls: step slider, \"Fix & advance\", \"Reset\".\
\>", "Text",ExpressionUUID->"feaecea5-46c1-4638-994a-204ab2109817"],

Cell["Setup", "Section",ExpressionUUID->"eff84e0f-1c25-4468-a782-62f00202fde4"],

