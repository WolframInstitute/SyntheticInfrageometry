Notebook[{
Cell["FindInfraPerpendicular", "Title",ExpressionUUID->"cfec27e4-f329-4f77-8d30-7182594b9adb"],

Cell["[LLM Generated]", "Subtitle",ExpressionUUID->"1ec1db89-622c-4b99-b4d8-ad52d8ae7ef3"],

Cell["\<\
FindInfraPerpendicular[g, line, point] returns the feet of perpendiculars from \
point to line (Euclid I.12: isosceles base midpoint construction). Returns a \
List of unary InfraPoint[{foot}] wrappers; n / UpTo[n] / All control \
multiplicity. Option Method (\"Metric\" (default) | \"Embedding\").\
\>", "Text",ExpressionUUID->"f979ba30-397b-414b-bad9-0dd940fff8ed"],

Cell["Setup", "Section",ExpressionUUID->"e2cdd263-06a7-4b12-9a60-7a8222c84493"],

