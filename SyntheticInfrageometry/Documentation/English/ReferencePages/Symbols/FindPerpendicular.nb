Cell["\<\
With[{g = GridGraph[{5, 5}], baseLine = {1, 2, 3, 4, 5}}, \
InfraSceneHighlight[g, {InfraSegment[{baseLine}] -> Blue, InfraPoint[{13}] -> \
Green, FindPerpendicular[g, baseLine, 13, 1, Method -> \"Embedding\"] -> \
Red}]]\
\>", "Input",
 CellLabel->
